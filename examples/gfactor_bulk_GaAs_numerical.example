waveVector: k0
waveVectorMax: 0.1
waveVectorStep: 1
confinement: 0
FDstep: 1
numLayers: 1
material: GaAs
numcb: 2
numvb: 6
ExternalField: 0 EF
EFParams: 0.0

# Numerical perturbation configuration
gfactorMethod: numerical
numericalTolerance: 1e-12
perturbationStep: 1e-4
useSparseSolver: false
validateWithAnalytical: true

# Band selection (CB 1 by default)
gfactorBand: cb 1
