waveVector: k0
waveVectorMax: 0.1
waveVectorStep: 1
confinement: 1
FDstep: 101
numLayers: 2
# 8nm well (from -40 to 40 Angstroms)
# Barriers 50A each side (total 180A domain)
material1: Al30Ga70As -90 90 0
material2: GaAs -40 40 0
numcb: 2
numvb: 6
ExternalField: 0 EF
EFParams: 0.0

# Numerical g-factor configuration
gfactorMethod: numerical
numericalTolerance: 1e-12
perturbationStep: 1e-4
gfactorBand: cb 1
