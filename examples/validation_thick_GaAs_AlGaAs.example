waveVector: k0
waveVectorMax: 0.1
waveVectorStep: 1
confinement: 1
FDstep: 201
numLayers: 2
# 20nm well (from -100 to 100 Angstroms)
material1: Al30Ga70As -200 200 0
material2: GaAs -100 100 0
numcb: 2
numvb: 6
ExternalField: 0 EF
EFParams: 0.0

# Numerical g-factor configuration
gfactorMethod: numerical
numericalTolerance: 1e-12
perturbationStep: 1e-6
gfactorBand: cb 1
