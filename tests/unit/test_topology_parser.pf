module test_topology_parser
  use funit
  use definitions
  use input_parser
  implicit none
contains

  @test
  subroutine test_parse_topology_and_bdg_block()
    type(simulation_config) :: cfg
    open(unit=99, file='input.toml', status='replace', action='write')
    write(99, '(A)') 'confinement = "bulk"'
    write(99, '(A)') 'FDorder = 2'
    write(99, '(A)') ''
    write(99, '(A)') '[[material]]'
    write(99, '(A)') 'name = "InAs"'
    write(99, '(A)') ''
    write(99, '(A)') '[wave_vector]'
    write(99, '(A)') 'mode = "k0"'
    write(99, '(A)') ''
    write(99, '(A)') '[bands]'
    write(99, '(A)') 'num_cb = 2'
    write(99, '(A)') 'num_vb = 6'
    write(99, '(A)') ''
    write(99, '(A)') '[topology]'
    write(99, '(A)') 'mode = "bdg"'
    write(99, '(A)') 'compute_chern = true'
    write(99, '(A)') ''
    write(99, '(A)') '[bdg]'
    write(99, '(A)') 'mu = 0.010'
    write(99, '(A)') 'delta_0 = 0.0003'
    close(99)
    call read_config(cfg)
    @assertTrue(cfg%topo%enabled)
    @assertEqual('bdg', trim(cfg%topo%mode))
    @assertTrue(cfg%topo%compute_chern)
    @assertTrue(cfg%bdg%enabled)
    @assertEqual(0.010_dp, cfg%bdg%mu, tolerance=1.0e-6_dp)
    @assertEqual(0.0003_dp, cfg%bdg%delta_0, tolerance=1.0e-8_dp)
    close(unit=99, status='delete')
  end subroutine

  @test
  subroutine test_parse_topology_false_values()
    type(simulation_config) :: cfg
    open(unit=99, file='input.toml', status='replace', action='write')
    write(99, '(A)') 'confinement = "bulk"'
    write(99, '(A)') 'FDorder = 2'
    write(99, '(A)') ''
    write(99, '(A)') '[[material]]'
    write(99, '(A)') 'name = "InAs"'
    write(99, '(A)') ''
    write(99, '(A)') '[wave_vector]'
    write(99, '(A)') 'mode = "k0"'
    write(99, '(A)') ''
    write(99, '(A)') '[bands]'
    write(99, '(A)') 'num_cb = 2'
    write(99, '(A)') 'num_vb = 6'
    write(99, '(A)') ''
    write(99, '(A)') '[topology]'
    write(99, '(A)') 'mode = "qhe"'
    write(99, '(A)') 'compute_chern = false'
    write(99, '(A)') 'compute_hall = false'
    write(99, '(A)') 'qwz_u = 2.0'
    write(99, '(A)') 'compute_z2 = false'
    write(99, '(A)') 'extract_edge_states = false'
    write(99, '(A)') 'edge_E_window = 0.05'
    write(99, '(A)') 'compute_ldos = false'
    write(99, '(A)') 'ldos_eta = 0.001'
    write(99, '(A)') 'ldos_E_range = [-0.1, 0.1]'
    write(99, '(A)') 'ldos_num_E = 100'
    close(99)
    call read_config(cfg)
    @assertTrue(cfg%topo%enabled)
    @assertEqual('qhe', trim(cfg%topo%mode))
    @assertFalse(cfg%topo%compute_chern)
    @assertFalse(cfg%topo%compute_hall)
    @assertFalse(cfg%topo%compute_z2)
    @assertFalse(cfg%topo%extract_edge_states)
    @assertFalse(cfg%topo%compute_ldos)
    @assertEqual(0.05_dp, cfg%topo%edge_E_window, tolerance=1.0e-12_dp)
    @assertEqual(-0.1_dp, cfg%topo%ldos_E_range(1), tolerance=1.0e-12_dp)
    @assertEqual(0.1_dp, cfg%topo%ldos_E_range(2), tolerance=1.0e-12_dp)
    @assertEqual(100, cfg%topo%ldos_num_E)
    close(unit=99, status='delete')
  end subroutine

  @test
  subroutine test_parse_topology_phase6_name_aware_fields()
    type(simulation_config) :: cfg

    open(unit=99, file='input.toml', status='replace', action='write')
    write(99, '(A)') 'confinement = "bulk"'
    write(99, '(A)') 'fd_step = 1'
    write(99, '(A)') 'FDorder = 2'
    write(99, '(A)') ''
    write(99, '(A)') '[[material]]'
    write(99, '(A)') 'name = "InAs"'
    write(99, '(A)') ''
    write(99, '(A)') '[wave_vector]'
    write(99, '(A)') 'mode = "k0"'
    write(99, '(A)') ''
    write(99, '(A)') '[bands]'
    write(99, '(A)') 'num_cb = 2'
    write(99, '(A)') 'num_vb = 6'
    write(99, '(A)') ''
    write(99, '(A)') '[topology]'
    write(99, '(A)') 'mode = "conductance"'
    write(99, '(A)') 'compute_chern = false'
    write(99, '(A)') 'compute_hall = false'
    write(99, '(A)') 'qwz_u = -0.8'
    write(99, '(A)') 'compute_z2 = false'
    write(99, '(A)') 'extract_edge_states = false'
    write(99, '(A)') 'edge_E_window = 0.01'
    write(99, '(A)') 'compute_ldos = false'
    write(99, '(A)') 'ldos_eta = 0.001'
    write(99, '(A)') 'ldos_E_range = [-0.1, 0.1]'
    write(99, '(A)') 'ldos_num_E = 10'
    write(99, '(A)') 'compute_spectral = true'
    write(99, '(A)') 'spectral_E_min = -0.2'
    write(99, '(A)') 'spectral_E_max = 0.2'
    write(99, '(A)') 'spectral_nE = 21'
    write(99, '(A)') 'spectral_eta = 0.004'
    write(99, '(A)') 'conductance_method = "landauer"'
    write(99, '(A)') 'spectral_k_min = -0.02'
    write(99, '(A)') 'spectral_k_max = 0.02'
    write(99, '(A)') 'spectral_nk = 5'
    write(99, '(A)') 'compute_conductance = true'
    write(99, '(A)') 'berry_nk = 9'
    write(99, '(A)') 'landauer_energy = 0.03'
    write(99, '(A)') 'compute_gap_sweep = true'
    write(99, '(A)') 'gap_sweep_mu_min = 0.0'
    write(99, '(A)') 'gap_sweep_mu_max = 0.002'
    write(99, '(A)') 'gap_sweep_nMu = 2'
    write(99, '(A)') 'sweep_model = "bhz_analytic"'
    write(99, '(A)') 'gap_sweep_B_min = -0.01'
    write(99, '(A)') 'gap_sweep_B_max = 0.01'
    write(99, '(A)') 'gap_sweep_nB = 3'
    close(99)

    call read_config(cfg)

    @assertTrue(cfg%topo%compute_spectral)
    @assertEqual(5, cfg%topo%spectral_nk)
    @assertEqual(21, cfg%topo%spectral_nE)
    @assertEqual(0.004_dp, cfg%topo%spectral_eta, tolerance=1.0e-12_dp)
    @assertTrue(cfg%topo%compute_conductance)
    @assertEqual('landauer', trim(cfg%topo%conductance_method))
    @assertEqual(9, cfg%topo%berry_nk)
    @assertEqual(0.03_dp, cfg%topo%landauer_energy, tolerance=1.0e-12_dp)
    @assertTrue(cfg%topo%compute_gap_sweep)
    @assertEqual(3, cfg%topo%gap_sweep_nB)
    @assertEqual(2, cfg%topo%gap_sweep_nMu)
    @assertEqual('bhz_analytic', trim(cfg%topo%sweep_model))

    close(unit=99, status='delete')
  end subroutine test_parse_topology_phase6_name_aware_fields

  @test
  subroutine test_parse_topology_old_qhe_block()
    type(simulation_config) :: cfg

    open(unit=99, file='input.toml', status='replace', action='write')
    write(99, '(A)') 'confinement = "bulk"'
    write(99, '(A)') 'fd_step = 1'
    write(99, '(A)') 'FDorder = 2'
    write(99, '(A)') ''
    write(99, '(A)') '[[material]]'
    write(99, '(A)') 'name = "InAs"'
    write(99, '(A)') ''
    write(99, '(A)') '[wave_vector]'
    write(99, '(A)') 'mode = "k0"'
    write(99, '(A)') ''
    write(99, '(A)') '[bands]'
    write(99, '(A)') 'num_cb = 2'
    write(99, '(A)') 'num_vb = 6'
    write(99, '(A)') ''
    write(99, '(A)') '[topology]'
    write(99, '(A)') 'mode = "qhe"'
    write(99, '(A)') 'compute_chern = true'
    close(99)

    call read_config(cfg)

    @assertTrue(cfg%topo%enabled)
    @assertEqual('qhe', trim(cfg%topo%mode))
    @assertTrue(cfg%topo%compute_chern)

    close(unit=99, status='delete')
  end subroutine test_parse_topology_old_qhe_block

  @test
  subroutine test_parse_topology_sweep_model()
    type(simulation_config) :: cfg

    open(unit=99, file='input.toml', status='replace', action='write')
    write(99, '(A)') 'confinement = "bulk"'
    write(99, '(A)') 'fd_step = 1'
    write(99, '(A)') 'FDorder = 2'
    write(99, '(A)') ''
    write(99, '(A)') '[[material]]'
    write(99, '(A)') 'name = "InAs"'
    write(99, '(A)') ''
    write(99, '(A)') '[wave_vector]'
    write(99, '(A)') 'mode = "k0"'
    write(99, '(A)') ''
    write(99, '(A)') '[bands]'
    write(99, '(A)') 'num_cb = 2'
    write(99, '(A)') 'num_vb = 6'
    write(99, '(A)') ''
    write(99, '(A)') '[topology]'
    write(99, '(A)') 'mode = "sweep"'
    write(99, '(A)') 'compute_chern = false'
    write(99, '(A)') 'compute_hall = false'
    write(99, '(A)') 'qwz_u = 0.0'
    write(99, '(A)') 'compute_z2 = false'
    write(99, '(A)') 'extract_edge_states = false'
    write(99, '(A)') 'edge_E_window = 0.01'
    write(99, '(A)') 'compute_ldos = false'
    write(99, '(A)') 'ldos_eta = 0.001'
    write(99, '(A)') 'ldos_E_range = [-0.1, 0.1]'
    write(99, '(A)') 'ldos_num_E = 10'
    write(99, '(A)') 'compute_gap_sweep = true'
    write(99, '(A)') 'gap_sweep_B_min = -0.01'
    write(99, '(A)') 'gap_sweep_B_max = 0.01'
    write(99, '(A)') 'gap_sweep_nB = 3'
    write(99, '(A)') 'gap_sweep_mu_min = 0.0'
    write(99, '(A)') 'gap_sweep_mu_max = 0.001'
    write(99, '(A)') 'gap_sweep_nMu = 2'
    write(99, '(A)') 'sweep_model = "qw_fukane"'
    close(99)

    call read_config(cfg)

    @assertTrue(cfg%topo%compute_gap_sweep)
    @assertEqual('qw_fukane', trim(cfg%topo%sweep_model))
    @assertEqual(3, cfg%topo%gap_sweep_nB)
    @assertEqual(2, cfg%topo%gap_sweep_nMu)

    close(unit=99, status='delete')
  end subroutine

end module
