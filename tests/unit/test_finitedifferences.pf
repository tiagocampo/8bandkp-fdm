module test_finitedifferences
  use funit
  use definitions
  use finitedifferences
  implicit none

contains

  @test
  subroutine test_identity()
    real(kind=dp), allocatable :: mat(:,:)
    integer :: i, n
    n = 5
    call Identity(n, mat)
    do i = 1, n
      @assertEqual(1.0_dp, mat(i,i), tolerance=1.0e-14_dp)
    end do
    ! Off-diagonal should be zero
    @assertEqual(0.0_dp, mat(1,2), tolerance=1.0e-14_dp)
    @assertEqual(0.0_dp, mat(3,5), tolerance=1.0e-14_dp)
  end subroutine test_identity

  @test
  subroutine test_identity_scaled()
    real(kind=dp), allocatable :: mat(:,:)
    call Identity(3, mat, factor=2.5_dp)
    @assertEqual(2.5_dp, mat(1,1), tolerance=1.0e-14_dp)
    @assertEqual(2.5_dp, mat(2,2), tolerance=1.0e-14_dp)
    @assertEqual(2.5_dp, mat(3,3), tolerance=1.0e-14_dp)
    @assertEqual(0.0_dp, mat(1,2), tolerance=1.0e-14_dp)
  end subroutine test_identity_scaled

  @test
  subroutine test_buildFD2ndDeriv_order2()
    ! d2/dz2 of f(z) = z^2 should be exactly 2.0 at all interior points
    integer, parameter :: N = 11
    real(kind=dp) :: dz, z(N), f(N)
    real(kind=dp), allocatable :: D2(:,:)
    real(kind=dp), allocatable :: result(:)
    integer :: i

    dz = 0.1_dp
    do i = 1, N
      z(i) = (i - 1) * dz
      f(i) = z(i)**2
    end do

    call buildFD2ndDerivMatrix(N, dz, 2, D2)

    ! D2 * f should be ~2.0 at interior points
    allocate(result(N))
    result = matmul(D2, f)

    ! Check interior points (order 2: only 1 boundary point on each side)
    do i = 2, N-1
      @assertEqual(2.0_dp, result(i), tolerance=1.0e-6_dp, message="Interior point d2f/dz2")
    end do
  end subroutine test_buildFD2ndDeriv_order2

  @test
  subroutine test_buildFD2ndDeriv_order4()
    ! d2/dz2 of f(z) = z^3 should be exactly 6*z at all points (order 4 accurate)
    integer, parameter :: N = 21
    real(kind=dp) :: dz, z(N), f(N)
    real(kind=dp), allocatable :: D2(:,:), result(:)
    integer :: i

    dz = 0.05_dp
    do i = 1, N
      z(i) = (i - 1) * dz
      f(i) = z(i)**3
    end do

    call buildFD2ndDerivMatrix(N, dz, 4, D2)

    allocate(result(N))
    result = matmul(D2, f)

    ! Interior points: d2(z^3)/dz2 = 6*z, should be accurate to O(h^4)
    do i = 3, N-2
      @assertEqual(6.0_dp*z(i), result(i), tolerance=1.0e-4_dp, message="Order-4 interior d2f/dz2")
    end do
  end subroutine test_buildFD2ndDeriv_order4

  @test
  subroutine test_buildFD2ndDeriv_constant_zero()
    ! D2 applied to a constant function should be zero at interior points.
    ! This verifies the "central coefficients sum to zero" property through
    ! the public matrix API.
    integer, parameter :: N = 21
    real(kind=dp) :: dz, f(N)
    real(kind=dp), allocatable :: D2(:,:), result(:)
    integer :: i
    integer, parameter :: FDorder = 4

    dz = 0.05_dp
    f = 1.0_dp

    call buildFD2ndDerivMatrix(N, dz, FDorder, D2)

    allocate(result(N))
    result = matmul(D2, f)

    ! Interior points should be zero (coefficients sum to zero)
    do i = FDorder/2 + 1, N - FDorder/2
      @assertTrue(abs(result(i)) < 1.0e-12_dp, message="D2 * const = 0 at interior")
    end do
  end subroutine test_buildFD2ndDeriv_constant_zero

  @test
  subroutine test_buildFD2ndDeriv_order2_structure()
    ! Verify structural properties of the order-2 D2 matrix:
    ! tridiagonal, correct diagonal/off-diagonal values, hardwall corners.
    integer, parameter :: N = 5
    real(kind=dp) :: dz
    real(kind=dp), allocatable :: D2(:,:)
    integer :: i, j

    dz = 0.1_dp
    call buildFD2ndDerivMatrix(N, dz, 2, D2)

    ! Interior points: diagonal = -2/dz^2, off-diagonal = 1/dz^2
    do i = 2, N-1
      @assertEqual(-2.0_dp/dz**2, D2(i,i), tolerance=1.0e-12_dp, message="Diagonal value")
      @assertEqual(1.0_dp/dz**2, D2(i,i-1), tolerance=1.0e-12_dp, message="Lower off-diag")
      @assertEqual(1.0_dp/dz**2, D2(i,i+1), tolerance=1.0e-12_dp, message="Upper off-diag")
    end do

    ! Hardwall: corner elements should be zero (no periodic wrap)
    @assertEqual(0.0_dp, D2(1,N), tolerance=1.0e-14_dp, message="Hardwall top-right")
    @assertEqual(0.0_dp, D2(N,1), tolerance=1.0e-14_dp, message="Hardwall bottom-left")

    ! Tridiagonal structure at interior: elements beyond ±1 off-diagonal are zero
    do i = 2, N-1
      do j = 1, N
        if (abs(j - i) > 1) then
          @assertEqual(0.0_dp, D2(i,j), tolerance=1.0e-14_dp, message="Tridiag zero element")
        end if
      end do
    end do
  end subroutine test_buildFD2ndDeriv_order2_structure

  @test
  subroutine test_buildFD1stDeriv_order10()
    ! D1 applied to f(z) = z^2 should give 2z at interior points.
    ! Tests order-10 1st derivative through the public matrix API.
    integer, parameter :: N = 25, FDorder = 10
    real(kind=dp) :: dz, z(N), f(N)
    real(kind=dp), allocatable :: D1(:,:), result(:)
    integer :: i

    dz = 0.05_dp
    do i = 1, N
      z(i) = (i - 1) * dz
      f(i) = z(i)**2
    end do

    call buildFD1stDerivMatrix(N, dz, FDorder, D1)

    allocate(result(N))
    result = matmul(D1, f)

    ! Interior points: d(z^2)/dz = 2z, should be accurate to O(h^10)
    do i = FDorder/2 + 1, N - FDorder/2
      @assertEqual(2.0_dp*z(i), result(i), tolerance=1.0e-6_dp, message="Order-10 D1 of z^2")
    end do
  end subroutine test_buildFD1stDeriv_order10

end module test_finitedifferences
