  ! --- Variable-coefficient 2nd derivative tests ---

  @test
  subroutine test_varcoeff_d2_order2_convergence()
    real(kind=dp) :: obs_rate
    call compute_varcoeff_convergence_rate(2, obs_rate)
    @assertTrue(abs(obs_rate - 2.0_dp) < rate_tolerance(2))
  end subroutine test_varcoeff_d2_order2_convergence

  @test
  subroutine test_varcoeff_d2_order4_convergence()
    real(kind=dp) :: obs_rate
    call compute_varcoeff_convergence_rate(4, obs_rate)
    @assertTrue(abs(obs_rate - 4.0_dp) < rate_tolerance(4))
  end subroutine test_varcoeff_d2_order4_convergence

  @test
  subroutine test_varcoeff_d2_order6_convergence()
    real(kind=dp) :: obs_rate
