  end subroutine test_legacy_d2_order10_convergence

  ! --- Legacy API 1st-derivative tests ---
  ! Legacy FDstencil only implements 1st-derivative at orders 2 and 8.
  ! Orders 4, 6, 10 silently return zero vector — known gap, not tested.

  @test
  subroutine test_legacy_d1_order2_convergence()
    real(kind=dp) :: obs_rate
    call compute_legacy_convergence_rate(1, 2, obs_rate)
    @assertTrue(abs(obs_rate - 2.0_dp) < rate_tolerance(2))
  end subroutine test_legacy_d1_order2_convergence

  @test
  subroutine test_legacy_d1_order8_convergence()
    real(kind=dp) :: obs_rate
    call compute_legacy_convergence_rate(1, 8, obs_rate)
    @assertTrue(abs(obs_rate - 8.0_dp) < rate_tolerance(8))
  end subroutine test_legacy_d1_order8_convergence

end module test_fd_convergence
