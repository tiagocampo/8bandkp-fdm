    @assertTrue(abs(obs_rate - 8.0_dp) < rate_tolerance(8))
  end subroutine test_d1_order8_convergence

  @test
  subroutine test_d1_order10_convergence()
    real(kind=dp) :: obs_rate
    call compute_convergence_rate(10, 1, obs_rate)
    @assertTrue(abs(obs_rate - 10.0_dp) < rate_tolerance(10))
  end subroutine test_d1_order10_convergence

  ! --- Interpolation convergence tests ---

  @test
  subroutine test_interp_order2_convergence()
    real(kind=dp) :: obs_rate
    call compute_interp_convergence_rate(2, obs_rate)
    @assertTrue(abs(obs_rate - 2.0_dp) < rate_tolerance(2))
  end subroutine test_interp_order2_convergence

  @test
  subroutine test_interp_order4_convergence()
    real(kind=dp) :: obs_rate
    call compute_interp_convergence_rate(4, obs_rate)
