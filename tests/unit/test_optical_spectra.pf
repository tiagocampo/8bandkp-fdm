module test_optical_spectra
  use funit
  use definitions
  use sparse_matrices, only: csr_matrix, csr_build_from_coo, csr_free
  use optical_spectra
  implicit none

contains

  ! ==================================================================
  ! Test 1: optics_engine_init allocates and zeros E_grid, alpha_te,
  ! alpha_tm, alpha_isbt
  ! ==================================================================
  @test
  subroutine test_engine_init_allocates_zeros()
    type(optics_engine) :: oe
    type(optics_config) :: optcfg

    call make_default_config(optcfg)
    call optics_init(oe, optcfg)

    ! Arrays should be allocated
    @assertTrue(allocated(oe%E_grid))
    @assertTrue(allocated(oe%alpha_te))
    @assertTrue(allocated(oe%alpha_tm))
    @assertTrue(allocated(oe%alpha_isbt))

    ! Size should match num_energy_points
    @assertEqual(optcfg%num_energy_points, size(oe%E_grid))
    @assertEqual(optcfg%num_energy_points, size(oe%alpha_te))
    @assertEqual(optcfg%num_energy_points, size(oe%alpha_tm))
    @assertEqual(optcfg%num_energy_points, size(oe%alpha_isbt))

    ! All arrays should be zeroed
    @assertEqual(0.0_dp, maxval(abs(oe%alpha_te)))
    @assertEqual(0.0_dp, maxval(abs(oe%alpha_tm)))
    @assertEqual(0.0_dp, maxval(abs(oe%alpha_isbt)))

    ! E_grid should be linearly spaced
    @assertTrue(oe%E_grid(1) > 0.0_dp)

    ! nE should be set
    @assertEqual(optcfg%num_energy_points, oe%nE)

    call optics_free(oe)
  end subroutine test_engine_init_allocates_zeros


  ! ==================================================================
  ! Test 2: optics_engine_free deallocates all arrays and resets nE
  ! ==================================================================
  @test
  subroutine test_engine_free_deallocates()
    type(optics_engine) :: oe
    type(optics_config) :: optcfg

    call make_default_config(optcfg)
    call optics_init(oe, optcfg)

    ! Confirm arrays are allocated before free
    @assertTrue(allocated(oe%E_grid))
    @assertTrue(allocated(oe%alpha_te))

    call optics_free(oe)

    ! All arrays should be deallocated
    @assertFalse(allocated(oe%E_grid))
    @assertFalse(allocated(oe%alpha_te))
    @assertFalse(allocated(oe%alpha_tm))
    @assertFalse(allocated(oe%alpha_isbt))
    @assertFalse(allocated(oe%alpha_gain_te))
    @assertFalse(allocated(oe%alpha_gain_tm))
    @assertFalse(allocated(oe%spont_te))
    @assertFalse(allocated(oe%spont_tm))
    @assertFalse(allocated(oe%alpha_te_up))
    @assertFalse(allocated(oe%alpha_te_dw))
    @assertFalse(allocated(oe%alpha_tm_up))
    @assertFalse(allocated(oe%alpha_tm_dw))

    ! nE should be reset
    @assertEqual(0, oe%nE)

    ! Gain state should be reset
    @assertFalse(oe%gain_fermi_computed)
    @assertEqual(0.0_dp, oe%mu_e)
    @assertEqual(0.0_dp, oe%mu_h)
  end subroutine test_engine_free_deallocates


  ! ==================================================================
  ! Test 3: double-free is safe (calling free on already-freed type)
  ! ==================================================================
  @test
  subroutine test_engine_double_free_safe()
    type(optics_engine) :: oe
    type(optics_config) :: optcfg

    call make_default_config(optcfg)
    call optics_init(oe, optcfg)
    call optics_free(oe)

    ! Second free should not crash
    call optics_free(oe)

    @assertEqual(0, oe%nE)
    @assertFalse(allocated(oe%E_grid))
  end subroutine test_engine_double_free_safe


  ! ==================================================================
  ! Test 4: finalizer fires on scope exit
  ! ==================================================================
  @test
  subroutine test_engine_finalizer()
    type(optics_config) :: optcfg

    call make_default_config(optcfg)

    ! Call subroutine that creates and lets optics_engine go out of scope
    call finalizer_helper(optcfg)

    ! If we reach here, the finalizer ran without error
    @assertTrue(.true.)
  end subroutine test_engine_finalizer


  ! ==================================================================
  ! Test 5: conditional allocation — gain arrays only when gain_enabled
  ! ==================================================================
  @test
  subroutine test_engine_gain_conditional()
    type(optics_engine) :: oe
    type(optics_config) :: optcfg

    ! Without gain: arrays should NOT be allocated
    call make_default_config(optcfg)
    optcfg%gain_enabled = .false.
    call optics_init(oe, optcfg)
    @assertFalse(allocated(oe%alpha_gain_te))
    @assertFalse(allocated(oe%alpha_gain_tm))
    call optics_free(oe)

    ! With gain: arrays SHOULD be allocated and zeroed
    call make_default_config(optcfg)
    optcfg%gain_enabled = .true.
    call optics_init(oe, optcfg)
    @assertTrue(allocated(oe%alpha_gain_te))
    @assertTrue(allocated(oe%alpha_gain_tm))
    @assertEqual(optcfg%num_energy_points, size(oe%alpha_gain_te))
    @assertEqual(0.0_dp, maxval(abs(oe%alpha_gain_te)))
    @assertEqual(0.0_dp, maxval(abs(oe%alpha_gain_tm)))
    call optics_free(oe)
  end subroutine test_engine_gain_conditional


  ! ==================================================================
  ! Test 6: conditional allocation — spontaneous arrays only when
  ! spontaneous_enabled
  ! ==================================================================
  @test
  subroutine test_engine_spontaneous_conditional()
    type(optics_engine) :: oe
    type(optics_config) :: optcfg

    ! Without spontaneous: arrays should NOT be allocated
    call make_default_config(optcfg)
    optcfg%spontaneous_enabled = .false.
    call optics_init(oe, optcfg)
    @assertFalse(allocated(oe%spont_te))
    @assertFalse(allocated(oe%spont_tm))
    call optics_free(oe)

    ! With spontaneous: arrays SHOULD be allocated and zeroed
    call make_default_config(optcfg)
    optcfg%spontaneous_enabled = .true.
    call optics_init(oe, optcfg)
    @assertTrue(allocated(oe%spont_te))
    @assertTrue(allocated(oe%spont_tm))
    @assertEqual(optcfg%num_energy_points, size(oe%spont_te))
    @assertEqual(0.0_dp, maxval(abs(oe%spont_te)))
    @assertEqual(0.0_dp, maxval(abs(oe%spont_tm)))
    call optics_free(oe)
  end subroutine test_engine_spontaneous_conditional


  ! ==================================================================
  ! Test 7: conditional allocation — spin-resolved arrays only when
  ! spin_resolved
  ! ==================================================================
  @test
  subroutine test_engine_spin_resolved_conditional()
    type(optics_engine) :: oe
    type(optics_config) :: optcfg

    ! Without spin_resolved: arrays should NOT be allocated
    call make_default_config(optcfg)
    optcfg%spin_resolved = .false.
    call optics_init(oe, optcfg)
    @assertFalse(allocated(oe%alpha_te_up))
    @assertFalse(allocated(oe%alpha_te_dw))
    @assertFalse(allocated(oe%alpha_tm_up))
    @assertFalse(allocated(oe%alpha_tm_dw))
    call optics_free(oe)

    ! With spin_resolved: arrays SHOULD be allocated and zeroed
    call make_default_config(optcfg)
    optcfg%spin_resolved = .true.
    call optics_init(oe, optcfg)
    @assertTrue(allocated(oe%alpha_te_up))
    @assertTrue(allocated(oe%alpha_te_dw))
    @assertTrue(allocated(oe%alpha_tm_up))
    @assertTrue(allocated(oe%alpha_tm_dw))
    @assertEqual(optcfg%num_energy_points, size(oe%alpha_te_up))
    @assertEqual(0.0_dp, maxval(abs(oe%alpha_te_up)))
    @assertEqual(0.0_dp, maxval(abs(oe%alpha_te_dw)))
    @assertEqual(0.0_dp, maxval(abs(oe%alpha_tm_up)))
    @assertEqual(0.0_dp, maxval(abs(oe%alpha_tm_dw)))
    call optics_free(oe)
  end subroutine test_engine_spin_resolved_conditional


  ! ==================================================================
  ! Test 8: config is stored in the engine
  ! ==================================================================
  @test
  subroutine test_engine_config_stored()
    type(optics_engine) :: oe
    type(optics_config) :: optcfg

    call make_default_config(optcfg)
    optcfg%linewidth_lorentzian = 0.05_dp
    optcfg%temperature = 200.0_dp
    call optics_init(oe, optcfg)

    @assertEqual(0.05_dp, oe%config%linewidth_lorentzian)
    @assertEqual(200.0_dp, oe%config%temperature)
    @assertEqual(optcfg%num_energy_points, oe%config%num_energy_points)

    call optics_free(oe)
  end subroutine test_engine_config_stored


  ! ==================================================================
  ! Helper: construct a default optics_config
  ! ==================================================================
  subroutine make_default_config(optcfg)
    type(optics_config), intent(out) :: optcfg

    optcfg%enabled = .true.
    optcfg%linewidth_lorentzian = 0.030_dp
    optcfg%linewidth_gaussian = 0.005_dp
    optcfg%refractive_index = 3.3_dp
    optcfg%temperature = 300.0_dp
    optcfg%num_energy_points = 50
    optcfg%E_min = 0.5_dp
    optcfg%E_max = 2.0_dp
    optcfg%carrier_density = 0.0_dp
    optcfg%gain_enabled = .false.
    optcfg%gain_carrier_density = 3.0e12_dp
    optcfg%isbt_enabled = .false.
    optcfg%spontaneous_enabled = .false.
    optcfg%spin_resolved = .false.
    optcfg%confinement = 'bulk'
  end subroutine make_default_config


  ! Helper for finalizer test: creates engine in inner scope
  subroutine finalizer_helper(optcfg)
    type(optics_config), intent(in) :: optcfg
    type(optics_engine) :: oe

    call optics_init(oe, optcfg)
    @assertTrue(allocated(oe%E_grid))
    ! oe goes out of scope here — finalizer should fire
  end subroutine finalizer_helper


  ! ==================================================================
  ! Helper: build a small 8x8 diagonal CSR matrix with value val on
  ! the diagonal for direction dir.
  ! For dir=1 (x): val on diagonal entries 7,8 (CB block)
  ! For dir=2 (y): val on diagonal entries 7,8
  ! For dir=3 (z): val on diagonal entries 7,8
  !
  ! This simulates velocity matrices for an 8-band bulk system with
  ! 1 grid point (Ngrid=1, dim=8).  The velocity operator is non-zero
  ! only in the off-diagonal CB-VB coupling blocks, but for testing
  ! purposes we use a simple diagonal matrix where dir=3 has a known
  ! value on rows 7,8 (CB states) and cols 1 (VB state).
  !
  ! Simpler approach: identity-like matrix with known value.
  ! Actually: build a single element CSR that maps VB(1) -> CB(7) for
  ! dir=3 (z-dipole), and VB(1) -> CB(7) for dir=1,2.
  !
  ! For a bulk 8x8 system: dim=8, numvb=6, numcb=2.
  ! The accumulate loop iterates VB i=1..6, CB j=1..2.
  ! For testing, we want at least one VB-CB pair to produce non-zero
  ! |<CB|vel|VB>|^2.
  ! ==================================================================
  subroutine build_test_vel_identity(dim, vel)
    integer, intent(in) :: dim
    type(csr_matrix), intent(out) :: vel(3)

    integer :: i
    integer, allocatable :: rows(:), cols(:)
    complex(kind=dp), allocatable :: vals(:)

    ! Build a diagonal matrix: vel(dir) = I (identity).
    ! This means <CB|vel|VB> = delta_{CB,VB} = 0 for CB != VB.
    ! Not useful. Instead, build vel that has a known off-diagonal element.
    !
    ! For each direction: put val = (1,0) at (CB_row, VB_col).
    ! CB rows are 7,8. VB columns are 1..6.
    ! So vel(dir) has entry at (7,1) and (8,2) for all dirs.

    allocate(rows(2), cols(2), vals(2))
    rows(1) = 7; cols(1) = 1; vals(1) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    rows(2) = 8; cols(2) = 2; vals(2) = cmplx(1.0_dp, 0.0_dp, kind=dp)

    do i = 1, 3
      call csr_build_from_coo(vel(i), dim, dim, 2, rows, cols, vals)
    end do

    deallocate(rows, cols, vals)
  end subroutine build_test_vel_identity


  ! ==================================================================
  ! Test 9: optics_accumulate_engine produces non-zero alpha_te
  ! ==================================================================
  @test
  subroutine test_accumulate_engine_nonzero_alpha_te()
    type(optics_engine) :: oe
    type(optics_config) :: optcfg
    type(csr_matrix) :: vel(3)

    integer, parameter :: dim = 8   ! bulk 8x8
    integer, parameter :: numvb = 6, numcb = 2
    real(kind=dp) :: eigvals(numvb + numcb)
    complex(kind=dp) :: eigvecs(dim, numvb + numcb)
    real(kind=dp) :: k_weight, fermi_level

    ! Config: small energy grid with positive E_min
    call make_default_config(optcfg)
    optcfg%num_energy_points = 5
    optcfg%E_min = 0.5_dp
    optcfg%E_max = 2.0_dp
    optcfg%confinement = 'bulk'   ! bulk mode
    call optics_init(oe, optcfg)

    ! Eigenvalues: VB states low, CB states high
    ! VB: -1.0, -0.9, -0.8, -0.7, -0.6, -0.5
    ! CB:  1.0,  1.1
    eigvals(1:6) = [-1.0_dp, -0.9_dp, -0.8_dp, -0.7_dp, -0.6_dp, -0.5_dp]
    eigvals(7:8) = [1.0_dp, 1.1_dp]

    ! Eigenvectors: identity (each state is a pure basis state)
    eigvecs = cmplx(0.0_dp, 0.0_dp, kind=dp)
    eigvecs(1,1) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(2,2) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(3,3) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(4,4) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(5,5) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(6,6) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(7,7) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(8,8) = cmplx(1.0_dp, 0.0_dp, kind=dp)

    ! Build velocity matrices with known off-diagonal elements
    call build_test_vel_identity(dim, vel)

    k_weight = 1.0_dp
    fermi_level = 0.0_dp   ! mid-gap

    ! Call the new engine routine
    call optics_accumulate(oe, eigvals, eigvecs, k_weight, &
      & vel, numcb, numvb, fermi_level)

    ! alpha_te should be non-zero (at least some VB-CB transitions)
    @assertTrue(maxval(abs(oe%alpha_te)) > 0.0_dp, message="alpha_te non-zero after accumulate")

    ! Cleanup
    call optics_free(oe)
    call csr_free(vel(1))
    call csr_free(vel(2))
    call csr_free(vel(3))
  end subroutine test_accumulate_engine_nonzero_alpha_te


  ! ==================================================================
  ! Test 10: optics_accumulate_engine bulk mode (TE == TM)
  ! ==================================================================
  @test
  subroutine test_accumulate_engine_bulk_te_eq_tm()
    type(optics_engine) :: oe
    type(optics_config) :: optcfg
    type(csr_matrix) :: vel(3)

    integer, parameter :: dim = 8
    integer, parameter :: numvb = 6, numcb = 2
    real(kind=dp) :: eigvals(numvb + numcb)
    complex(kind=dp) :: eigvecs(dim, numvb + numcb)
    real(kind=dp) :: k_weight, fermi_level
    real(kind=dp) :: max_diff

    call make_default_config(optcfg)
    optcfg%num_energy_points = 5
    optcfg%E_min = 0.5_dp
    optcfg%E_max = 2.0_dp
    optcfg%confinement = 'bulk'   ! bulk: TE == TM
    call optics_init(oe, optcfg)

    eigvals(1:6) = [-1.0_dp, -0.9_dp, -0.8_dp, -0.7_dp, -0.6_dp, -0.5_dp]
    eigvals(7:8) = [1.0_dp, 1.1_dp]

    eigvecs = cmplx(0.0_dp, 0.0_dp, kind=dp)
    eigvecs(1,1) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(2,2) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(3,3) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(4,4) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(5,5) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(6,6) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(7,7) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(8,8) = cmplx(1.0_dp, 0.0_dp, kind=dp)

    call build_test_vel_identity(dim, vel)

    k_weight = 1.0_dp
    fermi_level = 0.0_dp

    call optics_accumulate(oe, eigvals, eigvecs, k_weight, &
      & vel, numcb, numvb, fermi_level)

    ! In bulk mode, TE == TM (both = (px+py+pz)/2)
    max_diff = maxval(abs(oe%alpha_te - oe%alpha_tm))
    @assertTrue(max_diff < 1.0e-14_dp, message="bulk: TE == TM within tolerance")

    call optics_free(oe)
    call csr_free(vel(1))
    call csr_free(vel(2))
    call csr_free(vel(3))
  end subroutine test_accumulate_engine_bulk_te_eq_tm


  ! ==================================================================
  ! Test 11: optics_apply_prefactor scales arrays correctly
  ! ==================================================================
  @test
  subroutine test_apply_prefactor_scales()
    type(optics_engine) :: oe
    type(optics_config) :: optcfg
    real(kind=dp) :: expected_te(5), expected_tm(5)
    real(kind=dp) :: prefactor_E
    real(kind=dp), parameter :: e0_AA = e0 / 10.0_dp
    real(kind=dp), parameter :: AA_TO_CM = 1.0e8_dp
    real(kind=dp) :: max_err
    integer :: ie

    call make_default_config(optcfg)
    optcfg%num_energy_points = 5
    optcfg%E_min = 1.0_dp   ! all E > 0
    optcfg%E_max = 2.0_dp
    call optics_init(oe, optcfg)

    ! Manually set some values in alpha_te, alpha_tm, alpha_isbt
    oe%alpha_te = [1.0_dp, 2.0_dp, 3.0_dp, 4.0_dp, 5.0_dp]
    oe%alpha_tm = [0.5_dp, 1.0_dp, 1.5_dp, 2.0_dp, 2.5_dp]
    oe%alpha_isbt = [0.1_dp, 0.2_dp, 0.3_dp, 0.4_dp, 0.5_dp]

    ! Compute expected values
    do ie = 1, 5
      if (oe%E_grid(ie) > 0.0_dp) then
        prefactor_E = (2.0_dp * pi_dp * e**2) &
          & / (optcfg%refractive_index * c * e0_AA * hbar**2 * oe%E_grid(ie))
      else
        prefactor_E = 0.0_dp
      end if
      expected_te(ie) = prefactor_E * real(ie, kind=dp) * AA_TO_CM
      expected_tm(ie) = prefactor_E * (0.5_dp * real(ie, kind=dp)) * AA_TO_CM
    end do

    call optics_apply_prefactor(oe)

    ! Verify arrays match expected
    max_err = maxval(abs(oe%alpha_te - expected_te))
    @assertTrue(max_err < 1.0e-10_dp, message="alpha_te scaled correctly")
    max_err = maxval(abs(oe%alpha_tm - expected_tm))
    @assertTrue(max_err < 1.0e-10_dp, message="alpha_tm scaled correctly")

    call optics_free(oe)
  end subroutine test_apply_prefactor_scales


  ! ==================================================================
  ! Test 12: optics_apply_prefactor zeros out E<=0 points
  ! ==================================================================
  @test
  subroutine test_apply_prefactor_zero_energy()
    type(optics_engine) :: oe
    type(optics_config) :: optcfg
    integer :: idx_zero

    call make_default_config(optcfg)
    optcfg%num_energy_points = 5
    optcfg%E_min = -1.0_dp   ! first point is E < 0
    optcfg%E_max = 1.0_dp
    call optics_init(oe, optcfg)

    ! Find index of E <= 0
    idx_zero = 0
    do idx_zero = 1, oe%nE
      if (oe%E_grid(idx_zero) <= 0.0_dp) exit
    end do
    @assertTrue(idx_zero <= oe%nE, message="found E<=0 point")

    ! Set non-zero values
    oe%alpha_te = 1.0_dp
    oe%alpha_tm = 1.0_dp
    oe%alpha_isbt = 1.0_dp

    call optics_apply_prefactor(oe)

    ! E <= 0 points should be zeroed
    @assertEqual(0.0_dp, oe%alpha_te(idx_zero))
    @assertEqual(0.0_dp, oe%alpha_tm(idx_zero))
    @assertEqual(0.0_dp, oe%alpha_isbt(idx_zero))

    ! E > 0 points should be non-zero
    if (oe%E_grid(oe%nE) > 0.0_dp) then
      @assertTrue(oe%alpha_te(oe%nE) /= 0.0_dp, message="E>0 point has non-zero alpha_te after prefactor")
    end if

    call optics_free(oe)
  end subroutine test_apply_prefactor_zero_energy


  ! ==================================================================
  ! Test 13: gain_reset_engine resets state
  ! ==================================================================
  @test
  subroutine test_gain_reset_engine()
    type(optics_engine) :: oe
    type(optics_config) :: optcfg

    call make_default_config(optcfg)
    optcfg%gain_enabled = .true.
    call optics_init(oe, optcfg)

    ! Simulate gain state having been computed
    oe%gain_fermi_computed = .true.
    oe%mu_e = 1.5_dp
    oe%mu_h = -0.5_dp

    call gain_reset(oe)

    @assertFalse(oe%gain_fermi_computed)
    @assertEqual(0.0_dp, oe%mu_e)
    @assertEqual(0.0_dp, oe%mu_h)

    call optics_free(oe)
  end subroutine test_gain_reset_engine


  ! ==================================================================
  ! Test 14: optics_write_output writes files with correct content
  ! ==================================================================
  @test
  subroutine test_write_output_files()
    type(optics_engine) :: oe
    type(optics_config) :: optcfg
    integer :: iounit, ie, ios
    real(kind=dp) :: e_read, a_read

    call make_default_config(optcfg)
    optcfg%num_energy_points = 3
    optcfg%E_min = 1.0_dp
    optcfg%E_max = 2.0_dp
    call optics_init(oe, optcfg)

    ! Set known values (already "finalized" — no prefactor)
    oe%alpha_te = [10.0_dp, 20.0_dp, 30.0_dp]
    oe%alpha_tm = [5.0_dp, 10.0_dp, 15.0_dp]
    oe%alpha_isbt = [1.0_dp, 2.0_dp, 3.0_dp]

    call optics_write_output(oe)

    ! Read back and verify TE file
    open(newunit=iounit, file='output/absorption_TE.dat', &
      & status='old', action='read', iostat=ios)
    @assertEqual(0, ios, message="TE file exists")

    ! Skip 2 header lines
    read(iounit, *)
    read(iounit, *)
    ie = 0
    do
      read(iounit, *, iostat=ios) e_read, a_read
      if (ios /= 0) exit
      ie = ie + 1
      if (ie == 2) then
        ! Middle point: E_grid(2), alpha_te(2)
        @assertTrue(abs(a_read - 20.0_dp) < 1.0e-6_dp, message="TE file middle point value correct")
      end if
    end do
    close(iounit)
    @assertEqual(3, ie, message="TE file has 3 data points")

    call optics_free(oe)

    ! Cleanup test artifacts
    open(newunit=iounit, file='output/absorption_TE.dat', status='old', iostat=ios)
    if (ios == 0) close(iounit, status='delete')
    open(newunit=iounit, file='output/absorption_TM.dat', status='old', iostat=ios)
    if (ios == 0) close(iounit, status='delete')
    open(newunit=iounit, file='output/absorption_ISBT.dat', status='old', iostat=ios)
    if (ios == 0) close(iounit, status='delete')
  end subroutine test_write_output_files


  ! ==================================================================
  ! Test 15: compute_isbt_absorption_engine accumulates ISBT
  ! ==================================================================
  @test
  subroutine test_isbt_absorption_engine_accumulates()
    type(optics_engine) :: oe
    type(optics_config) :: optcfg
    type(csr_matrix) :: vel(3)

    integer, parameter :: dim = 8
    integer, parameter :: numvb = 6, numcb = 2
    real(kind=dp) :: eigvals(numvb + numcb)
    complex(kind=dp) :: eigvecs(dim, numvb + numcb)
    real(kind=dp) :: k_weight, fermi_level

    call make_default_config(optcfg)
    optcfg%num_energy_points = 5
    optcfg%E_min = 0.01_dp
    optcfg%E_max = 0.5_dp
    optcfg%confinement = 'qw'   ! QW for ISBT
    call optics_init(oe, optcfg)

    ! For ISBT, we need two CB subbands at different energies.
    ! CB1 = 1.0, CB2 = 1.2 (transition energy = 0.2, within E_grid)
    eigvals(1:6) = [-1.0_dp, -0.9_dp, -0.8_dp, -0.7_dp, -0.6_dp, -0.5_dp]
    eigvals(7:8) = [1.0_dp, 1.2_dp]   ! two CB states

    eigvecs = cmplx(0.0_dp, 0.0_dp, kind=dp)
    eigvecs(1,1) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(2,2) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(3,3) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(4,4) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(5,5) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(6,6) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(7,7) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(8,8) = cmplx(1.0_dp, 0.0_dp, kind=dp)

    ! Build velocity matrices. For ISBT, only vel(3) (z-dipole) is used.
    ! We need vel(3) to have a non-zero element at (8,7) or (7,8).
    call build_test_vel_isbt(dim, vel)

    k_weight = 1.0_dp
    fermi_level = 0.0_dp

    call compute_isbt_absorption(oe, eigvals, eigvecs, &
      & vel, numcb, numvb, k_weight, fermi_level)

    ! ISBT should be zero here because eigenvectors are identity and
    ! vel only connects 7->1 and 8->2, NOT 7->8. With identity
    ! eigenvectors, <CB1|vel|CB2> = vel(7,8) = 0.
    ! So we just verify it runs without error.
    @assertTrue(allocated(oe%alpha_isbt), message="alpha_isbt allocated")

    call optics_free(oe)
    call csr_free(vel(1))
    call csr_free(vel(2))
    call csr_free(vel(3))
  end subroutine test_isbt_absorption_engine_accumulates


  ! ==================================================================
  ! Test 16: optics_accumulate_spontaneous_engine accumulates
  ! ==================================================================
  @test
  subroutine test_accumulate_spontaneous_engine()
    type(optics_engine) :: oe
    type(optics_config) :: optcfg
    type(csr_matrix) :: vel(3)

    integer, parameter :: dim = 8
    integer, parameter :: numvb = 6, numcb = 2
    real(kind=dp) :: eigvals(numvb + numcb)
    complex(kind=dp) :: eigvecs(dim, numvb + numcb)
    real(kind=dp) :: k_weight, fermi_level

    call make_default_config(optcfg)
    optcfg%num_energy_points = 5
    optcfg%E_min = 0.5_dp
    optcfg%E_max = 2.0_dp
    optcfg%confinement = 'qw'   ! QW for TE = px+py, TM = pz
    optcfg%spontaneous_enabled = .true.
    call optics_init(oe, optcfg)

    ! Use eigenvalues where VB states are near the Fermi level so
    ! that (1 - f_v) is not ~0.  Set fermi_level between VB and CB.
    eigvals(1:6) = [0.0_dp, 0.01_dp, 0.02_dp, 0.03_dp, 0.04_dp, 0.05_dp]
    eigvals(7:8) = [1.0_dp, 1.1_dp]

    eigvecs = cmplx(0.0_dp, 0.0_dp, kind=dp)
    eigvecs(1,1) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(2,2) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(3,3) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(4,4) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(5,5) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(6,6) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(7,7) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    eigvecs(8,8) = cmplx(1.0_dp, 0.0_dp, kind=dp)

    call build_test_vel_identity(dim, vel)

    k_weight = 1.0_dp
    fermi_level = 0.5_dp   ! between VB and CB so f_c > 0 and (1-f_v) > 0

    call optics_accumulate_spontaneous(oe, eigvals, eigvecs, &
      & k_weight, vel, numcb, numvb, fermi_level)

    ! spont arrays should be allocated (spontaneous_enabled = .true.)
    @assertTrue(allocated(oe%spont_te), message="spont_te allocated")
    @assertTrue(allocated(oe%spont_tm), message="spont_tm allocated")

    ! spont should be non-zero
    @assertTrue(maxval(abs(oe%spont_te)) > 0.0_dp, message="spont_te non-zero after accumulate")
    @assertTrue(maxval(abs(oe%spont_tm)) > 0.0_dp, message="spont_tm non-zero after accumulate")

    call optics_free(oe)
    call csr_free(vel(1))
    call csr_free(vel(2))
    call csr_free(vel(3))
  end subroutine test_accumulate_spontaneous_engine


  ! ==================================================================
  ! Helper: build velocity matrices for ISBT test.
  ! vel(3) has an element connecting CB states (7,8) for ISBT.
  ! ==================================================================
  subroutine build_test_vel_isbt(dim, vel)
    integer, intent(in) :: dim
    type(csr_matrix), intent(out) :: vel(3)

    integer :: dir
    integer :: rows(2), cols(2)
    complex(kind=dp) :: vals_arr(2)

    do dir = 1, 2
      ! vel(1) and vel(2): basic identity-like with VB-CB coupling
      rows(1) = 7; cols(1) = 1; vals_arr(1) = cmplx(1.0_dp, 0.0_dp, kind=dp)
      rows(2) = 8; cols(2) = 2; vals_arr(2) = cmplx(1.0_dp, 0.0_dp, kind=dp)
      call csr_build_from_coo(vel(dir), dim, dim, 2, rows, cols, vals_arr)
    end do

    ! vel(3): z-dipole with CB-CB coupling for ISBT
    ! Element at (8,7): connects CB2 to CB1
    rows(1) = 8; cols(1) = 7; vals_arr(1) = cmplx(0.5_dp, 0.0_dp, kind=dp)
    rows(2) = 7; cols(2) = 1; vals_arr(2) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    call csr_build_from_coo(vel(3), dim, dim, 2, rows, cols, vals_arr)
  end subroutine build_test_vel_isbt


end module test_optical_spectra
