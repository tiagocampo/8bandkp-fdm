module test_csr_helpers
  use funit
  use definitions
  use sparse_matrices
  use csr_test_helpers
  implicit none

contains

  ! ==================================================================
  ! Happy path: valid 3x3 CSR passes all invariants
  ! ==================================================================
  @test
  subroutine test_valid_csr_passes_invariants()
    integer, parameter :: n = 3
    type(csr_matrix) :: A
    integer :: rows(3), cols(3)
    complex(kind=dp) :: vals(3)

    rows = [1, 2, 3]
    cols = [1, 2, 3]
    vals = [cmplx(1.0_dp, 0, dp), cmplx(2.0_dp, 0, dp), cmplx(3.0_dp, 0, dp)]
    call csr_build_from_coo(A, n, n, 3, rows, cols, vals)

    ! Should not stop
    call assert_csr_structural_invariants(A, .true.)

    @assertTrue(check_rowptr_monotonic(A))
    @assertTrue(check_colind_sorted(A))
    @assertTrue(check_colind_bounds(A))
    @assertTrue(check_nnz_consistency(A))
    @assertTrue(check_diagonal_present(A))

    call A%free()
  end subroutine test_valid_csr_passes_invariants

  ! ==================================================================
  ! Happy path: valid CSR with diagonal, require_diagonal=.true.
  ! ==================================================================
  @test
  subroutine test_valid_csr_diagonal_required()
    type(csr_matrix) :: A
    integer :: rows(5), cols(5)
    complex(kind=dp) :: vals(5)

    ! 3x3 matrix with diagonal + off-diagonal entries
    rows = [1, 1, 2, 2, 3]
    cols = [1, 2, 1, 2, 3]
    vals = [cmplx(1.0_dp, 0, dp), cmplx(2.0_dp, 0, dp), &
            cmplx(3.0_dp, 0, dp), cmplx(4.0_dp, 0, dp), &
            cmplx(5.0_dp, 0, dp)]
    call csr_build_from_coo(A, 3, 3, 5, rows, cols, vals)

    call assert_csr_structural_invariants(A, .true.)

    call A%free()
  end subroutine test_valid_csr_diagonal_required

  ! ==================================================================
  ! Edge case: empty CSR (0 nonzeros) passes all invariants
  ! ==================================================================
  @test
  subroutine test_empty_csr_passes_invariants()
    type(csr_matrix) :: A

    call csr_init(A, 3, 3)

    @assertTrue(check_rowptr_monotonic(A))
    @assertTrue(check_colind_sorted(A))
    @assertTrue(check_colind_bounds(A))
    @assertTrue(check_nnz_consistency(A))
    @assertFalse(check_diagonal_present(A))

    call assert_csr_structural_invariants(A, .false.)

    call A%free()
  end subroutine test_empty_csr_passes_invariants

  ! ==================================================================
  ! Edge case: rectangular CSR passes without diagonal requirement
  ! ==================================================================
  @test
  subroutine test_rectangular_csr_passes()
    type(csr_matrix) :: A
    integer :: rows(2), cols(2)
    complex(kind=dp) :: vals(2)

    rows = [1, 2]
    cols = [1, 2]
    vals = [cmplx(1.0_dp, 0, dp), cmplx(2.0_dp, 0, dp)]
    call csr_build_from_coo(A, 2, 3, 2, rows, cols, vals)

    call assert_csr_structural_invariants(A)

    call A%free()
  end subroutine test_rectangular_csr_passes

  ! ==================================================================
  ! Edge case: CSR with empty rows (rowptr(i) == rowptr(i+1))
  ! ==================================================================
  @test
  subroutine test_csr_empty_rows_passes()
    type(csr_matrix) :: A
    integer :: rows(2), cols(2)
    complex(kind=dp) :: vals(2)

    ! 4x4 matrix: only rows 1 and 4 have entries
    rows = [1, 4]
    cols = [1, 4]
    vals = [cmplx(1.0_dp, 0, dp), cmplx(2.0_dp, 0, dp)]
    call csr_build_from_coo(A, 4, 4, 2, rows, cols, vals)

    @assertTrue(check_rowptr_monotonic(A))
    @assertTrue(check_colind_sorted(A))
    @assertTrue(check_nnz_consistency(A))

    call A%free()
  end subroutine test_csr_empty_rows_passes

  ! ==================================================================
  ! Error path: rowptr not monotonic — detected
  ! ==================================================================
  @test
  subroutine test_detects_rowptr_not_monotonic()
    type(csr_matrix) :: A
    logical :: ok

    call csr_init(A, 3, 3)
    ! Manually corrupt rowptr to be non-monotonic
    A%rowptr = [1, 3, 2, 3]
    A%nnz = 2
    ! Allocate colind/values to match
    if (allocated(A%colind)) deallocate(A%colind)
    if (allocated(A%values)) deallocate(A%values)
    allocate(A%colind(2), A%values(2))
    A%colind = [1, 2]
    A%values = [cmplx(1.0_dp, 0, dp), cmplx(2.0_dp, 0, dp)]

    ok = check_rowptr_monotonic(A)
    @assertFalse(ok)

    call A%free()
  end subroutine test_detects_rowptr_not_monotonic

  ! ==================================================================
  ! Error path: colind unsorted within a row — detected
  ! ==================================================================
  @test
  subroutine test_detects_colind_unsorted()
    type(csr_matrix) :: A
    logical :: ok

    call csr_init(A, 2, 3)
    ! Manually create unsorted colind
    A%rowptr = [1, 3, 3]
    A%nnz = 2
    if (allocated(A%colind)) deallocate(A%colind)
    if (allocated(A%values)) deallocate(A%values)
    allocate(A%colind(2), A%values(2))
    A%colind = [3, 1]  ! unsorted within row 1
    A%values = [cmplx(1.0_dp, 0, dp), cmplx(2.0_dp, 0, dp)]

    ok = check_colind_sorted(A)
    @assertFalse(ok)

    call A%free()
  end subroutine test_detects_colind_unsorted

  ! ==================================================================
  ! Error path: colind entry outside [1, ncols] — detected
  ! ==================================================================
  @test
  subroutine test_detects_colind_out_of_bounds()
    type(csr_matrix) :: A
    logical :: ok

    call csr_init(A, 2, 2)
    A%rowptr = [1, 2, 3]
    A%nnz = 2
    if (allocated(A%colind)) deallocate(A%colind)
    if (allocated(A%values)) deallocate(A%values)
    allocate(A%colind(2), A%values(2))
    A%colind = [1, 5]  ! 5 > ncols=2
    A%values = [cmplx(1.0_dp, 0, dp), cmplx(2.0_dp, 0, dp)]

    ok = check_colind_bounds(A)
    @assertFalse(ok)

    call A%free()
  end subroutine test_detects_colind_out_of_bounds

  ! ==================================================================
  ! Error path: nnz inconsistent with rowptr — detected
  ! ==================================================================
  @test
  subroutine test_detects_nnz_inconsistency()
    type(csr_matrix) :: A
    logical :: ok

    call csr_init(A, 2, 2)
    A%rowptr = [1, 2, 3]
    A%nnz = 5  ! should be 2 (rowptr(3)-1)
    if (allocated(A%colind)) deallocate(A%colind)
    if (allocated(A%values)) deallocate(A%values)
    allocate(A%colind(5), A%values(5))
    A%colind = [1, 2, 1, 2, 1]
    A%values = cmplx(1.0_dp, 0, dp)

    ok = check_nnz_consistency(A)
    @assertFalse(ok)

    call A%free()
  end subroutine test_detects_nnz_inconsistency

  ! ==================================================================
  ! Error path: missing diagonal when require_diagonal=.true.
  ! ==================================================================
  @test
  subroutine test_detects_missing_diagonal()
    type(csr_matrix) :: A
    logical :: ok

    ! 3x3 with no diagonal in row 2
    call csr_init(A, 3, 3)
    A%rowptr = [1, 2, 2, 3]
    A%nnz = 2
    if (allocated(A%colind)) deallocate(A%colind)
    if (allocated(A%values)) deallocate(A%values)
    allocate(A%colind(2), A%values(2))
    A%colind = [1, 3]  ! row 2 is empty, no diag
    A%values = [cmplx(1.0_dp, 0, dp), cmplx(1.0_dp, 0, dp)]

    ok = check_diagonal_present(A)
    @assertFalse(ok)

    call A%free()
  end subroutine test_detects_missing_diagonal

end module test_csr_helpers
