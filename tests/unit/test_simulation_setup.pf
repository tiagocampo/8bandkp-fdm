module test_simulation_setup
  use funit
  use definitions
  use parameters
  use simulation_setup_mod
  use strain_solver, only: strain_result, strain_result_free
  implicit none

contains

  ! Vertical slice 1: Bulk init — simulation_setup_init with bulk GaAs config
  @test
  subroutine test_bulk_init()
    type(simulation_config) :: cfg
    type(simulation_setup) :: setup

    call make_bulk_gaas_config(cfg)
    call simulation_setup_init(cfg, setup)

    ! Assertions
    @assertEqual(0, setup%confinement)
    @assertEqual(8, setup%N)
    @assertEqual(1, setup%il)
    @assertEqual(8, setup%iuu)
    @assertFalse(setup%has_strain)
    @assertFalse(setup%sc_was_run)

    ! Cleanup
    call simulation_setup_free(setup)
  end subroutine test_bulk_init


  ! Vertical slice 2: Bulk build_H — 8x8 Hamiltonian
  @test
  subroutine test_bulk_build_H()
    type(simulation_config) :: cfg
    type(simulation_setup) :: setup
    complex(kind=dp), allocatable :: HT(:,:)
    type(wavevector) :: kv

    call make_bulk_gaas_config(cfg)
    call simulation_setup_init(cfg, setup)

    ! Build H at k=0
    allocate(HT(8, 8))
    HT = 0.0_dp
    kv%kx = 0.0_dp
    kv%ky = 0.0_dp
    kv%kz = 0.0_dp

    call setup_build_H(setup, cfg, kv, HT)

    ! HT should be 8x8 with nonzero diagonal (bandgaps)
    @assertTrue(size(HT, 1) == 8)
    @assertTrue(size(HT, 2) == 8)
    ! CB diagonal (bands 7,8) should have Eg on the diagonal at k=0
    @assertTrue(abs(real(HT(7,7))) > 0.1_dp)
    @assertTrue(abs(real(HT(8,8))) > 0.1_dp)

    deallocate(HT)
    call simulation_setup_free(setup)
  end subroutine test_bulk_build_H


  ! Vertical slice 3: Bulk solve at k=0 — eigenvalues match known GaAs bandgap
  @test
  subroutine test_bulk_solve_k0()
    type(simulation_config) :: cfg
    type(simulation_setup) :: setup
    real(kind=dp), allocatable :: evals(:)
    complex(kind=dp), allocatable :: evecs(:,:)
    type(wavevector) :: kv
    real(kind=dp) :: eg_gaas, eg_computed

    call make_bulk_gaas_config(cfg)
    call simulation_setup_init(cfg, setup)

    ! Solve at k=0
    allocate(evals(8))
    allocate(evecs(8, 8))
    kv%kx = 0.0_dp
    kv%ky = 0.0_dp
    kv%kz = 0.0_dp

    call setup_solve_kpoint_serial(setup, cfg, kv, evals, evecs)

    ! GaAs bandgap ~1.519 eV (Vurgaftman 2001)
    ! CB minimum = evals(7) (7th eigenvalue sorted ascending)
    ! VB maximum = evals(6)
    eg_gaas = 1.519_dp
    eg_computed = evals(7) - evals(6)

    @assertEqual(eg_gaas, eg_computed, tolerance=0.01_dp)

    ! VB top should be near 0 (EV reference)
    @assertTrue(abs(evals(6)) < 0.5_dp)

    deallocate(evals, evecs)
    call simulation_setup_free(setup)
  end subroutine test_bulk_solve_k0


  ! Vertical slice 4: QW init — correct N, il, iuu
  @test
  subroutine test_qw_init()
    type(simulation_config) :: cfg
    type(simulation_setup) :: setup
    character(len=255) :: materials(2)
    integer :: fdStep, expected_N

    ! Build a minimal QW GaAs/AlGaAs config
    fdStep = 51
    cfg%confinement = 1
    cfg%fdStep = fdStep
    cfg%FDorder = 2
    cfg%numLayers = 2
    cfg%numcb = 2
    cfg%numvb = 6
    cfg%evnum = 8
    cfg%confDir = 'z'
    cfg%waveVector = 'k0'
    cfg%waveVectorMax = 0.0_dp
    cfg%waveVectorStep = 100
    cfg%ExternalField = 0
    cfg%EFtype = 'EF'
    cfg%Evalue = 0.0_dp
    cfg%whichBand = 0
    cfg%bandIdx = 1

    ! Two layers: AlGaAs barrier (full domain) + GaAs well (center)
    allocate(cfg%materialN(2))
    cfg%materialN(1) = 'Al20Ga80As'
    cfg%materialN(2) = 'GaAs'

    allocate(cfg%startPos(2))
    allocate(cfg%endPos(2))
    cfg%startPos(1) = 0.0_dp
    cfg%endPos(1) = 200.0_dp    ! barrier covers full domain
    cfg%startPos(2) = 80.0_dp
    cfg%endPos(2) = 120.0_dp    ! well in center

    cfg%totalSize = cfg%endPos(1) - cfg%startPos(1)
    cfg%delta = cfg%totalSize / real(fdStep - 1, kind=dp)
    cfg%dz = cfg%delta

    allocate(cfg%z(fdStep))
    block
      integer :: i
      do i = 1, fdStep
        cfg%z(i) = cfg%startPos(1) + (i-1)*cfg%delta
      end do
    end block

    allocate(cfg%intStartPos(2))
    allocate(cfg%intEndPos(2))
    cfg%intStartPos(1) = 1
    cfg%intEndPos(1) = fdStep
    cfg%intStartPos(2) = nint((cfg%startPos(2) - cfg%startPos(1)) / cfg%delta) + 1
    cfg%intEndPos(2) = nint((cfg%endPos(2) - cfg%startPos(1)) / cfg%delta) + 1

    ! Material parameters
    allocate(cfg%params(2))
    materials(1) = 'Al20Ga80As'
    materials(2) = 'GaAs'
    call paramDatabase(materials, 2, cfg%params)
    call init_grid_from_config(cfg)

    call simulation_setup_init(cfg, setup)

    expected_N = fdStep * 8

    @assertEqual(1, setup%confinement)
    @assertEqual(expected_N, setup%N)
    @assertTrue(allocated(setup%profile))
    @assertTrue(allocated(setup%kpterms))
    @assertTrue(allocated(setup%HT))
    @assertTrue(allocated(setup%work))
    @assertTrue(setup%lwork > 0)

    call simulation_setup_free(setup)
  end subroutine test_qw_init


  ! Vertical slice 5: Bulk velocity matrices — CSR with correct size
  @test
  subroutine test_bulk_velocity_matrices()
    type(simulation_config) :: cfg
    type(simulation_setup) :: setup

    call make_bulk_gaas_config(cfg)
    call simulation_setup_init(cfg, setup)
    call setup_build_velocity_matrices(setup, cfg)

    @assertTrue(setup%vel_built)

    ! Each velocity matrix should be 8x8 CSR
    @assertEqual(8, setup%vel(1)%nrows)
    @assertEqual(8, setup%vel(1)%ncols)
    @assertTrue(setup%vel(1)%nnz > 0)

    @assertEqual(8, setup%vel(2)%nrows)
    @assertEqual(8, setup%vel(2)%ncols)
    @assertTrue(setup%vel(2)%nnz > 0)

    @assertEqual(8, setup%vel(3)%nrows)
    @assertEqual(8, setup%vel(3)%ncols)
    @assertTrue(setup%vel(3)%nnz > 0)

    ! Kane P matrix element should be nonzero for vx/vy
    ! (GaAs has P ~ 10.493 eV*A)
    @assertTrue(setup%vel(1)%nnz > 0)

    call simulation_setup_free(setup)
  end subroutine test_bulk_velocity_matrices


  ! Vertical slice 6: QW velocity matrices — CSR with correct dimensions
  @test
  subroutine test_qw_velocity_matrices()
    type(simulation_config) :: cfg
    type(simulation_setup) :: setup
    integer :: expected_N

    call make_qw_gaas_config(cfg)
    call simulation_setup_init(cfg, setup)
    call setup_build_velocity_matrices(setup, cfg)

    expected_N = cfg%fdStep * 8

    @assertTrue(setup%vel_built)

    ! Each velocity matrix should be expected_N x expected_N CSR
    @assertEqual(expected_N, setup%vel(1)%nrows)
    @assertEqual(expected_N, setup%vel(1)%ncols)
    @assertTrue(setup%vel(1)%nnz > 0)

    @assertEqual(expected_N, setup%vel(2)%nrows)
    @assertEqual(expected_N, setup%vel(2)%ncols)
    @assertTrue(setup%vel(2)%nnz > 0)

    @assertEqual(expected_N, setup%vel(3)%nrows)
    @assertEqual(expected_N, setup%vel(3)%ncols)
    @assertTrue(setup%vel(3)%nnz > 0)

    ! x and y velocity matrices should have nonzero Kane P elements
    @assertTrue(setup%vel(1)%nnz > 0)
    @assertTrue(setup%vel(2)%nnz > 0)
    ! z velocity should also be nonzero (P*kz term)
    @assertTrue(setup%vel(3)%nnz > 0)

    call simulation_setup_free(setup)
  end subroutine test_qw_velocity_matrices


  ! Helper: build a minimal bulk GaAs config (shared across tests)
  subroutine make_bulk_gaas_config(cfg)
    type(simulation_config), intent(out) :: cfg
    character(len=255) :: materials(1)

    cfg%confinement = 0
    cfg%fdStep = 1
    cfg%FDorder = 2
    cfg%numLayers = 1
    cfg%numcb = 2
    cfg%numvb = 6
    cfg%evnum = 8
    cfg%confDir = 'n'
    cfg%waveVector = 'k0'
    cfg%waveVectorMax = 0.0_dp
    cfg%waveVectorStep = 100
    cfg%ExternalField = 0
    cfg%EFtype = 'EF'
    cfg%Evalue = 0.0_dp
    cfg%totalSize = 0.0_dp
    cfg%delta = 0.0_dp
    cfg%dz = 0.0_dp
    cfg%whichBand = 0
    cfg%bandIdx = 1

    allocate(cfg%materialN(1))
    cfg%materialN(1) = 'GaAs'
    allocate(cfg%startPos(1))
    allocate(cfg%endPos(1))
    cfg%startPos(1) = 0.0_dp
    cfg%endPos(1) = 1.0_dp

    allocate(cfg%params(1))
    materials(1) = 'GaAs'
    call paramDatabase(materials, 1, cfg%params)
    call init_grid_from_config(cfg)
  end subroutine make_bulk_gaas_config


  ! Helper: build a minimal QW GaAs/AlGaAs config
  subroutine make_qw_gaas_config(cfg)
    type(simulation_config), intent(out) :: cfg
    character(len=255) :: materials(2)
    integer :: fdStep

    fdStep = 11
    cfg%confinement = 1
    cfg%fdStep = fdStep
    cfg%FDorder = 2
    cfg%numLayers = 2
    cfg%numcb = 2
    cfg%numvb = 6
    cfg%evnum = 8
    cfg%confDir = 'z'
    cfg%waveVector = 'k0'
    cfg%waveVectorMax = 0.0_dp
    cfg%waveVectorStep = 100
    cfg%ExternalField = 0
    cfg%EFtype = 'EF'
    cfg%Evalue = 0.0_dp
    cfg%whichBand = 0
    cfg%bandIdx = 1

    ! Two layers: AlGaAs barrier (full domain) + GaAs well (center)
    allocate(cfg%materialN(2))
    cfg%materialN(1) = 'Al20Ga80As'
    cfg%materialN(2) = 'GaAs'

    allocate(cfg%startPos(2))
    allocate(cfg%endPos(2))
    cfg%startPos(1) = 0.0_dp
    cfg%endPos(1) = 200.0_dp    ! barrier covers full domain
    cfg%startPos(2) = 80.0_dp
    cfg%endPos(2) = 120.0_dp    ! well in center

    cfg%totalSize = cfg%endPos(1) - cfg%startPos(1)
    cfg%delta = cfg%totalSize / real(fdStep - 1, kind=dp)
    cfg%dz = cfg%delta

    allocate(cfg%z(fdStep))
    block
      integer :: i
      do i = 1, fdStep
        cfg%z(i) = cfg%startPos(1) + (i-1)*cfg%delta
      end do
    end block

    allocate(cfg%intStartPos(2))
    allocate(cfg%intEndPos(2))
    cfg%intStartPos(1) = 1
    cfg%intEndPos(1) = fdStep
    cfg%intStartPos(2) = nint((cfg%startPos(2) - cfg%startPos(1)) / cfg%delta) + 1
    cfg%intEndPos(2) = nint((cfg%endPos(2) - cfg%startPos(1)) / cfg%delta) + 1

    ! Material parameters
    allocate(cfg%params(2))
    materials(1) = 'Al20Ga80As'
    materials(2) = 'GaAs'
    call paramDatabase(materials, 2, cfg%params)
    call init_grid_from_config(cfg)
  end subroutine make_qw_gaas_config


  ! Vertical slice 7: Wire init — correct Ngrid, Ntot, sparse components
  @test
  subroutine test_wire_init()
    type(simulation_config) :: cfg
    type(simulation_setup) :: setup
    integer :: expected_Ngrid, expected_Ntot

    call make_wire_gaas_config(cfg)
    call simulation_setup_init(cfg, setup)

    expected_Ngrid = 5 * 5
    expected_Ntot = 8 * expected_Ngrid

    @assertEqual(2, setup%confinement)
    @assertEqual(expected_Ngrid, setup%Ngrid)
    @assertEqual(expected_Ntot, setup%Ntot)
    @assertEqual(expected_Ntot, setup%N)
    @assertTrue(allocated(setup%profile_2d))
    @assertTrue(allocated(setup%kpterms_2d))
    @assertTrue(allocated(setup%HT_csr_ptr))
    @assertTrue(allocated(setup%coo_cache_ptr))
    @assertTrue(allocated(setup%wire_ws_ptr))
    @assertTrue(allocated(setup%eigen_solver))
    @assertFalse(setup%has_strain)
    @assertFalse(setup%sc_was_run)

    call simulation_setup_free(setup)
  end subroutine test_wire_init


  ! Vertical slice 8: Wire build_H — CSR Hamiltonian with nonzero entries
  @test
  subroutine test_wire_build_H()
    type(simulation_config) :: cfg
    type(simulation_setup) :: setup
    type(wavevector) :: kv
    integer :: expected_Ntot

    call make_wire_gaas_config(cfg)
    call simulation_setup_init(cfg, setup)

    expected_Ntot = 8 * 25

    kv%kx = 0.0_dp
    kv%ky = 0.0_dp
    kv%kz = 0.0_dp

    call setup_build_H(setup, cfg, kv)

    @assertTrue(allocated(setup%HT_csr_ptr))
    @assertEqual(expected_Ntot, setup%HT_csr_ptr%nrows)
    @assertEqual(expected_Ntot, setup%HT_csr_ptr%ncols)
    @assertTrue(setup%HT_csr_ptr%nnz > 0)

    call simulation_setup_free(setup)
  end subroutine test_wire_build_H


  ! Vertical slice 9: Wire velocity matrices — CSR with correct dimensions
  @test
  subroutine test_wire_velocity_matrices()
    type(simulation_config) :: cfg
    type(simulation_setup) :: setup
    type(wavevector) :: kv
    integer :: expected_Ntot

    call make_wire_gaas_config(cfg)
    call simulation_setup_init(cfg, setup)

    expected_Ntot = 8 * 25

    ! Build H first (needed for velocity matrices)
    kv%kx = 0.0_dp
    kv%ky = 0.0_dp
    kv%kz = 0.0_dp
    call setup_build_H(setup, cfg, kv)

    ! Build velocity matrices
    call setup_build_velocity_matrices(setup, cfg)

    @assertTrue(setup%vel_built)

    ! vel(1) = vx, vel(2) = vy
    @assertEqual(expected_Ntot, setup%vel(1)%nrows)
    @assertEqual(expected_Ntot, setup%vel(1)%ncols)
    @assertTrue(setup%vel(1)%nnz > 0)

    @assertEqual(expected_Ntot, setup%vel(2)%nrows)
    @assertEqual(expected_Ntot, setup%vel(2)%ncols)
    @assertTrue(setup%vel(2)%nnz > 0)

    call simulation_setup_free(setup)
  end subroutine test_wire_velocity_matrices


  ! Vertical slice 10: Full bulk pipeline integration — GaAs bandgap at Gamma
  ! Exercises: simulation_setup_init → setup_build_H → setup_solve_kpoint_serial
  ! Validates that the CB-VB gap matches Vurgaftman 2001 Eg(GaAs) = 1.519 eV.
  @test
  subroutine test_gaas_bulk_pipeline()
    type(simulation_config) :: cfg
    type(simulation_setup) :: setup
    real(kind=dp), allocatable :: evals(:)
    complex(kind=dp), allocatable :: evecs(:,:)
    type(wavevector) :: kv
    real(kind=dp) :: eg_gaas, eg_computed, cb_min, vb_max

    call make_bulk_gaas_config(cfg)

    ! Step 1: Initialize setup (bulk path)
    call simulation_setup_init(cfg, setup)
    @assertEqual(0, setup%confinement)
    @assertEqual(8, setup%N)

    ! Step 2: Build H at k=0 via setup_build_H
    allocate(setup%HT(8, 8))
    kv%kx = 0.0_dp
    kv%ky = 0.0_dp
    kv%kz = 0.0_dp
    call setup_build_H(setup, cfg, kv, setup%HT)
    ! CB diagonal should be nonzero at k=0
    @assertTrue(abs(real(setup%HT(7,7))) > 0.1_dp)

    ! Step 3: Solve at k=0 via setup_solve_kpoint_serial
    allocate(evals(8))
    allocate(evecs(8, 8))
    call setup_solve_kpoint_serial(setup, cfg, kv, evals, evecs)

    ! Step 4: Verify GaAs bandgap at Gamma (Vurgaftman 2001: Eg = 1.519 eV)
    ! Eigenvalues are sorted ascending: bands 1-6 = VB, 7-8 = CB
    cb_min = evals(7)
    vb_max = evals(6)
    eg_computed = cb_min - vb_max
    eg_gaas = 1.519_dp

    @assertEqual(eg_gaas, eg_computed, tolerance=0.01_dp)

    ! Step 5: Free
    deallocate(evals, evecs)
    call simulation_setup_free(setup)
  end subroutine test_gaas_bulk_pipeline


  ! Helper: build a minimal wire GaAs config for testing
  subroutine make_wire_gaas_config(cfg)
    type(simulation_config), intent(out) :: cfg
    character(len=255) :: materials(1)
    integer :: nx, ny

    nx = 5
    ny = 5

    cfg%confinement = 2
    cfg%fdStep = nx * ny
    cfg%FDorder = 2
    cfg%numLayers = 1
    cfg%numcb = 2
    cfg%numvb = 6
    cfg%evnum = 8
    cfg%confDir = 'z'
    cfg%waveVector = 'kz'
    cfg%waveVectorMax = 0.1_dp
    cfg%waveVectorStep = 2
    cfg%ExternalField = 0
    cfg%EFtype = 'EF'
    cfg%Evalue = 0.0_dp
    cfg%whichBand = 0
    cfg%bandIdx = 1
    cfg%feast_m0 = -1

    ! Wire grid dimensions
    cfg%wire_nx = nx
    cfg%wire_ny = ny
    cfg%wire_dx = 4.0_dp
    cfg%wire_dy = 4.0_dp
    cfg%wire_geom%shape = 'rectangle'

    ! Single material: GaAs everywhere
    allocate(cfg%materialN(1))
    cfg%materialN(1) = 'GaAs'

    allocate(cfg%startPos(1))
    allocate(cfg%endPos(1))
    cfg%startPos(1) = 0.0_dp
    cfg%endPos(1) = real(nx, kind=dp) * cfg%wire_dx

    ! One region: full domain
    cfg%numRegions = 1
    allocate(cfg%regions(1))
    cfg%regions(1)%material = 'GaAs'
    cfg%regions(1)%inner = 0.0_dp
    cfg%regions(1)%outer = sqrt((real(nx, kind=dp) * cfg%wire_dx)**2 + &
      (real(ny, kind=dp) * cfg%wire_dy)**2)

    ! Material parameters
    allocate(cfg%params(1))
    materials(1) = 'GaAs'
    call paramDatabase(materials, 1, cfg%params)
    call init_grid_from_config(cfg)
  end subroutine make_wire_gaas_config

  ! Vertical slice 11: Strain setup — has_strain and strain_blocks populated
  ! Uses InAs/GaAs QW (lattice-mismatched) to trigger nonzero strain.
  @test
  subroutine test_strain_setup()
    type(simulation_config) :: cfg
    type(simulation_setup) :: setup
    type(strain_result), allocatable :: strain_diag
    character(len=255) :: materials(2)
    integer :: fdStep, i
    real(kind=dp) :: strain_sum

    ! Build QW with InAs well in GaAs barrier (lattice mismatch ~7%)
    fdStep = 51
    cfg%confinement = 1
    cfg%fdStep = fdStep
    cfg%FDorder = 2
    cfg%numLayers = 2
    cfg%numcb = 2
    cfg%numvb = 6
    cfg%evnum = 8
    cfg%confDir = 'z'
    cfg%waveVector = 'k0'
    cfg%waveVectorMax = 0.0_dp
    cfg%waveVectorStep = 100
    cfg%ExternalField = 0
    cfg%EFtype = 'EF'
    cfg%Evalue = 0.0_dp
    cfg%whichBand = 0
    cfg%bandIdx = 1

    ! Two layers: GaAs barrier (full domain) + InAs well (center)
    allocate(cfg%materialN(2))
    cfg%materialN(1) = 'GaAs'
    cfg%materialN(2) = 'InAs'

    allocate(cfg%startPos(2))
    allocate(cfg%endPos(2))
    cfg%startPos(1) = 0.0_dp
    cfg%endPos(1) = 200.0_dp     ! barrier covers full domain
    cfg%startPos(2) = 80.0_dp
    cfg%endPos(2) = 120.0_dp     ! well in center

    cfg%totalSize = cfg%endPos(1) - cfg%startPos(1)
    cfg%delta = cfg%totalSize / real(fdStep - 1, kind=dp)
    cfg%dz = cfg%delta

    allocate(cfg%z(fdStep))
    do i = 1, fdStep
      cfg%z(i) = cfg%startPos(1) + (i-1)*cfg%delta
    end do

    ! Compute layer index bounds from positions
    allocate(cfg%intStartPos(2))
    allocate(cfg%intEndPos(2))
    do i = 1, cfg%numLayers
      cfg%intStartPos(i) = max(1, nint((cfg%startPos(i) - cfg%startPos(1)) / cfg%delta) + 1)
      cfg%intEndPos(i) = min(fdStep, nint((cfg%endPos(i) - cfg%startPos(1)) / cfg%delta) + 1)
    end do

    ! Material parameters
    allocate(cfg%params(2))
    materials(1) = 'GaAs'
    materials(2) = 'InAs'
    call paramDatabase(materials, 2, cfg%params)
    call init_grid_from_config(cfg)

    ! Enable strain
    cfg%strain%enabled = .true.

    ! Initialize with strain capture
    call simulation_setup_init(cfg, setup, strain_out=strain_diag)

    ! Assert: has_strain flag set
    @assertTrue(setup%has_strain)

    ! Assert: strain_blocks populated (bir_pikus_blocks allocated)
    @assertTrue(allocated(cfg%strain_blocks%delta_Ec))
    @assertTrue(allocated(cfg%strain_blocks%delta_EHH))
    @assertTrue(allocated(cfg%strain_blocks%delta_ELH))
    @assertTrue(allocated(cfg%strain_blocks%delta_ESO))

    ! Assert: strain_diag allocated and has nonzero strain components
    @assertTrue(allocated(strain_diag))
    @assertTrue(allocated(strain_diag%eps_xx))
    @assertTrue(allocated(strain_diag%eps_yy))
    @assertTrue(allocated(strain_diag%eps_zz))

    ! InAs well region should have nonzero in-plane strain
    ! (InAs a0=6.058, GaAs a0=5.653 -> ~7% mismatch)
    strain_sum = sum(abs(strain_diag%eps_xx)) + sum(abs(strain_diag%eps_yy)) + &
                 sum(abs(strain_diag%eps_zz))
    @assertTrue(strain_sum > 1.0e-6_dp)

    ! Cleanup
    call strain_result_free(strain_diag)
    call simulation_setup_free(setup)
  end subroutine test_strain_setup


  ! Vertical slice 12: SC setup — sc_was_run flag and Fermi level adjustment
  @test
  subroutine test_sc_setup()
    type(simulation_config) :: cfg
    type(simulation_setup) :: setup
    character(len=255) :: materials(2)
    integer :: fdStep, i

    ! Build QW config inline with valid material names
    ! (make_qw_gaas_config uses 'AlGaAs' which is not in the parameter DB)
    fdStep = 11
    cfg%confinement = 1
    cfg%fdStep = fdStep
    cfg%FDorder = 2
    cfg%numLayers = 2
    cfg%numcb = 2
    cfg%numvb = 6
    cfg%evnum = 8
    cfg%confDir = 'z'
    cfg%waveVector = 'k0'
    cfg%waveVectorMax = 0.0_dp
    cfg%waveVectorStep = 100
    cfg%ExternalField = 0
    cfg%EFtype = 'EF'
    cfg%Evalue = 0.0_dp
    cfg%whichBand = 0
    cfg%bandIdx = 1

    ! Two layers: Al20Ga80As barrier (full domain) + GaAs well (center)
    allocate(cfg%materialN(2))
    cfg%materialN(1) = 'Al20Ga80As'
    cfg%materialN(2) = 'GaAs'

    allocate(cfg%startPos(2))
    allocate(cfg%endPos(2))
    cfg%startPos(1) = 0.0_dp
    cfg%endPos(1) = 200.0_dp
    cfg%startPos(2) = 80.0_dp
    cfg%endPos(2) = 120.0_dp

    cfg%totalSize = cfg%endPos(1) - cfg%startPos(1)
    cfg%delta = cfg%totalSize / real(fdStep - 1, kind=dp)
    cfg%dz = cfg%delta

    allocate(cfg%z(fdStep))
    do i = 1, fdStep
      cfg%z(i) = cfg%startPos(1) + (i-1)*cfg%delta
    end do

    ! Compute layer index bounds from positions (clamped to grid)
    allocate(cfg%intStartPos(2))
    allocate(cfg%intEndPos(2))
    do i = 1, cfg%numLayers
      cfg%intStartPos(i) = max(1, nint((cfg%startPos(i) - cfg%startPos(1)) / cfg%delta) + 1)
      cfg%intEndPos(i) = min(fdStep, nint((cfg%endPos(i) - cfg%startPos(1)) / cfg%delta) + 1)
    end do

    ! Material parameters
    allocate(cfg%params(2))
    materials(1) = 'Al20Ga80As'
    materials(2) = 'GaAs'
    call paramDatabase(materials, 2, cfg%params)
    call init_grid_from_config(cfg)

    ! Enable SC with minimal parameters (3 iterations for speed)
    cfg%sc%enabled = 1
    cfg%sc%temperature = 300.0_dp
    cfg%sc%max_iterations = 3
    cfg%sc%tolerance = 1.0e-6_dp
    cfg%sc%mixing_alpha = 0.3_dp
    cfg%sc%num_kpar = 5
    cfg%sc%kpar_max = 0.3_dp
    cfg%sc%bc_type = 'DD'
    cfg%sc%fermi_mode = 1
    cfg%sc%fermi_level = 1.0_dp

    call simulation_setup_init(cfg, setup)

    ! Assert: SC was run
    @assertTrue(setup%sc_was_run)

    ! Assert: Fermi level was set (SC adjusts it from initial value)
    @assertTrue(setup%fermi_level /= 0.0_dp)

    call simulation_setup_free(setup)
  end subroutine test_sc_setup


end module test_simulation_setup
