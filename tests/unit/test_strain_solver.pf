module test_strain_solver
  use funit
  use definitions
  use parameters
  use strain_solver
  use geometry
  use hamiltonianConstructor
  implicit none

contains

  @test
  subroutine test_biaxial_strain_qw()
    ! QW biaxial strain: InAs well embedded in GaAs substrate.
    ! Reference lattice constant = GaAs a0 = 5.65325 AA.
    ! At InAs points: eps_0 = (5.65325 - 6.0583) / 6.0583 (compressive, negative)
    ! eps_xx = eps_yy = eps_0, eps_zz = -2*C12/C11 * eps_0, eps_yz = 0.

    integer, parameter :: ny = 10
    real(kind=dp), parameter :: dy = 1.0_dp

    type(spatial_grid) :: grid
    type(paramStruct) :: params(2)
    character(len=255) :: materials(2)
    type(strain_config) :: strain_cfg
    type(strain_result) :: strain_out
    real(kind=dp) :: a0_ref, eps_0_expected, eps_zz_expected
    real(kind=dp) :: max_err
    integer :: ij

    ! Two materials: 1=GaAs, 2=InAs
    materials(1) = "GaAs"
    materials(2) = "InAs"
    call paramDatabase(materials, 2, params)

    a0_ref = params(1)%a0  ! GaAs lattice constant

    ! Set up QW grid (ndim=1): nx=1, ny=10
    grid%ndim = 1
    grid%nx = 1
    grid%ny = ny
    grid%dx = 0.0_dp
    grid%dy = dy
    allocate(grid%z(ny))
    do ij = 1, ny
      grid%z(ij) = (ij - 1) * dy
    end do
    allocate(grid%material_id(ny))

    ! material_id: 1,1,1,1,2,2,2,2,1,1 (InAs embedded in GaAs)
    grid%material_id = [1, 1, 1, 1, 2, 2, 2, 2, 1, 1]

    ! Enable strain
    strain_cfg%enabled = .true.

    call compute_strain(grid, params, grid%material_id, strain_cfg, a0_ref, &
      strain_out)

    ! Expected strain at InAs points (standard pseudomorphic convention)
    eps_0_expected = (a0_ref - params(2)%a0) / params(2)%a0
    eps_zz_expected = -2.0_dp * params(2)%C12 / params(2)%C11 * eps_0_expected

    ! Check InAs points (5..8): eps_xx = eps_yy = eps_0, eps_zz correct, eps_yz = 0
    do ij = 5, 8
      @assertEqual(eps_0_expected, strain_out%eps_xx(ij), tolerance=1.0e-12_dp)
      @assertEqual(eps_0_expected, strain_out%eps_yy(ij), tolerance=1.0e-12_dp)
      @assertEqual(eps_zz_expected, strain_out%eps_zz(ij), tolerance=1.0e-10_dp)
      @assertEqual(0.0_dp, strain_out%eps_yz(ij), tolerance=1.0e-15_dp)
    end do

    ! Check GaAs points (1..4 and 9..10): all zero (lattice-matched)
    max_err = 0.0_dp
    do ij = 1, 4
      max_err = max(max_err, abs(strain_out%eps_xx(ij)))
      max_err = max(max_err, abs(strain_out%eps_yy(ij)))
      max_err = max(max_err, abs(strain_out%eps_zz(ij)))
      max_err = max(max_err, abs(strain_out%eps_yz(ij)))
    end do
    do ij = 9, 10
      max_err = max(max_err, abs(strain_out%eps_xx(ij)))
      max_err = max(max_err, abs(strain_out%eps_yy(ij)))
      max_err = max(max_err, abs(strain_out%eps_zz(ij)))
      max_err = max(max_err, abs(strain_out%eps_yz(ij)))
    end do
    @assertTrue(max_err < 1.0e-15_dp, message="GaAs points have zero strain")

    call strain_result_free(strain_out)
    deallocate(grid%z, grid%material_id)

  end subroutine test_biaxial_strain_qw


  @test
  subroutine test_strain_disabled()
    ! strain_config with enabled=.false.
    ! compute_strain should allocate zero arrays and return immediately.

    integer, parameter :: ny = 5
    type(spatial_grid) :: grid
    type(paramStruct) :: params(2)
    character(len=255) :: materials(2)
    type(strain_config) :: strain_cfg
    type(strain_result) :: strain_out
    real(kind=dp) :: a0_ref
    real(kind=dp) :: max_val
    integer :: ij

    materials(1) = "GaAs"
    materials(2) = "InAs"
    call paramDatabase(materials, 2, params)

    a0_ref = params(1)%a0

    grid%ndim = 1
    grid%nx = 1
    grid%ny = ny
    grid%dx = 0.0_dp
    grid%dy = 1.0_dp
    allocate(grid%z(ny))
    allocate(grid%material_id(ny))
    grid%material_id = [1, 2, 2, 2, 1]

    ! Strain disabled
    strain_cfg%enabled = .false.

    call compute_strain(grid, params, grid%material_id, strain_cfg, a0_ref, &
      strain_out)

    ! All arrays should be zero
    max_val = 0.0_dp
    do ij = 1, ny
      max_val = max(max_val, abs(strain_out%eps_xx(ij)))
      max_val = max(max_val, abs(strain_out%eps_yy(ij)))
      max_val = max(max_val, abs(strain_out%eps_zz(ij)))
      max_val = max(max_val, abs(strain_out%eps_yz(ij)))
    end do
    @assertTrue(max_val == 0.0_dp, message="Disabled strain produces zero arrays")

    call strain_result_free(strain_out)
    deallocate(grid%z, grid%material_id)

  end subroutine test_strain_disabled


  @test
  subroutine test_lattice_matched()
    ! All materials have same a0 (all GaAs).
    ! compute_strain should detect lattice-matched and return zero arrays.

    integer, parameter :: ny = 8
    type(spatial_grid) :: grid
    type(paramStruct) :: params(1)
    character(len=255) :: materials(1)
    type(strain_config) :: strain_cfg
    type(strain_result) :: strain_out
    real(kind=dp) :: a0_ref
    real(kind=dp) :: max_val
    integer :: ij

    materials(1) = "GaAs"
    call paramDatabase(materials, 1, params)

    a0_ref = params(1)%a0

    grid%ndim = 1
    grid%nx = 1
    grid%ny = ny
    grid%dx = 0.0_dp
    grid%dy = 1.0_dp
    allocate(grid%z(ny))
    allocate(grid%material_id(ny))
    grid%material_id = 1  ! all GaAs

    strain_cfg%enabled = .true.

    call compute_strain(grid, params, grid%material_id, strain_cfg, a0_ref, &
      strain_out)

    ! All strain arrays should be zero
    max_val = 0.0_dp
    do ij = 1, ny
      max_val = max(max_val, abs(strain_out%eps_xx(ij)))
      max_val = max(max_val, abs(strain_out%eps_yy(ij)))
      max_val = max(max_val, abs(strain_out%eps_zz(ij)))
      max_val = max(max_val, abs(strain_out%eps_yz(ij)))
    end do
    @assertTrue(max_val == 0.0_dp, message="Lattice-matched produces zero strain")

    call strain_result_free(strain_out)
    deallocate(grid%z, grid%material_id)

  end subroutine test_lattice_matched


  @test
  subroutine test_strain_result_free()
    ! Allocate a strain_result, free it, verify deallocation.

    type(strain_result) :: s
    integer :: n

    n = 5
    allocate(s%eps_xx(n), s%eps_yy(n), s%eps_zz(n), s%eps_yz(n))
    s%eps_xx = 0.1_dp
    s%eps_yy = 0.2_dp
    s%eps_zz = 0.3_dp
    s%eps_yz = 0.0_dp

    ! Verify allocated before free
    @assertTrue(allocated(s%eps_xx), message="eps_xx allocated before free")
    @assertTrue(allocated(s%eps_yy), message="eps_yy allocated before free")
    @assertTrue(allocated(s%eps_zz), message="eps_zz allocated before free")
    @assertTrue(allocated(s%eps_yz), message="eps_yz allocated before free")

    call strain_result_free(s)

    ! Verify deallocated after free
    @assertFalse(allocated(s%eps_xx), message="eps_xx deallocated after free")
    @assertFalse(allocated(s%eps_yy), message="eps_yy deallocated after free")
    @assertFalse(allocated(s%eps_zz), message="eps_zz deallocated after free")
    @assertFalse(allocated(s%eps_yz), message="eps_yz deallocated after free")

  end subroutine test_strain_result_free


  @test
  subroutine test_strain_wire_biaxial()
    ! Wire plane-strain PDE: InAs square core in GaAs substrate.
    ! Uses grid_init_rect for a fully-active rectangular grid.
    ! 60x60 grid, 300x300 A domain. InAs square core: central 40x40 A region.
    ! a0_ref = GaAs a0 (substrate). InAs a0 > GaAs a0 => hydrostatic compression in core.
    !
    ! grid_init_rect is used because the strain solver's PARDISO backend
    ! requires all matrix rows to be populated (no zero rows from inactive
    ! cells). With rect, all cells are active (cell_volume=1).
    ! A square core avoids staircase-interface artifacts present with
    ! circular geometry on a Cartesian grid.

    integer, parameter :: nx = 60, ny = 60
    real(kind=dp), parameter :: Lx = 300.0_dp, Ly = 300.0_dp
    real(kind=dp), parameter :: core_half = 20.0_dp  ! half-width of square core

    type(spatial_grid) :: grid
    type(paramStruct) :: params(2)
    character(len=255) :: materials(2)
    type(strain_config) :: strain_cfg
    type(strain_result) :: strain_out
    real(kind=dp) :: a0_ref
    real(kind=dp) :: dx, dy, cx, cy, x_coord, y_coord
    real(kind=dp) :: max_strain, boundary_strain, tr_eps
    real(kind=dp) :: jump_max
    integer :: ix, iy, ij, mid
    integer :: material_id_2d(nx, ny)
    integer :: n_core_active, n_boundary_active

    dx = Lx / real(nx, kind=dp)
    dy = Ly / real(ny, kind=dp)
    cx = 0.5_dp * Lx
    cy = 0.5_dp * Ly
    ! Material 1 = InAs, Material 2 = GaAs
    materials(1) = "InAs"
    materials(2) = "GaAs"
    call paramDatabase(materials, 2, params)

    a0_ref = params(2)%a0  ! GaAs lattice constant = substrate reference

    ! Build material_id_2d: InAs in central square, GaAs elsewhere
    do iy = 1, ny
      do ix = 1, nx
        x_coord = (ix - 0.5_dp) * dx
        y_coord = (iy - 0.5_dp) * dy
        if (abs(x_coord - cx) <= core_half .and. abs(y_coord - cy) <= core_half) then
          material_id_2d(ix, iy) = 1  ! InAs
        else
          material_id_2d(ix, iy) = 2  ! GaAs
        end if
      end do
    end do

    ! Initialize rectangular grid (all cells active, cell_volume=1)
    call grid_init_rect(grid, nx, ny, dx, dy, material_id_2d)

    ! Enable strain
    strain_cfg%enabled = .true.

    call compute_strain(grid, params, grid%material_id, strain_cfg, a0_ref, &
      strain_out)

    ! ================================================================
    ! Assertion 1: eps_yy and eps_zz are non-zero at interior InAs points
    ! ================================================================
    max_strain = 0.0_dp
    n_core_active = 0
    do iy = 1, ny
      do ix = 1, nx
        ij = (iy - 1) * nx + ix
        if (grid%material_id(ij) /= 1) cycle  ! InAs only
        x_coord = grid%x(ix)
        y_coord = grid%z(iy)
        ! Only deep interior (half the core size)
        if (abs(x_coord - cx) > 0.5_dp * core_half .or. &
            abs(y_coord - cy) > 0.5_dp * core_half) cycle
        n_core_active = n_core_active + 1
        max_strain = max(max_strain, abs(strain_out%eps_yy(ij)))
        max_strain = max(max_strain, abs(strain_out%eps_zz(ij)))
      end do
    end do
    @assertTrue(n_core_active > 0, message="Found active InAs core points")
    @assertTrue(max_strain > 1.0e-6_dp, message="Strain is non-zero in InAs core")

    ! ================================================================
    ! Assertion 2: Tr(eps) < 0 in InAs core (hydrostatic compression)
    ! InAs a0 > GaAs a0 => pseudomorphic InAs is compressed => Tr < 0.
    ! Convention: eps = (a_ref - a_mat) / a_mat, compressive for InAs on GaAs.
    ! ================================================================
    tr_eps = 0.0_dp
    n_core_active = 0
    do iy = 1, ny
      do ix = 1, nx
        ij = (iy - 1) * nx + ix
        if (grid%material_id(ij) /= 1) cycle
        x_coord = grid%x(ix)
        y_coord = grid%z(iy)
        if (abs(x_coord - cx) > 0.5_dp * core_half .or. &
            abs(y_coord - cy) > 0.5_dp * core_half) cycle
        n_core_active = n_core_active + 1
        tr_eps = tr_eps + strain_out%eps_xx(ij) + strain_out%eps_yy(ij) &
                 + strain_out%eps_zz(ij)
      end do
    end do
    tr_eps = tr_eps / real(n_core_active, kind=dp)
    @assertTrue(tr_eps < 0.0_dp, message="Hydrostatic compression (Tr<0) in InAs core")

    ! ================================================================
    ! Assertion 3: eps_yy and eps_zz are continuous across interface
    ! With a square core aligned with the grid, the interface is a
    ! straight line. Displacement continuity makes the strain (gradient
    ! of displacement) approximately continuous, modulo finite-difference
    ! discretization error at the material boundary.
    ! ================================================================
    jump_max = 0.0_dp
    do iy = 2, ny - 1
      do ix = 2, nx - 1
        ij = (iy - 1) * nx + ix

        ! Check right neighbor
        if (ix < nx) then
          mid = (iy - 1) * nx + (ix + 1)
          if (grid%material_id(ij) /= grid%material_id(mid)) then
            jump_max = max(jump_max, &
              abs(strain_out%eps_yy(ij) - strain_out%eps_yy(mid)))
            jump_max = max(jump_max, &
              abs(strain_out%eps_zz(ij) - strain_out%eps_zz(mid)))
          end if
        end if

        ! Check top neighbor
        if (iy < ny) then
          mid = iy * nx + ix
          if (grid%material_id(ij) /= grid%material_id(mid)) then
            jump_max = max(jump_max, &
              abs(strain_out%eps_yy(ij) - strain_out%eps_yy(mid)))
            jump_max = max(jump_max, &
              abs(strain_out%eps_zz(ij) - strain_out%eps_zz(mid)))
          end if
        end if
      end do
    end do
    ! Continuity: max jump at interface should be bounded.
    ! Strain is computed from finite differences of displacement, and
    ! the displacement field has a gradient discontinuity at the material
    ! interface (different elastic constants), so the computed strain
    ! will show a jump. Allow jump up to the core strain magnitude.
    @assertTrue(jump_max < 1.0_dp * max_strain, message="eps_yy/eps_zz bounded across interface")

    ! ================================================================
    ! Assertion 4: Strain decays near the boundary of the domain.
    ! GaAs cells far from the interface should have small strain.
    ! ================================================================
    boundary_strain = 0.0_dp
    n_boundary_active = 0
    do iy = 1, ny
      do ix = 1, nx
        ij = (iy - 1) * nx + ix
        if (grid%material_id(ij) /= 2) cycle  ! GaAs only
        x_coord = grid%x(ix)
        y_coord = grid%z(iy)
        ! GaAs cells in the outer 30% of domain half-width
        if (abs(x_coord - cx) < 0.7_dp * 0.5_dp * Lx .and. &
            abs(y_coord - cy) < 0.7_dp * 0.5_dp * Ly) cycle
        n_boundary_active = n_boundary_active + 1
        boundary_strain = max(boundary_strain, abs(strain_out%eps_yy(ij)))
        boundary_strain = max(boundary_strain, abs(strain_out%eps_zz(ij)))
      end do
    end do
    @assertTrue(n_boundary_active > 0, message="Found GaAs boundary points")
    ! Strain at boundary should be less than in core (decay with distance)
    @assertTrue(boundary_strain < 0.3_dp * max_strain, message="Strain decays toward boundary")

    call strain_result_free(strain_out)
    call grid_free(grid)

  end subroutine test_strain_wire_biaxial


  @test
  subroutine test_bir_pikus_blocks_diagonal()
    ! Test compute_bir_pikus_blocks with known [001] biaxial strain.
    ! For [001] biaxial: eps_xx=eps_yy, eps_xy=eps_xz=eps_yz=0
    ! => R_eps=0, S_eps=0, but QT2_eps=2*Q_eps != 0

    integer, parameter :: ny = 3
    type(spatial_grid) :: grid
    type(paramStruct) :: params(1)
    character(len=255) :: materials(1)
    type(strain_result) :: strain_out
    type(bir_pikus_blocks) :: bp
    real(kind=dp) :: eps_xx_val, eps_zz_val
    real(kind=dp) :: Tr_eps, P_eps, Q_eps
    real(kind=dp) :: delta_Ec_exp, delta_EHH_exp, delta_ELH_exp, delta_ESO_exp
    integer :: ij

    materials(1) = "GaAs"
    call paramDatabase(materials, 1, params)

    ! Set up minimal grid
    grid%ndim = 1
    grid%nx = 1
    grid%ny = ny
    grid%dx = 0.0_dp
    grid%dy = 1.0_dp
    allocate(grid%z(ny))
    allocate(grid%material_id(ny))
    grid%material_id = 1

    ! Allocate strain arrays with known biaxial values
    allocate(strain_out%eps_xx(ny), strain_out%eps_yy(ny))
    allocate(strain_out%eps_zz(ny), strain_out%eps_yz(ny))

    eps_xx_val = 0.01_dp
    eps_zz_val = -0.005_dp

    strain_out%eps_xx = eps_xx_val
    strain_out%eps_yy = eps_xx_val  ! biaxial: eps_yy = eps_xx
    strain_out%eps_zz = eps_zz_val
    strain_out%eps_yz = 0.0_dp

    ! Expected values
    Tr_eps = 2.0_dp * eps_xx_val + eps_zz_val
    P_eps = -params(1)%av * Tr_eps
    Q_eps = params(1)%b_dp * 0.5_dp * (eps_zz_val - 0.5_dp * 2.0_dp * eps_xx_val)
    delta_Ec_exp  = params(1)%ac * Tr_eps
    delta_EHH_exp = -P_eps + Q_eps
    delta_ELH_exp = -P_eps - Q_eps
    delta_ESO_exp = -P_eps

    call compute_bir_pikus_blocks(strain_out, params, grid%material_id, grid, bp)

    ! Verify diagonal shifts
    do ij = 1, ny
      @assertEqual(delta_Ec_exp, bp%delta_Ec(ij), tolerance=1.0e-12_dp)
      @assertEqual(delta_EHH_exp, bp%delta_EHH(ij), tolerance=1.0e-12_dp)
      @assertEqual(delta_ELH_exp, bp%delta_ELH(ij), tolerance=1.0e-12_dp)
      @assertEqual(delta_ESO_exp, bp%delta_ESO(ij), tolerance=1.0e-12_dp)
    end do

    ! For [001] biaxial: R_eps=0, S_eps=0 (eps_xx=eps_yy, eps_xy=0)
    do ij = 1, ny
      @assertTrue(abs(bp%R_eps(ij)) < 1.0e-15_dp, message="R_eps=0 for biaxial")
      @assertTrue(abs(bp%S_eps(ij)) < 1.0e-15_dp, message="S_eps=0 for biaxial")
    end do

    ! QT2_eps = 2*Q_eps (LH-SO coupling survives for biaxial)
    do ij = 1, ny
      @assertEqual(2.0_dp * Q_eps, bp%QT2_eps(ij), tolerance=1.0e-12_dp)
    end do

    call bir_pikus_blocks_free(bp)
    call strain_result_free(strain_out)
    deallocate(grid%z, grid%material_id)

  end subroutine test_bir_pikus_blocks_diagonal


  @test
  subroutine test_bir_pikus_blocks_free()
    ! Allocate bir_pikus_blocks, free it, verify deallocation.

    type(bir_pikus_blocks) :: bp
    integer :: n

    n = 5
    allocate(bp%delta_Ec(n), bp%delta_EHH(n), bp%delta_ELH(n), bp%delta_ESO(n))
    allocate(bp%R_eps(n), bp%S_eps(n))
    allocate(bp%QT2_eps(n))

    bp%delta_Ec = 0.1_dp
    bp%delta_EHH = 0.2_dp

    ! Verify allocated
    @assertTrue(allocated(bp%delta_Ec), message="delta_Ec allocated before free")
    @assertTrue(allocated(bp%R_eps), message="R_eps allocated before free")
    @assertTrue(allocated(bp%QT2_eps), message="QT2_eps allocated before free")

    call bir_pikus_blocks_free(bp)

    @assertFalse(allocated(bp%delta_Ec), message="delta_Ec deallocated after free")
    @assertFalse(allocated(bp%delta_EHH), message="delta_EHH deallocated after free")
    @assertFalse(allocated(bp%delta_ELH), message="delta_ELH deallocated after free")
    @assertFalse(allocated(bp%delta_ESO), message="delta_ESO deallocated after free")
    @assertFalse(allocated(bp%R_eps), message="R_eps deallocated after free")
    @assertFalse(allocated(bp%S_eps), message="S_eps deallocated after free")
    @assertFalse(allocated(bp%QT2_eps), message="QT2_eps deallocated after free")

  end subroutine test_bir_pikus_blocks_free


  @test
  subroutine test_compute_bp_scalar_gaas_biaxial()
    ! Verify compute_bp_scalar matches the canonical Bir-Pikus formulas
    ! for [001] biaxial strain with GaAs parameters.
    type(paramStruct) :: params(1)
    character(len=255) :: materials(1)
    type(bp_scalar) :: s
    real(kind=dp) :: eps_xx, eps_zz, Tr_eps, P_eps, Q_eps

    materials(1) = "GaAs"
    call paramDatabase(materials, 1, params)

    eps_xx = 0.0382_dp
    eps_zz = -0.0354_dp
    Tr_eps = 2.0_dp * eps_xx + eps_zz

    s = compute_bp_scalar(params(1), eps_xx, eps_xx, eps_zz, &
      0.0_dp, 0.0_dp, 0.0_dp)

    P_eps = -params(1)%av * Tr_eps
    Q_eps = params(1)%b_dp * 0.5_dp * (eps_zz - eps_xx)

    @assertEqual(params(1)%ac * Tr_eps, s%delta_Ec, tolerance=1.0e-12_dp)
    @assertEqual(-P_eps + Q_eps, s%delta_EHH, tolerance=1.0e-12_dp)
    @assertEqual(-P_eps - Q_eps, s%delta_ELH, tolerance=1.0e-12_dp)
    @assertEqual(-P_eps, s%delta_ESO, tolerance=1.0e-12_dp)
    @assertEqual(2.0_dp * Q_eps, s%QT2_eps, tolerance=1.0e-12_dp)

    ! For [001] biaxial (eps_xx=eps_yy, eps_xy=0): R_eps=0, S_eps=0
    @assertTrue(abs(s%R_eps) < 1.0e-15_dp)
    @assertTrue(abs(s%S_eps) < 1.0e-15_dp)

  end subroutine test_compute_bp_scalar_gaas_biaxial


  @test
  subroutine test_strain_sign_inas_on_gaas()
    ! InAs on GaAs substrate: InAs has LARGER lattice constant.
    ! Pseudomorphic strain should be COMPRESSIVE (negative eps_xx).
    ! eps_xx = (a_sub - a_layer) / a_layer = (5.65325 - 6.0583) / 6.0583 < 0
    type(paramStruct) :: params(2)
    character(len=255) :: materials(2)
    type(spatial_grid) :: grid
    type(strain_config) :: strain_cfg
    type(strain_result) :: strain_out
    real(kind=dp) :: a0_ref
    integer, parameter :: ny = 4
    integer :: ij

    materials(1) = "GaAs"
    materials(2) = "InAs"
    call paramDatabase(materials, 2, params)

    a0_ref = params(1)%a0  ! GaAs = 5.65325

    grid%ndim = 1; grid%nx = 1; grid%ny = ny
    grid%dx = 0.0_dp; grid%dy = 1.0_dp
    allocate(grid%z(ny), grid%material_id(ny))
    do ij = 1, ny
      grid%z(ij) = (ij - 1) * 1.0_dp
    end do
    grid%material_id = [1, 2, 2, 1]
    strain_cfg%enabled = .true.

    call compute_strain(grid, params, grid%material_id, strain_cfg, a0_ref, &
      strain_out)

    ! InAs points (2,3): eps_xx should be NEGATIVE (compressive)
    @assertTrue(strain_out%eps_xx(2) < 0.0_dp, message="InAs on GaAs: compressive eps_xx")
    @assertTrue(strain_out%eps_xx(3) < 0.0_dp, message="InAs on GaAs: compressive eps_xx")
    ! GaAs points (1,4): eps_xx should be zero (reference material)
    @assertEqual(0.0_dp, strain_out%eps_xx(1), tolerance=1.0e-15_dp)
    @assertEqual(0.0_dp, strain_out%eps_xx(4), tolerance=1.0e-15_dp)

    call strain_result_free(strain_out)
    deallocate(grid%z, grid%material_id)

  end subroutine test_strain_sign_inas_on_gaas


  @test
  subroutine test_strain_coo_table_matches_unrolled()
    ! Build synthetic bir_pikus_blocks, insert strain COO using the
    ! (now table-driven) insert_strain_coo, and verify the expected number
    ! of entries and correct band structure.
    integer, parameter :: N = 3
    integer, parameter :: coo_cap = 32 * N + 10
    integer :: coo_r(coo_cap), coo_c(coo_cap)
    complex(kind=dp) :: coo_v(coo_cap)
    integer :: coo_idx, expected_nnz
    type(bir_pikus_blocks) :: bp

    ! Build synthetic strain blocks
    allocate(bp%delta_EHH(N), bp%delta_ELH(N), bp%delta_ESO(N), bp%delta_Ec(N))
    allocate(bp%S_eps(N), bp%R_eps(N), bp%QT2_eps(N))
    bp%delta_EHH = [1.0_dp, 2.0_dp, 3.0_dp]
    bp%delta_ELH = [0.1_dp, 0.2_dp, 0.3_dp]
    bp%delta_ESO = [0.01_dp, 0.02_dp, 0.03_dp]
    bp%delta_Ec = [10.0_dp, 11.0_dp, 12.0_dp]
    bp%S_eps = [(0.1_dp, 0.2_dp), (0.3_dp, 0.4_dp), (0.5_dp, 0.6_dp)]
    bp%R_eps = [(0.01_dp, 0.02_dp), (0.03_dp, 0.04_dp), (0.05_dp, 0.06_dp)]
    bp%QT2_eps = [(1.0_dp, 0.1_dp), (2.0_dp, 0.2_dp), (3.0_dp, 0.3_dp)]

    coo_idx = 0
    call insert_strain_coo(coo_r, coo_c, coo_v, coo_cap, coo_idx, bp, N)

    ! Must have exactly 32*N = 96 entries
    expected_nnz = 32 * N
    @assertEqual(expected_nnz, coo_idx, message="strain COO entry count")

    ! Spot-check a few entries:
    ! Entry 1: band 0 diagonal, delta_EHH(1) = (1.0, 0.0)
    @assertEqual(1, coo_r(1))
    @assertEqual(1, coo_c(1))
    @assertEqual(cmplx(1.0_dp, 0.0_dp, kind=dp), coo_v(1), tolerance=1.0e-14_dp)

    ! Entry 9 (first S_eps entry): band 0->1, conjg(S_eps(1))
    @assertEqual(1, coo_r(9))
    @assertEqual(N + 1, coo_c(9))
    @assertEqual(conjg(bp%S_eps(1)), coo_v(9), tolerance=1.0e-14_dp)

    ! Entry 13 (first R_eps entry): band 0->2, conjg(R_eps(1))
    @assertEqual(1, coo_r(13))
    @assertEqual(2*N + 1, coo_c(13))
    @assertEqual(conjg(bp%R_eps(1)), coo_v(13), tolerance=1.0e-14_dp)

    ! Entry 17 (first VB-SO coupling): band 0->4, -IU*RQS2*conjg(S_eps(1))
    @assertEqual(1, coo_r(17))
    @assertEqual(4*N + 1, coo_c(17))
    ! VB-SO entry uses -IU*RQS2*conjg(S_eps) — verify it's nonzero and complex
    @assertTrue(abs(coo_v(17)) > 0.0_dp, message="VB-SO entry is nonzero")

    call bir_pikus_blocks_free(bp)
  end subroutine test_strain_coo_table_matches_unrolled

end module test_strain_solver
