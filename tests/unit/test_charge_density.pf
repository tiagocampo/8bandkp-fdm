module test_charge_density
  use funit
  use definitions
  use charge_density
  use utils, only: simpson
  implicit none

contains

  @test
  subroutine test_fermi_dirac_zero_temp()
    ! At T -> 0, the Fermi-Dirac function becomes a step function.
    ! f(E < mu) = 1, f(E > mu) = 0.

    real(kind=dp) :: T, mu
    real(kind=dp) :: f_below, f_above, f_at

    T = 1.0e-10_dp
    mu = 1.0_dp

    f_below = fermi_dirac(0.5_dp, mu, T)
    f_above = fermi_dirac(1.5_dp, mu, T)
    f_at = fermi_dirac(1.0_dp, mu, T)

    ! E < mu: f = 1
    @assertEqual(1.0_dp, f_below, tolerance=1.0e-10_dp)
    ! E > mu: f = 0
    @assertEqual(0.0_dp, f_above, tolerance=1.0e-10_dp)
    ! E = mu: f = 0.5 in the limit, but T=0 implementation gives 0
    ! For our implementation with E == mu, energy < mu is false, so f = 0
    @assertTrue(f_at < 0.5_dp + 1.0e-10_dp, message="f at E=mu bounded")
  end subroutine test_fermi_dirac_zero_temp


  @test
  subroutine test_fermi_dirac_finite_temp()
    ! At T=300 K, mu=0:
    ! f(0) = 0.5
    ! f(kB*T) = 1/(1+e) ~ 0.2689

    real(kind=dp) :: T, mu, kB_val
    real(kind=dp) :: f_zero, f_kbt

    kB_val = 8.617333262e-5_dp
    T = 300.0_dp
    mu = 0.0_dp

    f_zero = fermi_dirac(0.0_dp, mu, T)
    f_kbt = fermi_dirac(kB_val * T, mu, T)

    ! f(0) = 0.5 exactly
    @assertEqual(0.5_dp, f_zero, tolerance=1.0e-12_dp)
    ! f(kB*T) = 1/(1+e) = 0.2689...
    @assertEqual(1.0_dp / (1.0_dp + exp(1.0_dp)), f_kbt, tolerance=1.0e-6_dp)
  end subroutine test_fermi_dirac_finite_temp


  @test
  subroutine test_eight_component_sum()
    ! Construct a known 8-component wavefunction at a single z-point.
    ! |Psi|^2 = sum_{nu=1}^8 |Psi_nu|^2 should equal the known total.
    !
    ! Use a minimal QW: N=1 (single z-point), 1 subband, 1 k_par point.
    ! Set eigenvector components such that sum of |Psi_nu|^2 = 1.0.

    integer, parameter :: N = 1
    integer, parameter :: num_subbands = 1
    integer, parameter :: num_kpar = 3
    integer, parameter :: numcb = 1
    real(kind=dp), parameter :: dz = 1.0_dp

    real(kind=dp) :: n_electron(N), n_hole(N)
    complex(kind=dp) :: eigenvectors(8*N, num_subbands, num_kpar)
    real(kind=dp) :: eigenvalues(num_subbands, num_kpar)
    real(kind=dp) :: kpar_grid(num_kpar)
    real(kind=dp) :: fermi_level, temperature
    integer :: iband

    ! Set up eigenvector: normalize so sum of |Psi_nu|^2 = 1.0
    ! Each of 8 bands gets Psi_nu = 1/sqrt(8) for the single z-point
    eigenvectors = cmplx(0.0_dp, 0.0_dp, kind=dp)
    do iband = 1, 8
      eigenvectors(iband, 1, :) = cmplx(1.0_dp / sqrt(8.0_dp), 0.0_dp, kind=dp)
    end do

    ! Set energy well below Fermi level so f=1
    fermi_level = 1.0_dp
    temperature = 300.0_dp
    eigenvalues = -1.0_dp  ! all well below mu => f ~ 1

    ! k_par grid (odd, for Simpson)
    kpar_grid(1) = 0.0_dp
    kpar_grid(2) = 0.5_dp
    kpar_grid(3) = 1.0_dp

    call compute_charge_density_qw(n_electron, n_hole, eigenvectors, &
      & eigenvalues, kpar_grid, fermi_level, temperature, N, num_subbands, &
      & num_kpar, numcb)

    ! n_electron(z) should be non-zero (CB subband, f~1, normalized wavefunction)
    ! The integral of |Psi|^2 * k_par/(2*pi) dk_par * 2 (spin) should give
    ! a definite positive number.
    @assertTrue(n_electron(1) > 0.0_dp, message="Electron density is positive")

    ! |Psi|^2 = 1.0 at each k_par. The integrand is 1.0 * f * k_par/(2*pi).
    ! For a single CB subband with f~1:
    !   n(z) = 2 * int_0^{k_max} k_par/(2*pi) dk_par * 1.0
    !        = 2 * [k_max^2 / (4*pi)]
    !        = 2 * 1.0^2 / (4*pi) = 1/(2*pi) in 1/nm^3
    ! In cm^-3: 1/(2*pi) * 1e21
    ! Simpson integral of k_par from 0 to 1 with 3 points:
    !   int = (1/3)*(1/2)*[0 + 4*0.5 + 1.0] = (1/6)*3 = 0.5
    ! Then divided by (2*pi): 0.5/(2*pi)
    ! Times spin factor 2: 2 * 0.5/(2*pi) = 1/(2*pi)
    ! In cm^-3: 1/(2*pi) * 1e21
    ! But wait, eigenvalues = -1 for ALL k_par, so f(-1, 1, 300) = f(E-mu = -2)
    ! which is very close to 1.

    ! Expected: ~ 1/(2*pi) * 1e24 ~ 1.59e23 cm^-3 (conversion from 1/AA^3)
    @assertTrue(n_electron(1) > 5.0e22_dp, message="Electron density lower bound")
    @assertTrue(n_electron(1) < 5.0e23_dp, message="Electron density upper bound")
  end subroutine test_eight_component_sum


  @test
  subroutine test_delta_function()
    ! Single Gaussian-like wavefunction centered at z=0.
    ! At T->0 with E < mu, f = 1 for all k_par.
    ! Use N=5 z-points, 1 CB subband, 3 k_par points.
    !
    ! Place all wavefunction weight at z-point 1 (delta-function-like).
    ! |Psi|^2 should be nonzero only at iz=1.
    ! After integration, n(z) should be nonzero only at iz=1.

    integer, parameter :: N = 5
    integer, parameter :: num_subbands = 1
    integer, parameter :: num_kpar = 3
    integer, parameter :: numcb = 1
    real(kind=dp), parameter :: dz = 1.0_dp

    real(kind=dp) :: n_electron(N), n_hole(N)
    complex(kind=dp) :: eigenvectors(8*N, num_subbands, num_kpar)
    real(kind=dp) :: eigenvalues(num_subbands, num_kpar)
    real(kind=dp) :: kpar_grid(num_kpar)
    real(kind=dp) :: fermi_level, temperature

    ! Initialize all to zero
    eigenvectors = cmplx(0.0_dp, 0.0_dp, kind=dp)

    ! Set wavefunction: band 7 (CB), z-point 1 only, normalized
    ! 8 bands, each has N=5 z-points
    ! Band 7: indices (6*N + 1) to (7*N) => 31..35
    ! Put all weight at z-point 1 (index 31)
    eigenvectors(31, 1, :) = cmplx(1.0_dp, 0.0_dp, kind=dp)  ! band 7, z=1

    ! Energy below Fermi level
    fermi_level = 2.0_dp
    temperature = 1.0e-10_dp  ! T -> 0
    eigenvalues = 0.0_dp  ! E < mu => f = 1

    ! k_par grid
    kpar_grid(1) = 0.0_dp
    kpar_grid(2) = 0.5_dp
    kpar_grid(3) = 1.0_dp

    call compute_charge_density_qw(n_electron, n_hole, eigenvectors, &
      & eigenvalues, kpar_grid, fermi_level, temperature, N, num_subbands, &
      & num_kpar, numcb)

    ! n_electron(1) should be the only nonzero value
    @assertTrue(n_electron(1) > 0.0_dp, message="Electron density nonzero at z=1")

    ! n_electron(2..5) should be essentially zero
    @assertTrue(n_electron(2) < 1.0e6_dp, message="Electron density zero away from peak")
    @assertTrue(n_electron(3) < 1.0e6_dp, message="Electron density zero at z=3")
    @assertTrue(n_electron(4) < 1.0e6_dp, message="Electron density zero at z=4")
    @assertTrue(n_electron(5) < 1.0e6_dp, message="Electron density zero at z=5")

    ! Hole density should be zero (no VB subbands occupied with these params)
    @assertTrue(n_hole(1) < 1.0e6_dp, message="Hole density zero (no VB subbands)")
  end subroutine test_delta_function


  @test
  subroutine test_bulk_charge_density()
    ! Bulk charge density with 8 subbands, 3 k-points.
    ! CB subbands (s=7,8) at E=1.0, VB subbands (s=1..6) at E=-1.0.
    ! Fermi level at -2.0: both VB and CB states above mu.
    ! For VB at E=-1.0: f(-1.0, -2.0, 300) ≈ 1/(1+exp(38.7)) ≈ 0
    !   => holes = (1-f) ≈ 1 (VB empty => lots of holes)
    ! For CB at E=+1.0: f(1.0, -2.0, 300) ≈ 1/(1+exp(116)) ≈ 0
    !   => electrons = f ≈ 0

    integer, parameter :: num_subbands = 8
    integer, parameter :: num_k = 3
    real(kind=dp) :: n_electron, n_hole
    real(kind=dp) :: eigenvalues(num_subbands, num_k)
    real(kind=dp) :: k_grid(num_k)
    real(kind=dp) :: fermi_level, temperature
    integer :: s

    ! VB subbands at E=-1.0, CB subbands at E=+1.0
    do s = 1, 6
      eigenvalues(s, :) = -1.0_dp
    end do
    eigenvalues(7, :) = 1.0_dp
    eigenvalues(8, :) = 1.0_dp

    fermi_level = -2.0_dp
    temperature = 300.0_dp

    k_grid(1) = 0.0_dp
    k_grid(2) = 0.1_dp
    k_grid(3) = 0.2_dp

    call compute_charge_density_bulk(n_electron, n_hole, eigenvalues, &
      & k_grid, fermi_level, temperature, num_subbands, num_k)

    ! Holes should be significant (VB empty, 1-f ~ 1)
    ! Electrons should be negligible (CB far above Fermi level)
    @assertTrue(n_hole > 1.0e18_dp, message="Bulk hole density significant")
    @assertTrue(n_electron < 1.0e10_dp, message="Bulk electron density negligible")
    @assertTrue(n_hole > n_electron, message="More holes than electrons")
  end subroutine test_bulk_charge_density

  @test
  subroutine test_wire_normalization()
    ! Wire with Ny=Nz=5 (Ngrid=25), 2 subbands, 3 kx points.
    ! All eigenvalues well below Fermi level (fully occupied).
    ! Normalized eigenstates: sum of |Psi_nu|^2 over all grid points = 1.
    !
    ! For 1 CB subband with f~1:
    !   n(y,z) = 2 * int dkx/(2*pi) * |Psi|^2
    !   With Simpson over kx from 0 to kx_max:
    !     int_0^{kx_max} dkx = kx_max  (analytically)
    !   So n at each grid point = 2 * kx_max / (2*pi) * |Psi(p)|^2
    !
    ! Total integrated charge = sum_p n(p) * dA
    ! With normalized states (sum_p |Psi|^2 = 1) and dA not needed since
    ! we just sum n(p):
    !   sum_p n(p) = 2 * numcb * int dkx/(2*pi)
    !
    ! With kx_max=1.0, Simpson with 3 points gives exact integral = 1.0.
    ! So sum_p n(p) = 2 * numcb * 1.0 / (2*pi)
    ! In 1/AA^3: = numcb / pi
    ! In cm^-3: = numcb/pi * 1e24

    integer, parameter :: Ny = 5, Nz = 5
    integer, parameter :: Ngrid = Ny * Nz   ! 25
    integer, parameter :: num_subbands = 2
    integer, parameter :: num_kx = 3
    integer, parameter :: numcb = 1

    real(kind=dp) :: n_electron(Ngrid), n_hole(Ngrid)
    complex(kind=dp) :: eigenvectors(8*Ngrid, num_subbands, num_kx)
    real(kind=dp) :: eigenvalues(num_subbands, num_kx)
    real(kind=dp) :: kx_grid(num_kx)
    real(kind=dp) :: fermi_level, temperature
    real(kind=dp) :: total_charge, expected
    real(kind=dp) :: norm_factor
    integer :: iband, p

    ! Set up normalized eigenvectors for CB subband (s=1):
    ! |Psi_nu(p)|^2 = 1/(8*Ngrid) so sum = 1.0
    eigenvectors = cmplx(0.0_dp, 0.0_dp, kind=dp)
    norm_factor = 1.0_dp / sqrt(8.0_dp * real(Ngrid, kind=dp))
    do iband = 1, 8
      do p = 1, Ngrid
        eigenvectors((iband - 1)*Ngrid + p, 1, :) = &
          & cmplx(norm_factor, 0.0_dp, kind=dp)
      end do
    end do
    ! VB subband (s=2): same normalization
    do iband = 1, 8
      do p = 1, Ngrid
        eigenvectors((iband - 1)*Ngrid + p, 2, :) = &
          & cmplx(norm_factor, 0.0_dp, kind=dp)
      end do
    end do

    ! Eigenvalues: CB subband has higher energy, VB has lower.
    ! Sorted descending: highest numcb=1 -> CB (s=2, E=+1.0), rest -> VB (s=1, E=-5.0)
    ! Fermi level at 0.0:
    !   CB at E=+1.0: f(1.0, 0.0, 300) ~ 1/(1+exp(38.7)) ~ 0 => no electrons
    !   VB at E=-5.0: f(-5.0, 0.0, 300) ~ 1 => holes = 1-f ~ 0
    ! That's wrong. Let's set Fermi at +2.0:
    !   CB at E=+1.0: f(1.0, 2.0, 300) ~ 1/(1+exp(-38.7)) ~ 1 => electrons present
    !   VB at E=-5.0: f(-5.0, 2.0, 300) ~ 1/(1+exp(-257)) ~ 1 => holes = 1-f ~ 0
    ! Still wrong for holes. For holes we need VB states ABOVE Fermi.
    ! Let's use a Fermi level between CB and VB mid-gap, and verify electrons only.

    ! Setup: subband 2 is CB (E=+1.0), subband 1 is VB (E=-1.0)
    ! Fermi at +3.0 so CB is occupied (f~1) and VB is fully occupied (f~1 => holes~0)
    fermi_level = 3.0_dp
    temperature = 300.0_dp
    eigenvalues(1, :) = -1.0_dp   ! Lower energy -> VB after sorting
    eigenvalues(2, :) =  1.0_dp   ! Higher energy -> CB after sorting

    ! kx grid
    kx_grid(1) = 0.0_dp
    kx_grid(2) = 0.5_dp
    kx_grid(3) = 1.0_dp

    call compute_charge_density_wire(n_electron, n_hole, eigenvectors, &
      & eigenvalues, kx_grid, fermi_level, temperature, Ny, Nz, num_subbands, &
      & num_kx, numcb)

    ! Total electron charge: sum over all grid points
    total_charge = sum(n_electron)

    ! Expected: 2 * int_0^1 dkx/(2*pi) * sum_p |Psi|^2
    ! Simpson integral of 1 from 0 to 1 with 3 points = 1.0
    ! weight = 1/(2*pi), spin factor = 2
    ! sum_p |Psi_s|^2 = 8*Ngrid * (1/(8*Ngrid)) = 1.0 for each subband
    ! For 1 CB subband with f~1:
    !   n_total = 2 * 1.0/(2*pi) * 1.0 * 1e24 = 1/pi * 1e24
    expected = numcb * 1.0e24_dp / pi_dp

    ! Allow 1% tolerance for Simpson vs analytic
    @assertEqual(expected, total_charge, tolerance=0.01_dp * expected)

    ! Electron density should be positive at all points
    @assertTrue(all(n_electron > 0.0_dp), message="All electron density values positive")

    ! Hole density: VB at E=-1.0, Fermi at +3.0 => f~1 => holes = 1-f ~ 0
    ! So hole density should be negligible
    @assertTrue(all(n_hole < 1.0e10_dp), message="Hole density negligible (VB full)")

  end subroutine test_wire_normalization


  @test
  subroutine test_wire_localized_state()
    ! Wire with localized eigenstate: all weight at one grid point.
    ! n_electron should be nonzero only at that grid point.

    integer, parameter :: Ny = 3, Nz = 3
    integer, parameter :: Ngrid = Ny * Nz   ! 9
    integer, parameter :: num_subbands = 1
    integer, parameter :: num_kx = 3
    integer, parameter :: numcb = 1

    real(kind=dp) :: n_electron(Ngrid), n_hole(Ngrid)
    complex(kind=dp) :: eigenvectors(8*Ngrid, num_subbands, num_kx)
    real(kind=dp) :: eigenvalues(num_subbands, num_kx)
    real(kind=dp) :: kx_grid(num_kx)
    real(kind=dp) :: fermi_level, temperature
    integer :: iband

    ! All zero
    eigenvectors = cmplx(0.0_dp, 0.0_dp, kind=dp)

    ! Put all weight at grid point p=5 (center of 3x3), band 7
    ! Band 7 starts at index (7-1)*Ngrid + 1 = 55
    do iband = 1, num_kx
      eigenvectors(6*Ngrid + 5, 1, iband) = cmplx(1.0_dp, 0.0_dp, kind=dp)
    end do

    ! Energy below Fermi level => f = 1
    fermi_level = 2.0_dp
    temperature = 1.0e-10_dp
    eigenvalues = 0.0_dp

    kx_grid(1) = 0.0_dp
    kx_grid(2) = 0.5_dp
    kx_grid(3) = 1.0_dp

    call compute_charge_density_wire(n_electron, n_hole, eigenvectors, &
      & eigenvalues, kx_grid, fermi_level, temperature, Ny, Nz, num_subbands, &
      & num_kx, numcb)

    ! Only grid point 5 should have nonzero electron density
    @assertTrue(n_electron(5) > 0.0_dp, message="Localized state nonzero at p=5")

    ! All other points should be zero
    @assertTrue(n_electron(1) < 1.0e6_dp, message="Density zero at p=1")
    @assertTrue(n_electron(2) < 1.0e6_dp, message="Density zero at p=2")
    @assertTrue(n_electron(3) < 1.0e6_dp, message="Density zero at p=3")
    @assertTrue(n_electron(4) < 1.0e6_dp, message="Density zero at p=4")
    @assertTrue(n_electron(6) < 1.0e6_dp, message="Density zero at p=6")
    @assertTrue(n_electron(7) < 1.0e6_dp, message="Density zero at p=7")
    @assertTrue(n_electron(8) < 1.0e6_dp, message="Density zero at p=8")
    @assertTrue(n_electron(9) < 1.0e6_dp, message="Density zero at p=9")

    ! Hole density should be zero (no VB subbands)
    @assertTrue(all(n_hole < 1.0e6_dp), message="Hole density zero (no VB)")

  end subroutine test_wire_localized_state


end module test_charge_density
