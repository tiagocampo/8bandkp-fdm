module test_bdg_config
  use funit
  use definitions
  use input_parser
  implicit none

contains

  @test
  subroutine test_bdg_g_factor_parsing()
    type(simulation_config) :: cfg

    ! Write a minimal TOML config with [bdg] block including g_factor
    open(unit=99, file='input.toml', status='replace', action='write')
    write(99, '(A)') 'confinement = "bulk"'
    write(99, '(A)') 'FDorder = 2'
    write(99, '(A)') ''
    write(99, '(A)') '[[material]]'
    write(99, '(A)') 'name = "InAs"'
    write(99, '(A)') ''
    write(99, '(A)') '[wave_vector]'
    write(99, '(A)') 'mode = "k0"'
    write(99, '(A)') ''
    write(99, '(A)') '[bands]'
    write(99, '(A)') 'num_cb = 1'
    write(99, '(A)') 'num_vb = 2'
    write(99, '(A)') ''
    write(99, '(A)') '[topology]'
    write(99, '(A)') 'mode = "bdg"'
    write(99, '(A)') ''
    write(99, '(A)') '[bdg]'
    write(99, '(A)') 'mu = 0.010'
    write(99, '(A)') 'delta_0 = 0.0003'
    write(99, '(A)') 'g_factor = 2.0'
    write(99, '(A)') 'gauge = "landau_y"'
    close(99)

    call read_config(cfg)

    ! Verify g_factor was parsed correctly
    @assertEqual(2.0_dp, cfg%bdg%g_factor, tolerance=1.0e-6_dp)
    @assertEqual(0.010_dp, cfg%bdg%mu, tolerance=1.0e-6_dp)
    @assertEqual(0.0003_dp, cfg%bdg%delta_0, tolerance=1.0e-8_dp)
    @assertEqual('landau_y', trim(cfg%bdg%gauge))

    close(unit=99, status='delete')
  end subroutine

end module
