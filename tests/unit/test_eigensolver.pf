module test_eigensolver
  ! COVERAGE: observable=solver_dispatch_dense geometry=generic material=generic
  ! COVERAGE: observable=solver_dispatch_feast geometry=generic material=generic
  ! COVERAGE: observable=solver_config_validation geometry=generic material=generic
  ! COVERAGE: observable=solver_defaults_resolution geometry=generic material=generic
  use funit
  use definitions
  use sparse_matrices
  use eigensolver
  use csr_test_helpers, only: eigensolve_csr
  implicit none

  ! Number of (confinement, method, mode) combos exercised by the
  ! table-driven AUTO-resolution tests: 4 x 3 x 4 = 48.
  integer, parameter :: NRESOLVE_COMBOS = 48

contains

  ! ==================================================================
  ! Helper: build a diagonal CSR matrix from real diagonal values.
  ! ==================================================================
  subroutine build_diagonal_csr(diag_vals, n, mat)
    integer, intent(in)             :: n
    real(kind=dp), intent(in)       :: diag_vals(n)
    type(csr_matrix), intent(out)   :: mat
    integer :: i
    integer, allocatable :: rows(:), cols(:)
    complex(kind=dp), allocatable :: vals(:)

    allocate(rows(n), cols(n), vals(n))
    do i = 1, n
      rows(i) = i
      cols(i) = i
      vals(i) = cmplx(diag_vals(i), 0.0_dp, kind=dp)
    end do
    call csr_build_from_coo(mat, n, n, n, rows, cols, vals)
    deallocate(rows, cols, vals)
  end subroutine build_diagonal_csr

  ! ==================================================================
  ! Helper: build a real symmetric tridiagonal CSR matrix.
  ! Main diagonal = dval, sub/super diagonal = oval.
  ! ==================================================================
  subroutine build_tridiag_csr(dval, oval, n, mat)
    real(kind=dp), intent(in)       :: dval, oval
    integer, intent(in)             :: n
    type(csr_matrix), intent(out)   :: mat
    integer :: i, nnz
    integer, allocatable :: rows(:), cols(:)
    complex(kind=dp), allocatable :: vals(:)

    nnz = n + 2*(n-1)
    allocate(rows(nnz), cols(nnz), vals(nnz))
    nnz = 0
    do i = 1, n
      nnz = nnz + 1
      rows(nnz) = i
      cols(nnz) = i
      vals(nnz) = cmplx(dval, 0.0_dp, kind=dp)
      if (i < n) then
        nnz = nnz + 1
        rows(nnz) = i
        cols(nnz) = i + 1
        vals(nnz) = cmplx(oval, 0.0_dp, kind=dp)
      end if
      if (i > 1) then
        nnz = nnz + 1
        rows(nnz) = i
        cols(nnz) = i - 1
        vals(nnz) = cmplx(oval, 0.0_dp, kind=dp)
      end if
    end do
    call csr_build_from_coo(mat, n, n, nnz, rows(1:nnz), &
                            cols(1:nnz), vals(1:nnz))
    deallocate(rows, cols, vals)
  end subroutine build_tridiag_csr

  ! ==================================================================
  ! Test 1: FEAST on a diagonal matrix.
  ! Eigenvalues should equal the diagonal entries within the interval.
  ! ==================================================================
  @test
  subroutine test_feast_diagonal()
    integer, parameter :: n = 20
    real(kind=dp) :: diag(n)
    type(csr_matrix) :: H
    type(eigensolver_config) :: cfg
    type(eigensolver_result) :: res
    integer :: i

    do i = 1, n
      diag(i) = real(i, kind=dp)
    end do
    call build_diagonal_csr(diag, n, H)

    cfg%method = 'FEAST'
    cfg%emin = 0.5_dp
    cfg%emax = 5.5_dp
    cfg%nev = 5

    call solve_feast(H, cfg, res)

    @assertTrue(res%converged)
    @assertEqual(5, res%nev_found)

    ! Eigenvalues in [0.5, 5.5] are 1, 2, 3, 4, 5
    do i = 1, res%nev_found
      @assertEqual(real(i, kind=dp), res%eigenvalues(i), tolerance=1.0e-8_dp)
    end do

    call eigensolver_result_free(res)
    call csr_free(H)
  end subroutine test_feast_diagonal

  ! ==================================================================
  ! Test 2: FEAST on a tridiagonal Laplacian (1D, hard-wall).
  !
  ! The 1D discrete Laplacian on N points with spacing h has eigenvalues:
  !   lambda_k = 2*(1 - cos(k*pi/(N+1))) / h^2,  k = 1..N
  ! ==================================================================
  @test
  subroutine test_feast_tridiagonal_laplacian()
    integer, parameter :: n = 20
    real(kind=dp), parameter :: grid_dx = 1.0_dp
    real(kind=dp), parameter :: pi = pi_dp  ! use module constant
    type(csr_matrix) :: Hmat
    type(eigensolver_config) :: cfg
    type(eigensolver_result) :: res
    real(kind=dp) :: expected
    integer :: k

    call build_tridiag_csr(2.0_dp/grid_dx**2, -1.0_dp/grid_dx**2, n, Hmat)

    ! First verify with dense LAPACK that the matrix is correct
    cfg%method = 'DENSE'
    cfg%nev = 3
    cfg%emin = 0.0_dp
    cfg%emax = 0.0_dp
    call eigensolve_csr(Hmat, cfg, res)

    @assertTrue(res%converged)
    @assertEqual(3, res%nev_found)

    ! Check first 3 eigenvalues match analytical Laplacian values
    do k = 1, 3
      expected = 2.0_dp * (1.0_dp - cos(real(k, kind=dp) * pi / real(n+1, kind=dp))) / grid_dx**2
      @assertEqual(expected, res%eigenvalues(k), tolerance=1.0e-6_dp)
    end do

    call eigensolver_result_free(res)

    ! Now test FEAST with a wider interval to verify convergence.
    ! Use emin slightly below the smallest eigenvalue and emax above the
    ! first few eigenvalues, with sufficient M0.
    cfg%method = 'FEAST'
    cfg%emin = 0.01_dp
    cfg%emax = 0.25_dp
    cfg%nev = 3
    cfg%m0 = 10

    call solve_feast(Hmat, cfg, res)

    @assertTrue(res%converged)
    @assertTrue(res%nev_found >= 2)

    ! Check that FEAST eigenvalues match analytical values (sorted)
    do k = 1, min(res%nev_found, 3)
      expected = 2.0_dp * (1.0_dp - cos(real(k, kind=dp) * pi / real(n+1, kind=dp))) / grid_dx**2
      @assertEqual(expected, res%eigenvalues(k), tolerance=1.0e-6_dp)
    end do

    call eigensolver_result_free(res)
    call csr_free(Hmat)
  end subroutine test_feast_tridiagonal_laplacian

  ! ==================================================================
  ! Test 3: Eigenvector orthonormality (v^H v = I).
  ! ==================================================================
  @test
  subroutine test_eigenvector_orthonormality()
    integer, parameter :: n = 20
    real(kind=dp) :: diag(n)
    type(csr_matrix) :: H
    type(eigensolver_config) :: cfg
    type(eigensolver_result) :: res
    complex(kind=dp) :: dot_prod
    real(kind=dp) :: ortho_err
    integer :: i, j

    do i = 1, n
      diag(i) = real(i, kind=dp)
    end do
    call build_diagonal_csr(diag, n, H)

    cfg%method = 'FEAST'
    cfg%emin = 0.5_dp
    cfg%emax = 5.5_dp
    cfg%nev = 5

    call solve_feast(H, cfg, res)

    @assertTrue(res%converged)
    @assertTrue(res%nev_found >= 2)

    do i = 1, res%nev_found
      do j = 1, res%nev_found
        dot_prod = dot_product(res%eigenvectors(:,i), res%eigenvectors(:,j))
        if (i == j) then
          ortho_err = abs(dot_prod - cmplx(1.0_dp, 0.0_dp, kind=dp))
        else
          ortho_err = abs(dot_prod)
        end if
        @assertTrue(ortho_err < 1.0e-8_dp)
      end do
    end do

    call eigensolver_result_free(res)
    call csr_free(H)
  end subroutine test_eigenvector_orthonormality

  ! ==================================================================
  ! Test 4: Identity matrix -- all eigenvalues = 1.
  ! ==================================================================
  @test
  subroutine test_feast_identity()
    integer, parameter :: n = 10
    real(kind=dp) :: diag(n)
    type(csr_matrix) :: H
    type(eigensolver_config) :: cfg
    type(eigensolver_result) :: res
    integer :: i

    do i = 1, n
      diag(i) = 1.0_dp
    end do
    call build_diagonal_csr(diag, n, H)

    cfg%method = 'FEAST'
    cfg%emin = 0.5_dp
    cfg%emax = 1.5_dp
    cfg%nev = 10

    call solve_feast(H, cfg, res)

    @assertTrue(res%converged)
    @assertEqual(10, res%nev_found)

    do i = 1, res%nev_found
      @assertEqual(1.0_dp, res%eigenvalues(i), tolerance=1.0e-8_dp)
    end do

    call eigensolver_result_free(res)
    call csr_free(H)
  end subroutine test_feast_identity

  ! ==================================================================
  ! Test 5: Dispatch routine selects FEAST correctly.
  ! ==================================================================
  @test
  subroutine test_dispatch_feast()
    integer, parameter :: n = 5
    real(kind=dp) :: diag(n)
    type(csr_matrix) :: H
    type(eigensolver_config) :: cfg
    type(eigensolver_result) :: res
    integer :: i

    do i = 1, n
      diag(i) = real(i, kind=dp)
    end do
    call build_diagonal_csr(diag, n, H)

    cfg%method = 'FEAST'
    cfg%emin = 0.5_dp
    cfg%emax = 3.5_dp
    cfg%nev = 3

    call eigensolve_csr(H, cfg, res)

    @assertTrue(res%converged)
    @assertEqual(3, res%nev_found)

    call eigensolver_result_free(res)
    call csr_free(H)
  end subroutine test_dispatch_feast

  ! ==================================================================
  ! Test 7: Empty matrix returns gracefully.
  ! ==================================================================
  @test
  subroutine test_feast_empty_matrix()
    type(csr_matrix) :: H
    type(eigensolver_config) :: cfg
    type(eigensolver_result) :: res

    call csr_init(H, 0, 0)

    cfg%method = 'FEAST'
    cfg%emin = -1.0_dp
    cfg%emax = 1.0_dp
    cfg%nev = 4

    call solve_feast(H, cfg, res)

    @assertFalse(res%converged)
    @assertEqual(0, res%nev_found)

    call csr_free(H)
  end subroutine test_feast_empty_matrix

  ! ==================================================================
  ! Test 8: Gershgorin energy window estimation.
  ! ==================================================================
  @test
  subroutine test_energy_window_gershgorin()
    integer, parameter :: n = 10
    real(kind=dp) :: diag(n)
    type(csr_matrix) :: H
    real(kind=dp) :: emin, emax
    integer :: i

    do i = 1, n
      diag(i) = real(i, kind=dp)  ! eigenvalues 1..10
    end do
    call build_diagonal_csr(diag, n, H)

    call auto_compute_energy_window(H, emin, emax)

    ! For diagonal matrix, Gershgorin bounds = exact diagonal values
    ! with 10% margin
    @assertTrue(emin < 1.0_dp)
    @assertTrue(emax > 10.0_dp)

    call csr_free(H)
  end subroutine test_energy_window_gershgorin

  ! ==================================================================
  ! Test 9: feast_workspace caches upper-triangle structure.
  ! ==================================================================
  @test
  subroutine test_feast_workspace_cached_matches_uncached()
    ! Solve the same eigenvalue problem with and without workspace.
    ! Eigenvalues must be identical.
    integer, parameter :: n = 20
    real(kind=dp) :: diag(n)
    type(csr_matrix) :: H
    type(eigensolver_config) :: cfg
    type(eigensolver_result) :: res1, res2
    type(feast_workspace) :: fw
    integer :: i, min_nev

    do i = 1, n
      diag(i) = real(i, kind=dp)
    end do
    call build_diagonal_csr(diag, n, H)

    cfg%method = 'FEAST'
    cfg%emin = 0.5_dp
    cfg%emax = 5.5_dp
    cfg%nev = 5

    ! Solve without workspace
    call solve_feast(H, cfg, res1)

    ! Solve with workspace (first call = slow path, initializes cache)
    call solve_feast(H, cfg, res2, fw)
    @assertTrue(fw%initialized)
    @assertEqual(res1%nev_found, res2%nev_found)
    min_nev = min(res1%nev_found, res2%nev_found)
    do i = 1, min_nev
      @assertEqual(res1%eigenvalues(i), res2%eigenvalues(i), tolerance=1.0e-12_dp)
    end do
    call eigensolver_result_free(res1)
    call eigensolver_result_free(res2)

    ! Solve again with cached workspace (tests fast path)
    call solve_feast(H, cfg, res2, fw)
    @assertTrue(fw%initialized)
    call solve_feast(H, cfg, res1)
    @assertEqual(res1%nev_found, res2%nev_found)
    min_nev = min(res1%nev_found, res2%nev_found)
    do i = 1, min_nev
      @assertEqual(res1%eigenvalues(i), res2%eigenvalues(i), tolerance=1.0e-12_dp)
    end do

    call eigensolver_result_free(res1)
    call eigensolver_result_free(res2)
    call feast_workspace_free(fw)
    @assertFalse(fw%initialized)
    call csr_free(H)
  end subroutine test_feast_workspace_cached_matches_uncached

  ! ==================================================================
  ! Test 10: FEAST workspace rebuilds on sparsity pattern change.
  !
  ! Initializes cache with diagonal upper-triangle structure (N nonzeros),
  ! then reuses workspace on same-size tridiagonal matrix with different
  ! sparsity (2N-1 upper-triangle nonzeros).  The fast path at line 148 of
  ! eigensolver.f90 only checks dimensions (N, M0) but NOT the sparsity
  ! pattern (rowptr_loc, colind_loc).  This test catches that bug: cached
  ! colind_loc has wrong entries and wrong count, producing wrong
  ! eigenvalues or a crash.
  ! ==================================================================
  @test
  subroutine test_feast_workspace_rebuilds_on_pattern_change()
    integer, parameter :: n = 20
    real(kind=dp) :: diag(n)
    type(csr_matrix) :: H_diag, H_tri
    type(eigensolver_config) :: cfg
    type(eigensolver_result) :: cached, uncached
    type(feast_workspace) :: fw
    integer :: i, min_nev

    do i = 1, n
      diag(i) = real(i, kind=dp)
    end do
    call build_diagonal_csr(diag, n, H_diag)

    ! Tridiagonal with diagonal=3.0, off-diagonal=-0.1.  Eigenvalues cluster
    ! around 3.0 +/- 0.2*cos(k*pi/(n+1)) ~ 2.8..3.2.  Use a narrow window
    ! [2.82, 2.85] so only 1-2 eigenvalues fall inside, avoiding FEAST info=3
    ! (subspace too small) when all 20 eigenvalues sit in a wider window.
    call build_tridiag_csr(3.0_dp, -0.1_dp, n, H_tri)

    cfg%method = 'FEAST'
    cfg%emin = 2.82_dp
    cfg%emax = 2.85_dp
    cfg%nev = 3
    cfg%m0 = 8

    ! Initialize cache with diagonal upper-triangle structure.
    call solve_feast(H_diag, cfg, cached, fw)
    call eigensolver_result_free(cached)
    @assertTrue(fw%initialized)

    ! Reuse same workspace on same-size but different sparsity matrix.
    call solve_feast(H_tri, cfg, cached, fw)
    call solve_feast(H_tri, cfg, uncached)

    @assertEqual(uncached%nev_found, cached%nev_found)
    min_nev = min(uncached%nev_found, cached%nev_found)
    do i = 1, min_nev
      @assertEqual(uncached%eigenvalues(i), cached%eigenvalues(i), tolerance=1.0e-10_dp)
    end do

    call eigensolver_result_free(cached)
    call eigensolver_result_free(uncached)
    call feast_workspace_free(fw)
    call csr_free(H_diag)
    call csr_free(H_tri)
  end subroutine test_feast_workspace_rebuilds_on_pattern_change

  ! ==================================================================
  ! Test 11: FEAST solver with ENERGY mode on CSR tridiagonal.
  ! Uses polymorphic dispatch through feast_solver_t%solve_sparse.
  ! ==================================================================
  @test
  subroutine test_feast_energy_mode()
    integer, parameter :: n = 20
    real(kind=dp) :: diag(n)
    type(csr_matrix) :: H
    type(eigensolver_config) :: cfg
    type(eigensolver_result) :: res
    class(eigensolver_base), allocatable :: solver
    integer :: i

    do i = 1, n
      diag(i) = real(i, kind=dp)
    end do
    call build_diagonal_csr(diag, n, H)

    cfg%method = 'FEAST'
    cfg%mode = EIGEN_MODE_ENERGY
    cfg%emin = 0.5_dp
    cfg%emax = 5.5_dp
    cfg%nev = 5

    solver = make_eigensolver(cfg)
    call solver%solve_sparse(H, cfg, res)

    @assertTrue(res%converged)
    @assertEqual(5, res%nev_found)

    ! Eigenvalues in [0.5, 5.5] are 1, 2, 3, 4, 5
    do i = 1, res%nev_found
      @assertEqual(real(i, kind=dp), res%eigenvalues(i), tolerance=1.0e-8_dp)
    end do

    call eigensolver_result_free(res)
    call csr_free(H)
  end subroutine test_feast_energy_mode

  ! ==================================================================
  ! Test 12: FEAST solver with FULL mode (Gershgorin-bounded window).
  ! Verifies all eigenvalues are found for a small diagonal matrix.
  ! ==================================================================
  @test
  subroutine test_feast_full_mode()
    integer, parameter :: n = 10
    real(kind=dp) :: diag(n)
    type(csr_matrix) :: H
    type(eigensolver_config) :: cfg
    type(eigensolver_result) :: res
    class(eigensolver_base), allocatable :: solver
    integer :: i

    do i = 1, n
      diag(i) = real(i, kind=dp)
    end do
    call build_diagonal_csr(diag, n, H)

    cfg%method = 'FEAST'
    cfg%mode = EIGEN_MODE_FULL
    cfg%nev = 10
    cfg%m0 = 12

    solver = make_eigensolver(cfg)
    call solver%solve_sparse(H, cfg, res)

    @assertTrue(res%converged)
    @assertEqual(10, res%nev_found)

    ! All eigenvalues 1..10 should be present (sorted ascending)
    do i = 1, res%nev_found
      @assertEqual(real(i, kind=dp), res%eigenvalues(i), tolerance=1.0e-8_dp)
    end do

    call eigensolver_result_free(res)
    call csr_free(H)
  end subroutine test_feast_full_mode

  ! ==================================================================
  ! Test 13: Dense LAPACK solver with mode dispatch.
  ! Tests all three modes (FULL, INDEX, ENERGY) on a tridiagonal matrix.
  ! ==================================================================
  @test
  subroutine test_dense_mode_dispatch()
    integer, parameter :: n = 20
    real(kind=dp), parameter :: grid_dx = 1.0_dp
    real(kind=dp), parameter :: pi = pi_dp
    type(csr_matrix) :: Hmat
    type(eigensolver_config) :: cfg
    type(eigensolver_result) :: res
    class(eigensolver_base), allocatable :: solver
    real(kind=dp) :: expected
    integer :: k

    call build_tridiag_csr(2.0_dp/grid_dx**2, -1.0_dp/grid_dx**2, n, Hmat)

    ! --- FULL mode: all eigenvalues ---
    cfg%method = 'DENSE'
    cfg%mode = EIGEN_MODE_FULL
    cfg%nev = n

    solver = make_eigensolver(cfg)
    call solver%solve_sparse(Hmat, cfg, res)

    @assertTrue(res%converged)
    @assertEqual(n, res%nev_found)
    ! First eigenvalue should match analytical Laplacian
    expected = 2.0_dp * (1.0_dp - cos(1.0_dp * pi / real(n+1, kind=dp))) / grid_dx**2
    @assertEqual(expected, res%eigenvalues(1), tolerance=1.0e-6_dp)

    call eigensolver_result_free(res)

    ! --- INDEX mode: first 3 eigenvalues ---
    cfg%mode = EIGEN_MODE_INDEX
    cfg%il = 1
    cfg%iu = 3

    solver = make_eigensolver(cfg)
    call solver%solve_sparse(Hmat, cfg, res)

    @assertTrue(res%converged)
    @assertEqual(3, res%nev_found)
    do k = 1, 3
      expected = 2.0_dp * (1.0_dp - cos(real(k, kind=dp) * pi / real(n+1, kind=dp))) / grid_dx**2
      @assertEqual(expected, res%eigenvalues(k), tolerance=1.0e-6_dp)
    end do

    call eigensolver_result_free(res)

    ! --- ENERGY mode: eigenvalues in range ---
    cfg%mode = EIGEN_MODE_ENERGY
    cfg%emin = 0.01_dp
    cfg%emax = 0.25_dp

    solver = make_eigensolver(cfg)
    call solver%solve_sparse(Hmat, cfg, res)

    @assertTrue(res%converged)
    @assertTrue(res%nev_found >= 2)
    ! First eigenvalue should still match analytical
    expected = 2.0_dp * (1.0_dp - cos(1.0_dp * pi / real(n+1, kind=dp))) / grid_dx**2
    @assertEqual(expected, res%eigenvalues(1), tolerance=1.0e-6_dp)

    call eigensolver_result_free(res)
    call csr_free(Hmat)
  end subroutine test_dense_mode_dispatch

  ! ==================================================================
  ! Test 14: eigensolver_config_validate accepts valid combinations.
  ! ==================================================================
  @test
  subroutine test_config_validate_valid()
    type(eigensolver_config) :: cfg

    ! DENSE + FULL
    cfg%method = 'DENSE'
    cfg%mode = EIGEN_MODE_FULL
    call eigensolver_config_validate(cfg)

    ! DENSE + INDEX
    cfg%method = 'DENSE'
    cfg%mode = EIGEN_MODE_INDEX
    cfg%il = 1; cfg%iu = 4
    call eigensolver_config_validate(cfg)

    ! DENSE + ENERGY
    cfg%method = 'DENSE'
    cfg%mode = EIGEN_MODE_ENERGY
    cfg%emin = -1.5_dp; cfg%emax = 2.0_dp
    call eigensolver_config_validate(cfg)

    ! FEAST + ENERGY
    cfg%method = 'FEAST'
    cfg%mode = EIGEN_MODE_ENERGY
    cfg%emin = -1.5_dp; cfg%emax = 2.0_dp
    call eigensolver_config_validate(cfg)

    ! FEAST + FULL
    cfg%method = 'FEAST'
    cfg%mode = EIGEN_MODE_FULL
    call eigensolver_config_validate(cfg)

    @assertTrue(.true., message="All valid config combos pass validation")
  end subroutine test_config_validate_valid

  ! ==================================================================
  ! (Removed) Tests 15-17 previously asserted the rejection *condition*
  ! (e.g. @assertTrue(method=='FEAST' .and. mode==INDEX)) without ever
  ! calling eigensolver_config_validate, so they passed vacuously and
  ! guarded nothing. Acceptance of valid combos is covered by
  ! test_config_validate_valid above; rejection (FEAST+INDEX, emin>=emax,
  ! bad il/iu) is covered by integration test V13
  ! (tests/integration/test_validate_rejects_bad_configs.sh), which
  ! exercises the real error-stop branches via exit-code checks.
  ! ==================================================================

  ! ==================================================================
  ! Test 18: Dense LAPACK solve via polymorphic dispatch.
  ! ==================================================================
  @test
  subroutine test_dense_polymorphic_dispatch()
    integer, parameter :: n = 10
    real(kind=dp) :: diag(n)
    type(csr_matrix) :: H
    type(eigensolver_config) :: cfg
    type(eigensolver_result) :: res
    class(eigensolver_base), allocatable :: solver
    integer :: i

    do i = 1, n
      diag(i) = real(i, kind=dp)
    end do
    call build_diagonal_csr(diag, n, H)

    cfg%method = 'DENSE'
    cfg%mode = EIGEN_MODE_FULL
    cfg%nev = n

    solver = make_eigensolver(cfg)
    call solver%solve_sparse(H, cfg, res)

    @assertTrue(res%converged)
    @assertEqual(n, res%nev_found)

    ! Eigenvalues should be 1..10
    do i = 1, res%nev_found
      @assertEqual(real(i, kind=dp), res%eigenvalues(i), tolerance=1.0e-8_dp)
    end do

    call eigensolver_result_free(res)
    call csr_free(H)
  end subroutine test_dense_polymorphic_dispatch

  ! ==================================================================
  ! Test: eigensolve_csr helper dispatches through the polymorphic
  ! solver and returns correct eigenvalues (INDEX path, emin=emax=0).
  ! ==================================================================
  @test
  subroutine test_eigensolve_csr_helper()
    integer, parameter :: n = 20
    real(kind=dp), parameter :: pi = pi_dp
    type(csr_matrix) :: Hmat
    type(eigensolver_config) :: cfg
    type(eigensolver_result) :: res
    real(kind=dp) :: expected
    integer :: k

    call build_tridiag_csr(2.0_dp, -1.0_dp, n, Hmat)

    cfg%method = 'DENSE'
    cfg%emin = 0.0_dp
    cfg%emax = 0.0_dp
    cfg%nev = 3

    call eigensolve_csr(Hmat, cfg, res)

    @assertTrue(res%converged)
    @assertEqual(3, res%nev_found)
    do k = 1, 3
      expected = 2.0_dp * (1.0_dp - cos(real(k, kind=dp) * pi / real(n+1, kind=dp)))
      @assertEqual(expected, res%eigenvalues(k), tolerance=1.0e-6_dp)
    end do

    call eigensolver_result_free(res)
    call csr_free(Hmat)
  end subroutine test_eigensolve_csr_helper

  ! ==================================================================
  ! Test: a dense solver reused across calls returns identical, correct
  ! eigenvalues — verifies workspace caching does not corrupt results,
  ! including the realloc path when N grows.
  ! ==================================================================
  @test
  subroutine test_dense_solver_caches_workspace()
    integer :: n
    type(csr_matrix) :: H
    type(eigensolver_config) :: cfg
    type(eigensolver_result) :: res1, res2, res3
    class(eigensolver_base), allocatable :: solver
    real(kind=dp) :: expected

    cfg%method = 'DENSE'
    cfg%mode = EIGEN_MODE_INDEX
    cfg%il = 1
    cfg%iu = 1
    solver = make_eigensolver(cfg)

    ! First call: N = 20
    n = 20
    call build_tridiag_csr(2.0_dp, -1.0_dp, n, H)
    call solver%solve_sparse(H, cfg, res1)
    @assertTrue(res1%converged)
    expected = 2.0_dp * (1.0_dp - cos(pi_dp / real(n+1, kind=dp)))
    @assertEqual(expected, res1%eigenvalues(1), tolerance=1.0e-6_dp)
    call eigensolver_result_free(res1)

    ! Second call: same N — cached path, must match
    call solver%solve_sparse(H, cfg, res2)
    @assertTrue(res2%converged)
    @assertEqual(expected, res2%eigenvalues(1), tolerance=1.0e-6_dp)
    call eigensolver_result_free(res2)
    call csr_free(H)

    ! Third call: larger N — realloc path, must still be correct
    n = 30
    call build_tridiag_csr(2.0_dp, -1.0_dp, n, H)
    call solver%solve_sparse(H, cfg, res3)
    @assertTrue(res3%converged)
    expected = 2.0_dp * (1.0_dp - cos(pi_dp / real(n+1, kind=dp)))
    @assertEqual(expected, res3%eigenvalues(1), tolerance=1.0e-6_dp)
    call eigensolver_result_free(res3)
    call csr_free(H)
    deallocate(solver)
  end subroutine test_dense_solver_caches_workspace

  ! ==================================================================
  ! resolve_solver_defaults: contract table.
  !
  ! Expects the resolved (out_method, out_mode) for each
  ! (confinement, method, mode) triple, per the AUTO contract
  ! (CONTEXT.md): method resolves first (confinement default unless
  ! overridden); mode then resolves method-aware (FEAST->ENERGY,
  ! DENSE->confinement native: bulk FULL, qw/landau INDEX, wire ENERGY).
  !
  ! Returns .false. if a triple has no contract entry (should never happen).
  ! ==================================================================
  function resolve_expected(confinement, method, mode, out_method, out_mode) result(ok)
    character(len=*), intent(in)  :: confinement, method, mode
    character(len=*), intent(out) :: out_method, out_mode
    logical :: ok
    character(len=:), allocatable :: rmeth   ! resolved method (uppercase)

    ok = .true.
    out_method = ''
    out_mode = ''

    ! --- Resolve METHOD first (confinement default unless overridden) ---
    select case (trim(adjustl(upper(method))))
    case ('AUTO')
      select case (trim(adjustl(upper(confinement))))
      case ('BULK', 'QW', 'LANDAU')
        rmeth = 'DENSE'
      case ('WIRE')
        rmeth = 'FEAST'
      case default
        ok = .false.; return
      end select
    case ('DENSE', 'FEAST')
      rmeth = trim(adjustl(upper(method)))
    case default
      ok = .false.; return
    end select

    ! --- Resolve MODE method-aware ---
    select case (trim(adjustl(upper(mode))))
    case ('AUTO')
      select case (rmeth)
      case ('FEAST')
        out_mode = 'ENERGY'
      case ('DENSE')
        select case (trim(adjustl(upper(confinement))))
        case ('BULK')
          out_mode = 'FULL'
        case ('QW', 'LANDAU')
          out_mode = 'INDEX'
        case ('WIRE')
          out_mode = 'ENERGY'
        case default
          ok = .false.; return
        end select
      end select
    case ('FULL', 'INDEX', 'ENERGY')
      out_mode = trim(adjustl(upper(mode)))
    case default
      ok = .false.; return
    end select

    out_method = rmeth
  end function resolve_expected

  ! Uppercase a short ASCII string (independent oracle; does not call
  ! the resolver's own to_upper_trim, so the test is a genuine cross-check).
  pure function upper(s) result(u)
    character(len=*), intent(in) :: s
    character(len=len(s)) :: u
    integer :: i, c
    u = s
    do i = 1, len(s)
      c = iachar(s(i:i))
      if (c >= iachar('a') .and. c <= iachar('z')) then
        u(i:i) = achar(c - 32)
      end if
    end do
  end function upper

  ! ==================================================================
  ! Test: table-driven contract for resolve_solver_defaults across
  ! every confinement x method x mode combination.
  ! ==================================================================
  @test
  subroutine test_resolve_solver_defaults_table()
    character(len=8),  parameter :: confinements(4) = ['bulk   ', 'qw     ', 'wire   ', 'landau ']
    character(len=8),  parameter :: methods(3)      = ['AUTO   ', 'DENSE  ', 'FEAST  ']
    character(len=8),  parameter :: modes(4)        = ['AUTO   ', 'FULL   ', 'INDEX  ', 'ENERGY ']
    character(len=10) :: out_method, out_mode
    character(len=10) :: exp_method, exp_mode
    character(len=48) :: combo
    integer :: ic, im, imo, n
    logical :: ok

    n = 0
    do ic = 1, size(confinements)
      do im = 1, size(methods)
        do imo = 1, size(modes)
          n = n + 1
          call resolve_solver_defaults(confinements(ic), methods(im), modes(imo), &
                                       out_method, out_mode)
          ok = resolve_expected(confinements(ic), methods(im), modes(imo), &
                                exp_method, exp_mode)
          write(combo, '(A,1x,A,1x,A,1x,A)') 'conf=', trim(confinements(ic)), &
                                             'm='//trim(methods(im)), 'mo='//trim(modes(imo))
          @assertTrue(ok, message=trim(combo))
          @assertEqual(trim(exp_method), trim(out_method), message=trim(combo))
          @assertEqual(trim(exp_mode), trim(out_mode), message=trim(combo))
        end do
      end do
    end do
    @assertEqual(NRESOLVE_COMBOS, n)
  end subroutine test_resolve_solver_defaults_table

  ! ==================================================================
  ! Test: INVARIANT — AUTO mode never resolves to ('FEAST','INDEX').
  ! (Explicit FEAST+INDEX set by the caller is the caller/validate's
  ! responsibility to reject; the resolver faithfully honors it. This
  ! test only checks the AUTO-mode branch.)
  ! ==================================================================
  @test
  subroutine test_resolve_solver_defaults_no_feast_index_via_auto()
    character(len=8),  parameter :: confinements(4) = ['bulk   ', 'qw     ', 'wire   ', 'landau ']
    character(len=8),  parameter :: methods(3)      = ['AUTO   ', 'DENSE  ', 'FEAST  ']
    character(len=8),  parameter :: auto_mode(1)    = ['AUTO   ']
    character(len=10) :: out_method, out_mode
    integer :: ic, im

    do ic = 1, size(confinements)
      do im = 1, size(methods)
        call resolve_solver_defaults(confinements(ic), methods(im), auto_mode(1), &
                                     out_method, out_mode)
        ! The invariant: AUTO mode must never yield FEAST+INDEX.
        if (trim(out_method) == 'FEAST') then
          @assertTrue(trim(out_mode) /= 'INDEX', message="AUTO must not yield FEAST+INDEX")
        end if
      end do
    end do
  end subroutine test_resolve_solver_defaults_no_feast_index_via_auto

  ! ==================================================================
  ! Test: idempotency / uppercasing — resolve_solver_defaults must
  ! normalize whitespace and case so a caller passing lowercase or
  ! padded input gets the canonical uppercase output.
  ! ==================================================================
  @test
  subroutine test_resolve_solver_defaults_normalizes_case()
    character(len=10) :: out_method, out_mode

    call resolve_solver_defaults('bulk', 'auto', 'auto', out_method, out_mode)
    @assertEqual('DENSE', trim(out_method))
    @assertEqual('FULL',  trim(out_mode))

    call resolve_solver_defaults('WIRE', 'AUTO', 'auto', out_method, out_mode)
    @assertEqual('FEAST',  trim(out_method))
    @assertEqual('ENERGY', trim(out_mode))
  end subroutine test_resolve_solver_defaults_normalizes_case

  ! ==================================================================
  ! Test: backend_name() returns the resolved backend string for each
  ! concrete solver type. This is the contract that backend-aware
  ! diagnostics in the apps rely on: a failure forced on dense LAPACK
  ! must report "dense LAPACK", and one on FEAST must report "FEAST".
  ! ==================================================================
  ! COVERAGE: observable=backend_name geometry=generic material=generic
  @test
  subroutine test_backend_name_dense()
    type(eigensolver_config) :: cfg
    class(eigensolver_base), allocatable :: solver

    cfg%method = 'DENSE'
    cfg%mode = EIGEN_MODE_FULL
    solver = make_eigensolver(cfg)

    @assertEqual('dense LAPACK', trim(solver%backend_name()))
    deallocate(solver)
  end subroutine test_backend_name_dense

  @test
  subroutine test_backend_name_feast()
    type(eigensolver_config) :: cfg
    class(eigensolver_base), allocatable :: solver

    cfg%method = 'FEAST'
    cfg%mode = EIGEN_MODE_ENERGY
    cfg%emin = -1.0_dp
    cfg%emax = 1.0_dp
    solver = make_eigensolver(cfg)

    @assertEqual('FEAST', trim(solver%backend_name()))
    deallocate(solver)
  end subroutine test_backend_name_feast

end module test_eigensolver
