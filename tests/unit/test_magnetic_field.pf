module test_magnetic_field
  use funit
  use definitions
  use magnetic_field
  use sparse_matrices
  use geometry
  implicit none

contains

  @test
  subroutine test_zeeman_single_grid_point()
    real(kind=dp), allocatable :: coo_vals(:)
    integer, allocatable :: coo_row(:), coo_col(:)
    type(spatial_grid) :: grid
    integer :: nnz_offset, i
    integer, parameter :: nx = 1, ny = 1
    integer :: mat2d(nx, ny)

    ! Single grid point
    mat2d = 1
    call grid_init_rect(grid, nx, ny, 1.0_dp, 1.0_dp, mat2d)
    allocate(coo_vals(8), coo_row(8), coo_col(8))
    nnz_offset = 0

    ! B = [0, 0, 1.0] T, g_factor = 2.0
    call add_zeeman_coo(coo_vals, coo_row, coo_col, nnz_offset, &
                         grid, [0.0_dp, 0.0_dp, 1.0_dp], g_factor=2.0_dp, coo_capacity=8)

    @assertEqual(8, nnz_offset)
    ! All diagonal entries
    @assertTrue(all(coo_row(1:8) == coo_col(1:8)))
    ! Verify each band gets the correct Zeeman shift
    ! mu_B = 5.7883818012e-5 eV/T (CODATA)
    ! Basis: HH↑, LH↑, LH↓, HH↓, SO↑, SO↓, CB↓, CB↑ (Winkler ordering)
    ! Kramers partners split with opposite signs
    ! Band 1 (HH  mJ=+3/2): -3/2 * g*mu_B*B
    @assertEqual(-1.5_dp * 2.0_dp * mu_B, coo_vals(1), tolerance=1e-12_dp)
    ! Band 2 (LH  mJ=+1/2): +1/2 * g*mu_B*B
    @assertEqual( 0.5_dp * 2.0_dp * mu_B, coo_vals(2), tolerance=1e-12_dp)
    ! Band 3 (LH  mJ=-1/2): -1/2 * g*mu_B*B
    @assertEqual(-0.5_dp * 2.0_dp * mu_B, coo_vals(3), tolerance=1e-12_dp)
    ! Band 4 (HH  mJ=-3/2): +3/2 * g*mu_B*B
    @assertEqual( 1.5_dp * 2.0_dp * mu_B, coo_vals(4), tolerance=1e-12_dp)
    ! Band 5 (SO  mJ=+1/2): -1/2 * g*mu_B*B
    @assertEqual(-0.5_dp * 2.0_dp * mu_B, coo_vals(5), tolerance=1e-12_dp)
    ! Band 6 (SO  mJ=-1/2): +1/2 * g*mu_B*B
    @assertEqual( 0.5_dp * 2.0_dp * mu_B, coo_vals(6), tolerance=1e-12_dp)
    ! Band 7 (CB↓ mJ=-1/2): -g*mu_B*B
    @assertEqual(-1.0_dp * 2.0_dp * mu_B, coo_vals(7), tolerance=1e-12_dp)
    ! Band 8 (CB↑ mJ=+1/2): +g*mu_B*B
    @assertEqual( 1.0_dp * 2.0_dp * mu_B, coo_vals(8), tolerance=1e-12_dp)
    deallocate(coo_vals, coo_row, coo_col)
    call grid_free(grid)
  end subroutine

  @test
  subroutine test_peierls_phase_value()
    ! Test that Peierls phase is correctly computed
    ! B = 5T, y_i = 1nm, y_j = 0, dz = 1nm -> |phi| ≈ 0.76 rad
    real(kind=dp), parameter :: B_test = 5.0_dp ! Tesla
    real(kind=dp), parameter :: y_nm = 1.0_dp  ! nm
    real(kind=dp), parameter :: dz_nm = 1.0_dp ! nm

    real(kind=dp) :: y_i_m, y_j_m, dz_m, phi_direct

    ! Convert to SI: nm -> m
    y_i_m = y_nm * 1.0e-9_dp
    y_j_m = 0.0_dp
    dz_m = dz_nm * 1.0e-9_dp

    ! Compute phase: phi = e * B * (y_i - y_j) * dz / hbar_J
    ! hbar_J = hbar * e converts hbar from eV*s to J*s for SI units
    phi_direct = e * B_test * (y_i_m - y_j_m) * dz_m / (hbar * e)

    ! Phase should be a valid number and non-zero
    ! For B=5T, y=1nm, dz=1nm: phi ≈ 0.0076 rad (with SI unit conversion)
    @assertTrue(abs(phi_direct) > 0.005_dp)
    @assertTrue(abs(phi_direct) < 0.1_dp)
  end subroutine

  @test
  subroutine test_peierls_coo_off_diagonal()
    ! Test add_peierls_coo applies full complex phase to off-diagonal entries
    complex(kind=dp), allocatable :: coo_vals(:)
    integer, allocatable :: coo_row(:), coo_col(:)
    type(spatial_grid) :: grid
    integer :: nnz_offset, idx
    integer, parameter :: nx = 1, ny = 2
    integer :: mat2d(nx, ny)
    real(kind=dp) :: y_i_m, y_j_m, dz_m, phi_expected
    complex(kind=dp) :: exp_phase_expected

    ! 2 grid points in y-direction for distinct y-coordinates
    mat2d = 1
    call grid_init_rect(grid, nx, ny, 1.0_dp, 1.0_dp, mat2d)

    ! Set up COO with band-major indexing: row = (band-1)*ngrid + site
    ! ngrid = 2 grid points: site 1 -> row offset 1, site 2 -> row offset 2
    ! band 1, site 1 -> row 1;  band 1, site 2 -> row 2
    ! band 2, site 1 -> row 3;  band 2, site 2 -> row 4
    ! - Two diagonal entries (rows 1, 2) - should NOT be modified
    ! - One off-diagonal hopping (row 1, col 2) - should get phase factor
    allocate(coo_vals(3), coo_row(3), coo_col(3))
    nnz_offset = 0

    ! Diagonal entry at row 1 (band 1, site 1)
    nnz_offset = nnz_offset + 1
    coo_row(nnz_offset) = 1
    coo_col(nnz_offset) = 1
    coo_vals(nnz_offset) = cmplx(1.0_dp, 0.0_dp, kind=dp)

    ! Off-diagonal entry: row 1 (band 1, site 1) to col 2 (band 1, site 2)
    ! grid pt 1: y(1) = 0.5 Angstrom
    ! grid pt 2: y(2) = 1.5 Angstrom
    nnz_offset = nnz_offset + 1
    coo_row(nnz_offset) = 1
    coo_col(nnz_offset) = 2
    coo_vals(nnz_offset) = cmplx(0.5_dp, 0.0_dp, kind=dp)

    ! Another diagonal entry at row 2 (band 1, site 2)
    nnz_offset = nnz_offset + 1
    coo_row(nnz_offset) = 2
    coo_col(nnz_offset) = 2
    coo_vals(nnz_offset) = cmplx(2.0_dp, 0.0_dp, kind=dp)

    ! Apply Peierls phase with Bx = 5 Tesla
    ! y(1) = 0.5 Angstrom = 0.5e-10 m
    ! y(2) = 1.5 Angstrom = 1.5e-10 m
    ! dz = grid%dy = 1.0 Angstrom = 1e-10 m
    y_i_m = grid%z(1) * 1.0e-10_dp  ! y of grid pt 1 in meters
    y_j_m = grid%z(2) * 1.0e-10_dp  ! y of grid pt 2 in meters
    dz_m = grid%dy * 1.0e-10_dp     ! dz in meters

    call add_peierls_coo(coo_vals, coo_row, coo_col, nnz_offset, &
                         grid, [5.0_dp, 0.0_dp, 0.0_dp])

    ! Diagonal entries (row == col) should NOT be modified
    @assertEqual(cmplx(1.0_dp, 0.0_dp, kind=dp), coo_vals(1), tolerance=1e-12_dp)
    @assertEqual(cmplx(2.0_dp, 0.0_dp, kind=dp), coo_vals(3), tolerance=1e-12_dp)

    ! Off-diagonal entry: compute expected complex phase and verify
    ! hbar_J = hbar * e for SI unit conversion
    phi_expected = e * 5.0_dp * (y_i_m - y_j_m) * dz_m / (hbar * e)
    exp_phase_expected = cmplx(cos(phi_expected), -sin(phi_expected), kind=dp)

    ! The off-diagonal value should be 0.5 * exp(-i*phi)
    @assertEqual(0.5_dp * exp_phase_expected, coo_vals(2), tolerance=1e-10_dp)

    deallocate(coo_vals, coo_row, coo_col)
    call grid_free(grid)
  end subroutine

  @test
  subroutine test_zeeman_zero_field()
    ! All Zeeman entries should be zero at B=0
    real(kind=dp), allocatable :: coo_vals(:)
    integer, allocatable :: coo_row(:), coo_col(:)
    type(spatial_grid) :: grid
    integer :: nnz_offset, i
    integer, parameter :: nx = 1, ny = 1
    integer :: mat2d(nx, ny)

    ! Single grid point
    mat2d = 1
    call grid_init_rect(grid, nx, ny, 1.0_dp, 1.0_dp, mat2d)
    allocate(coo_vals(8), coo_row(8), coo_col(8))
    nnz_offset = 0

    ! B = [0, 0, 0] — no magnetic field
    call add_zeeman_coo(coo_vals, coo_row, coo_col, nnz_offset, &
                         grid, [0.0_dp, 0.0_dp, 0.0_dp], g_factor=2.0_dp, coo_capacity=8)

    @assertEqual(8, nnz_offset)
    ! All diagonal entries should be exactly zero when B=0
    do i = 1, 8
      @assertEqual(0.0_dp, coo_vals(i), tolerance=1.0e-30_dp)
    end do

    deallocate(coo_vals, coo_row, coo_col)
    call grid_free(grid)
  end subroutine

  @test
  subroutine test_zeeman_splitting_magnitude()
    ! Zeeman splitting for g=2, B=1T should be g*mu_B*B
    real(kind=dp) :: Vz(8), expected_cb_split
    real(kind=dp), parameter :: g_f = 2.0_dp
    real(kind=dp), parameter :: B_mag = 1.0_dp

    call compute_zeeman_vz(g_f, mu_B, B_mag, Vz)

    ! CB splitting: band 7 = -g*mu_B*B, band 8 = +g*mu_B*B
    expected_cb_split = g_f * mu_B * B_mag

    @assertEqual(-expected_cb_split, Vz(7), tolerance=1.0e-10_dp, message="CB band 7 Zeeman should be -g*mu_B*B")
    @assertEqual(+expected_cb_split, Vz(8), tolerance=1.0e-10_dp, message="CB band 8 Zeeman should be +g*mu_B*B")
  end subroutine test_zeeman_splitting_magnitude

  @test
  subroutine test_peierls_zero_Bx()
    ! When Bx=0, Peierls phase should be zero (no modification)
    type(csr_matrix) :: H_csr
    type(spatial_grid) :: grid
    complex(kind=dp), allocatable :: coo_vals(:)
    integer, allocatable :: coo_row(:), coo_col(:)
    integer :: nnz_offset, coo_capacity

    ! Build minimal 2x2 CSR
    call build_diagonal_csr_2x2_grid(H_csr, grid, [1.0_dp, 2.0_dp])

    coo_capacity = 100
    allocate(coo_vals(coo_capacity), coo_row(coo_capacity), coo_col(coo_capacity))
    coo_vals = cmplx(0.0_dp, 0.0_dp, kind=dp)
    coo_row = 0
    coo_col = 0
    nnz_offset = 0

    ! Peierls with B=(0,0,0) should be no-op
    call add_peierls_coo(coo_vals, coo_row, coo_col, nnz_offset, grid, [0.0_dp, 0.0_dp, 0.0_dp])

    @assertEqual(0, nnz_offset, message="Peierls should add no entries at B=0")

    call csr_free(H_csr)
    deallocate(grid%z)
    deallocate(coo_vals, coo_row, coo_col)
  end subroutine test_peierls_zero_Bx

  @test
  subroutine test_gauge_shifts_linearity()
    ! Pi_y should scale linearly with x for nonzero Bz
    real(kind=dp) :: x_grid(5), Pi_y(5), Pi_z(5)
    real(kind=dp) :: B_vec(3), ky, kz
    real(kind=dp) :: dPi_y_dx
    integer :: i

    x_grid = [10.0_dp, 20.0_dp, 30.0_dp, 40.0_dp, 50.0_dp]
    B_vec = [0.0_dp, 0.0_dp, 5.0_dp]
    ky = 0.01_dp
    kz = 0.0_dp

    call compute_gauge_shifts(x_grid, B_vec, ky, kz, Pi_y, Pi_z)

    ! Pi_y should be linear: dPi_y/dx = Bz/hbar (in appropriate units)
    do i = 1, 3
      dPi_y_dx = (Pi_y(i+1) - Pi_y(i)) / (x_grid(i+1) - x_grid(i))
      @assertTrue(dPi_y_dx > 0.0_dp, message="Pi_y should increase with x for Bz>0")
    end do
  end subroutine test_gauge_shifts_linearity

  ! Helper for Peierls test
  subroutine build_diagonal_csr_2x2_grid(H_csr, grid, diag_vals)
    type(csr_matrix), intent(out) :: H_csr
    type(spatial_grid), intent(out) :: grid
    real(kind=dp), intent(in) :: diag_vals(2)

    grid%ndim = 1
    grid%nx = 1
    grid%ny = 2
    grid%dx = 1.0_dp
    grid%dy = 1.0_dp
    allocate(grid%z(2))
    grid%z = [1.0_dp, 2.0_dp]

    H_csr%nrows = 2
    H_csr%nnz = 2
    allocate(H_csr%rowptr(3), H_csr%colind(2), H_csr%values(2))
    H_csr%rowptr = [1, 2, 3]
    H_csr%colind = [1, 2]
    H_csr%values = cmplx(diag_vals(1), 0.0_dp, kind=dp)
    H_csr%values(2) = cmplx(diag_vals(2), 0.0_dp, kind=dp)
  end subroutine build_diagonal_csr_2x2_grid

  @test
  subroutine test_peierls_y_axis_2d_wire()
    ! Verify add_peierls_coo uses grid%coords(2,:) for y-coordinates
    ! in 2D multi-column wires instead of flat-indexing grid%z.
    ! Bug: old code did grid%z(flat_index) which is out-of-bounds when
    ! grid%z has length ny but flat_index can be up to nx*ny.
    type(spatial_grid) :: grid
    complex(kind=dp), allocatable :: coo_vals(:)
    integer, allocatable :: coo_row(:), coo_col(:)
    real(kind=dp) :: B_vec(3)
    integer :: nnz, i
    real(kind=dp) :: y_expected_i, y_expected_j, phase_expected
    complex(kind=dp) :: val_expected
    real(kind=dp) :: hbar_J

    ! 2D wire: 3 columns x 5 rows
    grid%ndim = 2
    grid%nx = 3
    grid%ny = 5
    grid%dx = 2.0_dp
    grid%dy = 2.0_dp
    allocate(grid%z(5))
    grid%z = [1.0_dp, 2.0_dp, 3.0_dp, 4.0_dp, 5.0_dp]
    allocate(grid%coords(2, 15))
    ! coords(1,:) = x, coords(2,:) = y for each of 15 sites
    ! Column-major: ij = (iy-1)*nx + ix
    do i = 1, 15
      grid%coords(1, i) = grid%dx * real(mod(i-1, 3), kind=dp)
      grid%coords(2, i) = grid%z(mod(i-1, 5) + 1)
    end do

    ! One off-diagonal entry: site 1 (ix=2, iy=1, y=1.0) to site 8 (ix=2, iy=3, y=3.0)
    ! In band-major: row = (band-1)*ngrid + site, so band 1: row=1, row=8
    nnz = 1
    allocate(coo_vals(1), coo_row(1), coo_col(1))
    coo_row(1) = 1  ! band 1, site 1 -> grid point 1
    coo_col(1) = 8  ! band 1, site 8 -> grid point 8
    coo_vals(1) = cmplx(1.0_dp, 0.0_dp, kind=dp)

    B_vec = [1.0_dp, 0.0_dp, 0.0_dp]  ! Bx = 1 T

    call add_peierls_coo(coo_vals, coo_row, coo_col, nnz, grid, B_vec)

    ! Verify the phase was computed using correct y-coordinates
    ! Site 1 -> y = grid%coords(2, 1) = 1.0 AA
    ! Site 8 -> y = grid%coords(2, 8) = 3.0 AA  (NOT grid%z(8) which is out of bounds)
    ! Column-major flat_idx(3, ix=2, iy=3) = (3-1)*3 + 2 = 8
    ! coords(2, 8) = z(iy=3) = 3.0
    hbar_J = hbar * e
    y_expected_i = grid%coords(2, 1) * 1.0e-10_dp
    y_expected_j = grid%coords(2, 8) * 1.0e-10_dp
    phase_expected = e * 1.0_dp * (y_expected_i - y_expected_j) * (grid%dy * 1.0e-10_dp) / hbar_J
    val_expected = cmplx(cos(phase_expected), -sin(phase_expected), kind=dp)

    @assertEqual(real(val_expected), real(coo_vals(1)), tolerance=1.0e-12_dp)
    @assertEqual(aimag(val_expected), aimag(coo_vals(1)), tolerance=1.0e-12_dp)

    deallocate(grid%z, grid%coords, coo_vals, coo_row, coo_col)
  end subroutine test_peierls_y_axis_2d_wire

end module