module test_magnetic_field
  use funit
  use definitions
  use magnetic_field
  use sparse_matrices
  use geometry
  implicit none
contains

  @test
  subroutine test_zeeman_single_grid_point()
    real(kind=dp), allocatable :: coo_vals(:)
    integer, allocatable :: coo_row(:), coo_col(:)
    type(spatial_grid) :: grid
    integer :: nnz_offset, i
    integer, parameter :: nx = 1, ny = 1
    integer :: mat2d(nx, ny)

    ! Single grid point
    mat2d = 1
    call grid_init_rect(grid, nx, ny, 1.0_dp, 1.0_dp, mat2d)
    allocate(coo_vals(8), coo_row(8), coo_col(8))
    nnz_offset = 0

    ! B = [0, 0, 1.0] T, g_factor = 2.0
    call add_zeeman_coo(coo_vals, coo_row, coo_col, nnz_offset, &
                         grid, [0.0_dp, 0.0_dp, 1.0_dp], g_factor=2.0_dp)

    @assertEqual(8, nnz_offset)
    ! All diagonal entries
    @assertTrue(all(coo_row(1:8) == coo_col(1:8)))
    ! Verify each band gets the correct Zeeman shift
    ! mu_B = e*hbar/(2*m0) in eV/T ≈ 5.788e-5 eV/T
    ! HH bands (1,2): -1.5 * g*mu_B*B = -1.5 * 2 * 5.788e-5 * 1 = -1.7364e-4 eV
    @assertEqual(-1.5_dp * 2.0_dp * (e * hbar / (2.0_dp * m0)), coo_vals(1), tolerance=1e-12_dp)
    @assertEqual(-1.5_dp * 2.0_dp * (e * hbar / (2.0_dp * m0)), coo_vals(2), tolerance=1e-12_dp)
    ! LH bands (3,4): +0.5 * g*mu_B*B = +0.5 * 2 * 5.788e-5 * 1 = +5.788e-5 eV
    @assertEqual( 0.5_dp * 2.0_dp * (e * hbar / (2.0_dp * m0)), coo_vals(3), tolerance=1e-12_dp)
    @assertEqual( 0.5_dp * 2.0_dp * (e * hbar / (2.0_dp * m0)), coo_vals(4), tolerance=1e-12_dp)
    ! SO bands (5,6): -0.5 * g*mu_B*B = -0.5 * 2 * 5.788e-5 * 1 = -5.788e-5 eV
    @assertEqual(-0.5_dp * 2.0_dp * (e * hbar / (2.0_dp * m0)), coo_vals(5), tolerance=1e-12_dp)
    @assertEqual(-0.5_dp * 2.0_dp * (e * hbar / (2.0_dp * m0)), coo_vals(6), tolerance=1e-12_dp)
    ! CB band 7 (spin-down, J_z=-1/2): -g*mu_B*B = -2 * 5.788e-5 * 1 = -1.1576e-4 eV
    @assertEqual(-1.0_dp * 2.0_dp * (e * hbar / (2.0_dp * m0)), coo_vals(7), tolerance=1e-12_dp)
    ! CB band 8 (spin-up, J_z=+1/2): +g*mu_B*B = +2 * 5.788e-5 * 1 = +1.1576e-4 eV
    @assertEqual( 1.0_dp * 2.0_dp * (e * hbar / (2.0_dp * m0)), coo_vals(8), tolerance=1e-12_dp)
    deallocate(coo_vals, coo_row, coo_col)
    call grid_free(grid)
  end subroutine

end module
