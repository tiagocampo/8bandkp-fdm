module test_geometry
  use funit
  use definitions
  use geometry
  implicit none

contains

  ! ==================================================================
  ! Rectangle tests
  ! ==================================================================

  @test
  subroutine test_rect_all_active()
    type(spatial_grid) :: grid
    integer, parameter :: nx = 4, ny = 5
    real(kind=dp), parameter :: dx = 1.0_dp, dy = 2.0_dp
    integer :: mat2d(nx, ny)
    integer :: ix, iy, ij

    mat2d = 1
    call grid_init_rect(grid, nx, ny, dx, dy, mat2d)

    @assertEqual(2, grid%ndim)
    @assertEqual(nx, grid%nx)
    @assertEqual(ny, grid%ny)
    @assertTrue(allocated(grid%cell_volume))
    @assertTrue(allocated(grid%face_fraction_x))
    @assertTrue(allocated(grid%face_fraction_y))
    @assertTrue(allocated(grid%ghost_map))

    do iy = 1, ny
      do ix = 1, nx
        ij = (iy - 1) * nx + ix
        @assertEqual(1.0_dp, grid%cell_volume(ij), tolerance=1.0e-14_dp)
        @assertEqual(1.0_dp, grid%face_fraction_x(ij, 1), tolerance=1.0e-14_dp)
        @assertEqual(1.0_dp, grid%face_fraction_x(ij, 2), tolerance=1.0e-14_dp)
        @assertEqual(1.0_dp, grid%face_fraction_y(ij, 1), tolerance=1.0e-14_dp)
        @assertEqual(1.0_dp, grid%face_fraction_y(ij, 2), tolerance=1.0e-14_dp)
        @assertEqual(1, grid%material_id(ij))
      end do
    end do

    call grid_free(grid)
    @assertFalse(allocated(grid%cell_volume))
  end subroutine test_rect_all_active

  @test
  subroutine test_rect_material_id()
    type(spatial_grid) :: grid
    integer, parameter :: nx = 3, ny = 3
    integer :: mat2d(nx, ny)
    integer :: ij

    mat2d = reshape([1,1,1, 2,2,2, 3,3,3], [nx, ny])
    call grid_init_rect(grid, nx, ny, 1.0_dp, 1.0_dp, mat2d)

    ij = (1-1)*nx + 1
    @assertEqual(1, grid%material_id(ij))
    ij = (2-1)*nx + 1
    @assertEqual(2, grid%material_id(ij))
    ij = (3-1)*nx + 3
    @assertEqual(3, grid%material_id(ij))

    call grid_free(grid)
  end subroutine test_rect_material_id

  ! ==================================================================
  ! Circle tests
  ! ==================================================================

  @test
  subroutine test_circle_total_area()
    type(spatial_grid) :: grid
    integer, parameter :: nx = 100, ny = 100
    real(kind=dp), parameter :: dx = 0.1_dp, dy = 0.1_dp
    real(kind=dp), parameter :: cx = 5.0_dp, cy = 5.0_dp, radius = 4.0_dp
    real(kind=dp) :: total_area, expected_area, rel_err
    logical :: ok
    integer :: mat2d(nx, ny), ij

    mat2d = 1
    call grid_init_circle(grid, nx, ny, dx, dy, cx, cy, radius, mat2d)

    total_area = 0.0_dp
    do ij = 1, nx * ny
      total_area = total_area + grid%cell_volume(ij)
    end do
    total_area = total_area * dx * dy

    expected_area = pi_dp * radius**2
    rel_err = abs(total_area - expected_area) / expected_area
    ok = (rel_err < 0.01_dp)
    @assertTrue(ok)

    call grid_free(grid)
  end subroutine test_circle_total_area

  @test
  subroutine test_circle_outside_zero()
    type(spatial_grid) :: grid
    integer, parameter :: nx = 20, ny = 20
    real(kind=dp), parameter :: dx = 1.0_dp, dy = 1.0_dp
    real(kind=dp), parameter :: cx = 10.0_dp, cy = 10.0_dp, radius = 3.0_dp
    integer :: mat2d(nx, ny)
    integer :: ij

    mat2d = 1
    call grid_init_circle(grid, nx, ny, dx, dy, cx, cy, radius, mat2d)

    ij = (1-1)*nx + 1
    @assertEqual(0.0_dp, grid%cell_volume(ij), tolerance=1.0e-14_dp)
    @assertEqual(0, grid%material_id(ij))
    @assertEqual(0.0_dp, grid%face_fraction_x(ij, 1), tolerance=1.0e-14_dp)
    @assertEqual(0.0_dp, grid%face_fraction_y(ij, 1), tolerance=1.0e-14_dp)

    call grid_free(grid)
  end subroutine test_circle_outside_zero

  @test
  subroutine test_circle_center_inside()
    type(spatial_grid) :: grid
    integer, parameter :: nx = 20, ny = 20
    real(kind=dp), parameter :: dx = 1.0_dp, dy = 1.0_dp
    real(kind=dp), parameter :: cx = 10.0_dp, cy = 10.0_dp, radius = 8.0_dp
    integer :: mat2d(nx, ny)
    integer :: ij

    mat2d = 1
    call grid_init_circle(grid, nx, ny, dx, dy, cx, cy, radius, mat2d)

    ! Cell ix=10,iy=10 spans x=[9,10], y=[9,10]; all corners within radius 8
    ij = (10-1)*nx + 10
    @assertEqual(1.0_dp, grid%cell_volume(ij), tolerance=1.0e-14_dp)
    @assertEqual(1, grid%material_id(ij))

    call grid_free(grid)
  end subroutine test_circle_center_inside

  ! ==================================================================
  ! Hexagon tests
  ! ==================================================================

  @test
  subroutine test_hexagon_total_area()
    type(spatial_grid) :: grid
    integer, parameter :: nx = 80, ny = 80
    real(kind=dp), parameter :: dx = 0.1_dp, dy = 0.1_dp
    real(kind=dp), parameter :: cx = 4.0_dp, cy = 4.0_dp
    real(kind=dp), parameter :: side = 3.0_dp
    real(kind=dp) :: total_area, expected_area, rel_err
    logical :: ok
    integer :: mat2d(nx, ny), ij

    mat2d = 1
    call grid_init_hexagon(grid, nx, ny, dx, dy, cx, cy, side, mat2d)

    total_area = 0.0_dp
    do ij = 1, nx * ny
      total_area = total_area + grid%cell_volume(ij)
    end do
    total_area = total_area * dx * dy

    expected_area = 1.5_dp * sqrt(3.0_dp) * side**2
    rel_err = abs(total_area - expected_area) / expected_area
    ok = (rel_err < 0.02_dp)
    @assertTrue(ok)

    call grid_free(grid)
  end subroutine test_hexagon_total_area

  ! ==================================================================
  ! Polygon tests
  ! ==================================================================

  @test
  subroutine test_polygon_triangle_area()
    type(spatial_grid) :: grid
    integer, parameter :: nx = 100, ny = 100
    real(kind=dp), parameter :: dx = 0.1_dp, dy = 0.1_dp
    real(kind=dp) :: vx(3), vy(3)
    real(kind=dp) :: total_area, expected_area, rel_err
    logical :: ok
    integer :: mat2d(nx, ny), ij

    vx = [2.0_dp, 8.0_dp, 2.0_dp]
    vy = [2.0_dp, 2.0_dp, 8.0_dp]
    expected_area = 0.5_dp * 6.0_dp * 6.0_dp

    mat2d = 1
    call grid_init_polygon(grid, nx, ny, dx, dy, 3, vx, vy, mat2d)

    total_area = 0.0_dp
    do ij = 1, nx * ny
      total_area = total_area + grid%cell_volume(ij)
    end do
    total_area = total_area * dx * dy

    rel_err = abs(total_area - expected_area) / expected_area
    ok = (rel_err < 0.02_dp)
    @assertTrue(ok)

    call grid_free(grid)
  end subroutine test_polygon_triangle_area

  ! ==================================================================
  ! Coordinate consistency tests
  ! ==================================================================

  @test
  subroutine test_grid_coords_consistency()
    type(spatial_grid) :: grid
    integer, parameter :: nx = 5, ny = 7
    real(kind=dp), parameter :: dx = 0.5_dp, dy = 1.0_dp
    integer :: mat2d(nx, ny)
    integer :: ix, iy, ij

    mat2d = 1
    call grid_init_rect(grid, nx, ny, dx, dy, mat2d)
    call grid_build_coords(grid)

    @assertTrue(allocated(grid%coords))
    @assertEqual(2, size(grid%coords, 1))
    @assertEqual(nx * ny, size(grid%coords, 2))

    do iy = 1, ny
      do ix = 1, nx
        ij = (iy - 1) * nx + ix
        @assertEqual((ix - 0.5_dp) * dx, grid%coords(1, ij), tolerance=1.0e-14_dp)
        @assertEqual((iy - 0.5_dp) * dy, grid%coords(2, ij), tolerance=1.0e-14_dp)
      end do
    end do

    call grid_free(grid)
  end subroutine test_grid_coords_consistency

  @test
  subroutine test_grid_coord_arrays()
    type(spatial_grid) :: grid
    integer, parameter :: nx = 4, ny = 3
    real(kind=dp), parameter :: dx = 2.0_dp, dy = 3.0_dp
    integer :: mat2d(nx, ny)
    integer :: i

    mat2d = 1
    call grid_init_rect(grid, nx, ny, dx, dy, mat2d)

    @assertTrue(allocated(grid%x))
    @assertTrue(allocated(grid%z))
    @assertEqual(nx, size(grid%x))
    @assertEqual(ny, size(grid%z))

    do i = 1, nx
      @assertEqual((i - 0.5_dp) * dx, grid%x(i), tolerance=1.0e-14_dp)
    end do
    do i = 1, ny
      @assertEqual((i - 0.5_dp) * dy, grid%z(i), tolerance=1.0e-14_dp)
    end do

    call grid_free(grid)
  end subroutine test_grid_coord_arrays

  ! ==================================================================
  ! Ghost map tests
  ! ==================================================================

  @test
  subroutine test_rect_ghost_map()
    type(spatial_grid) :: grid
    integer, parameter :: nx = 3, ny = 3
    integer :: mat2d(nx, ny)
    integer :: ij

    mat2d = 1
    call grid_init_rect(grid, nx, ny, 1.0_dp, 1.0_dp, mat2d)

    ! Interior cell (2,2): neighbors should be immediate
    ij = (2-1)*nx + 2
    ! N (+y): (2,3) -> ij = (3-1)*3 + 2 = 8
    @assertEqual(8, grid%ghost_map(ij, 1))
    ! S (-y): (2,1) -> ij = (1-1)*3 + 2 = 2
    @assertEqual(2, grid%ghost_map(ij, 2))
    ! W (-x): (1,2) -> ij = (2-1)*3 + 1 = 4
    @assertEqual(4, grid%ghost_map(ij, 3))
    ! E (+x): (3,2) -> ij = (2-1)*3 + 3 = 6
    @assertEqual(6, grid%ghost_map(ij, 4))

    ! Boundary cell (1,1): S and W should map to self
    ij = (1-1)*nx + 1
    @assertEqual(ij, grid%ghost_map(ij, 2))
    @assertEqual(ij, grid%ghost_map(ij, 3))

    call grid_free(grid)
  end subroutine test_rect_ghost_map

  ! ==================================================================
  ! Grid free tests
  ! ==================================================================

  @test
  subroutine test_grid_free_resets()
    type(spatial_grid) :: grid
    integer :: mat2d(2, 2)

    mat2d = 1
    call grid_init_rect(grid, 2, 2, 1.0_dp, 1.0_dp, mat2d)
    call grid_free(grid)

    @assertEqual(0, grid%ndim)
    @assertEqual(1, grid%nx)
    @assertEqual(1, grid%ny)
    @assertEqual(0.0_dp, grid%dx)
    @assertEqual(0.0_dp, grid%dy)
    @assertFalse(allocated(grid%x))
    @assertFalse(allocated(grid%z))
    @assertFalse(allocated(grid%coords))
    @assertFalse(allocated(grid%cell_volume))
    @assertFalse(allocated(grid%ghost_map))
  end subroutine test_grid_free_resets

  ! ==================================================================
  ! init_wire_from_config integration tests
  ! ==================================================================

  @test
  subroutine test_wire_rect_single_material()
    ! Rectangle wire with single region: all cells active, material_id=1.
    type(simulation_config) :: cfg
    integer :: ij, ngrid
    real(kind=dp) :: xval, yval

    cfg%confinement = 2
    cfg%wire_nx = 5
    cfg%wire_ny = 5
    cfg%wire_dx = 2.0_dp
    cfg%wire_dy = 2.0_dp
    cfg%FDorder = 2

    ! Set grid dimensions (as init_grid_from_config would do)
    cfg%grid%ndim = 2
    cfg%grid%nx   = 5
    cfg%grid%ny   = 5
    cfg%grid%dx   = 2.0_dp
    cfg%grid%dy   = 2.0_dp

    cfg%wire_geom%shape = 'rectangle'

    ! Single region covering entire wire
    cfg%numRegions = 1
    allocate(cfg%regions(1))
    cfg%regions(1)%material = 'GaAs'
    cfg%regions(1)%inner = 0.0_dp
    cfg%regions(1)%outer = 100.0_dp  ! larger than any distance

    call init_wire_from_config(cfg)

    ngrid = 5 * 5

    ! All cells should be active (rectangle, fully inside)
    @assertTrue(allocated(cfg%grid%cell_volume))
    @assertTrue(allocated(cfg%grid%material_id))
    @assertTrue(allocated(cfg%grid%ghost_map))
    @assertTrue(allocated(cfg%grid%coords))

    do ij = 1, ngrid
      @assertEqual(1.0_dp, cfg%grid%cell_volume(ij), tolerance=1.0e-14_dp)
      @assertEqual(1.0_dp, cfg%grid%face_fraction_x(ij, 1), tolerance=1.0e-14_dp)
      @assertEqual(1.0_dp, cfg%grid%face_fraction_x(ij, 2), tolerance=1.0e-14_dp)
      @assertEqual(1.0_dp, cfg%grid%face_fraction_y(ij, 1), tolerance=1.0e-14_dp)
      @assertEqual(1.0_dp, cfg%grid%face_fraction_y(ij, 2), tolerance=1.0e-14_dp)
      @assertEqual(1, cfg%grid%material_id(ij))
    end do

    ! Coords should be cell-centered: x(1) = 0.5*dx = 1.0, y(1) = 0.5*dy = 1.0
    xval = cfg%grid%coords(1, 1)
    yval = cfg%grid%coords(2, 1)
    @assertEqual(1.0_dp, xval, tolerance=1.0e-14_dp)
    @assertEqual(1.0_dp, yval, tolerance=1.0e-14_dp)

    call grid_free(cfg%grid)
    deallocate(cfg%regions)
  end subroutine test_wire_rect_single_material

  @test
  subroutine test_wire_rect_two_regions()
    ! Rectangle wire with core (region 1, r<=4) and shell (region 2, r>4).
    ! Grid: 10x10, dx=dy=1. Grid center at (5,5).
    type(simulation_config) :: cfg
    integer :: ix, iy, ij
    real(kind=dp) :: cx, cy, dist

    cfg%confinement = 2
    cfg%wire_nx = 10
    cfg%wire_ny = 10
    cfg%wire_dx = 1.0_dp
    cfg%wire_dy = 1.0_dp
    cfg%FDorder = 2

    cfg%grid%ndim = 2
    cfg%grid%nx   = 10
    cfg%grid%ny   = 10
    cfg%grid%dx   = 1.0_dp
    cfg%grid%dy   = 1.0_dp

    cfg%wire_geom%shape = 'rectangle'

    ! Two concentric regions
    cfg%numRegions = 2
    allocate(cfg%regions(2))
    cfg%regions(1)%material = 'InAs'
    cfg%regions(1)%inner = 0.0_dp
    cfg%regions(1)%outer = 4.0_dp    ! core: r <= 4
    cfg%regions(2)%material = 'GaSb'
    cfg%regions(2)%inner = 4.0_dp
    cfg%regions(2)%outer = 100.0_dp  ! shell: r > 4

    call init_wire_from_config(cfg)

    ! Grid center is at (5, 5)
    cx = 5.0_dp
    cy = 5.0_dp

    ! Verify material_id is based on 2D distance from center
    do iy = 1, 10
      do ix = 1, 10
        ij = (iy - 1) * 10 + ix
        dist = sqrt(((ix - 0.5_dp) * 1.0_dp - cx)**2 + &
                    ((iy - 0.5_dp) * 1.0_dp - cy)**2)
        if (dist <= 4.0_dp) then
          @assertEqual(1, cfg%grid%material_id(ij))
        else
          @assertEqual(2, cfg%grid%material_id(ij))
        end if
      end do
    end do

    ! All cells should have volume=1 (rectangle)
    do ij = 1, 100
      @assertEqual(1.0_dp, cfg%grid%cell_volume(ij), tolerance=1.0e-14_dp)
    end do

    call grid_free(cfg%grid)
    deallocate(cfg%regions)
  end subroutine test_wire_rect_two_regions

end module test_geometry
